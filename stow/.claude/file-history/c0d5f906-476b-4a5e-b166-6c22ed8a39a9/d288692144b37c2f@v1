########################
## escalation policy
########################

resource "pagerduty_escalation_policy" "oac-escalation-sdk-ppcp" {
  name        = "PPCP Web Escalation Policy"
  description = "Managed by OaC in github, https://go/pd-config"
  teams       = [pagerduty_team.oac-team-sdk-ppcp.id]

  ########################
  ## Alert Schedule
  ########################
  rule {
    escalation_delay_in_minutes = 10

    target {
      type = "schedule_reference"
      id   = pagerduty_schedule.oac-schedule-sdk-ppcp-primary.id
    }
  }

  rule {
    escalation_delay_in_minutes = 10

    target {
      type = "schedule_reference"
      id   = pagerduty_schedule.oac-schedule-sdk-ppcp-backup.id
    }
  }

  ### page everyone

