const baseURL = "/commerceorchnodeserv/v2/firmly";
const createCartURL = `${baseURL}/cart`;
const updateCartURL = `${baseURL}/cart/firmly-cart-001`;
const completeCartURL = `${baseURL}/cart/firmly-cart-001/complete`;

const headers = {
  authorization: "Bearer test-token",
  "content-type": "application/json",
};

const createCartEvent = (
  overrides: Partial<any> = {}
): ALBEvent => ({
  requestContext: {
    elb: {
      targetGroupArn: "fake-arn",
    },
  },
  httpMethod: "POST",
  path: createCartURL,
  headers: headers,
  body: JSON.stringify({
    id: "id-00001",
    items: [
      {
        item_id: "PROD-123",
        quantity: 1,
        item_url: "https://firmly.com/products/test-product",
        price: {
          currency_code: "USD",
          value: "100.00"
        }
      },
    ],
    customer: {
      name: {
        given_name: "John",
        surname: "Doe"
      },
      email_address: "john.doe@example.com",
      phone: {
        country_code: "1",
        national_number: "7658675309"
      },
      ...overrides.customer,
    },
    shipping_address: {
      address_line_1: "222 Merchandise Mart Plz",
      address_line_2: "Ste 970",
      admin_area_1: "IL",
      admin_area_2: "CHICAGO",
      country_code: "US",
      postal_code: "60654-1133",
    },
    billing_address: {
      address_line_1: "234 W Russell St.",
      admin_area_1: "IL",
      admin_area_2: "Barrington",
      country_code: "US",
      postal_code: "60010",
    },
  }),
  isBase64Encoded: false,
  queryStringParameters: {},
  multiValueHeaders: {},
  multiValueQueryStringParameters: {},
});

const updateCartEvent = (): ALBEvent => ({
  requestContext: {
    elb: {
      targetGroupArn: "fake-arn",
    },
  },
  httpMethod: "PUT",
  path: updateCartURL,
  headers: headers,
  body: JSON.stringify({
    cart: {
      products: [
        {
          productId: "PROD-123",
          quantity: 2,
        },
      ],
    },
    operations: [
      {
        op: "replace",
        path: "/products/0/quantity",
        value: 2,
      },
    ],
  }),
  isBase64Encoded: false,
  queryStringParameters: {},
  multiValueHeaders: {},
  multiValueQueryStringParameters: {},
});

const completeCartEvent = (): ALBEvent => ({
  requestContext: {
    elb: {
      targetGroupArn: "fake-arn",
    },
  },
  httpMethod: "POST",
  path: completeCartURL,
  headers: headers,
  body: JSON.stringify({
    payment_method: {
      type: "paypal",
      payer_id: "PAYER-123456",
      token: "EC-TOKEN-123"
    },
    checkout_fields: [],
    accepted_policies: ["terms_of_service"]
  }),
  isBase64Encoded: false,
  queryStringParameters: {},
  multiValueHeaders: {},
  multiValueQueryStringParameters: {},
});

describe("Firmly Orchestrator", () => {
  let mockCreateCart: any;
  let mockCompleteCart: any;
  let mockUpdateCart: any;

  beforeEach(async () => {
    vi.clearAllMocks();

    // Get the mocks from the module
    const { __mocks } = await import("../../shared/firmly/controllers") as any;
    mockCreateCart = __mocks.createCart;
    mockCompleteCart = __mocks.completeCart;
    mockUpdateCart = __mocks.updateCart;

    // Reset mock implementations to defaults
    mockCreateCart.mockResolvedValue({
      id: "firmly-cart-001",
      status: "CREATED",
      ecToken: "EC-1234567890",
      totalAmount: {
        currency: "USD",
        value: "125.00",
      },
      taxAmount: {
        currency: "USD",
        value: "10.00",
      },
      shippingOptions: [
        {
          id: "standard",
          label: "Standard Shipping",
          amount: {
            currency: "USD",
            value: "5.00",
          },
          selected: true,
        },
        {
          id: "express",
          label: "Express Shipping",
          amount: {
            currency: "USD",
            value: "15.00",
          },
          selected: false,
        },
      ],
      paymentMethodOptions: [
        {
          type: "PAYPAL",
          description: "PayPal",
        },
      ],
    });

    mockCompleteCart.mockResolvedValue({
      id: "firmly-cart-001",
      status: "COMPLETED",
      orderId: "ORDER-123456",
      confirmationUrl: "https://firmly.com/order/confirmation/ORDER-123456",
    });

    mockUpdateCart.mockResolvedValue({
      id: "firmly-cart-001",
      status: "UPDATED",
      totalAmount: {
        currency: "USD",
        value: "130.00",
      },
    });

    process.env.APP_ENV = "test";
    process.env.SECRET_PATH = "fake-secret-path";

    SecretsManagerHelper.getInstance = vi.fn().mockReturnValue({
      getSecret: vi.fn().mockResolvedValue({
        firmly: JSON.stringify({
          api_key: "test-api-key",
          api_secret: "test-api-secret",
          merchant_id: "test-merchant-id",
        }),
      }),
    });
  });

  describe("create cart", () => {
    test("creates a cart successfully", async () => {
      const response = await app.request(
        createCartURL,
        {
          method: "POST",
        },
        {
          event: createCartEvent(),
        }
      );
      const responseBody = await response.json();

      expect(response.status).toBe(201);
      expect(responseBody.id).toEqual("firmly-cart-001");
      expect(responseBody.status).toEqual("CREATED");
      expect(responseBody.ecToken).toEqual("EC-1234567890");
      expect(responseBody.totalAmount.value).toEqual("125.00");
      expect(responseBody.shippingOptions).toHaveLength(2);
      expect(responseBody.paymentMethodOptions).toHaveLength(1);
    });

    test("handles validation errors", async () => {
      const invalidEvent = createCartEvent();
      // Make the body invalid - items array must have at least 1 item when provided
      invalidEvent.body = JSON.stringify({
        items: [], // Empty items array is invalid (min 1 required)
      });

      const response = await app.request(
        createCartURL,
        {
          method: "POST",
        },
        {
          event: invalidEvent,
        }
      );

      expect(response.status).toBe(400);
      const responseBody = await response.json();
      expect(responseBody.name).toEqual("BadRequestError");
    });

    test.each([
      {
        description: "handles out of stock error",
        mockError: new OutOfStockError("", {
          details: [
            {
              description: "Product is out of stock",
              issue: "ITEM_OUT_OF_STOCK",
            },
          ],
        }),
        expectedStatus: 422,
      },
      {
        description: "handles shipping zone error",
        mockError: new ShippingZoneNotCoveredError("", {
          details: [
            {
              description: "Cannot ship to this address",
            },
          ],
        }),
        expectedStatus: 422,
      },
    ])("$description", async ({ mockError, expectedStatus }) => {
      // Mock the createCart to reject with error
      mockCreateCart.mockRejectedValueOnce(mockError);

      const event = createCartEvent();
      const response = await app.request(
        createCartURL,
        { method: "POST" },
        { event }
      );

      const [, errorResponse] = convertErrorToLambdaResponse(mockError, event);
      const expectedBody = JSON.parse(errorResponse.body);

      expect(response.status).toBe(expectedStatus);
      expect(await response.json()).toEqual(expectedBody);
    });
  });

  describe("update cart", () => {
    test("updates a cart successfully", async () => {
      const response = await app.request(
        updateCartURL,
        {
          method: "PUT",
        },
        {
          event: updateCartEvent(),
        }
      );
      const responseBody = await response.json();

      expect(response.status).toBe(200);
      expect(responseBody.id).toEqual("firmly-cart-001");
      expect(responseBody.status).toEqual("UPDATED");
      expect(responseBody.totalAmount.value).toEqual("130.00");
    });
  });

  describe("complete cart", () => {
    test("completes a cart successfully", async () => {
      const response = await app.request(
        completeCartURL,
        {
          method: "POST",
        },
        {
          event: completeCartEvent(),
        }
      );
      const responseBody = await response.json();

      expect(response.status).toBe(201);
      expect(responseBody.id).toEqual("firmly-cart-001");
      expect(responseBody.status).toEqual("COMPLETED");
      expect(responseBody.orderId).toEqual("ORDER-123456");
      expect(responseBody.confirmationUrl).toBeDefined();
    });

   // commented out test for missing payment details - for now
    test("handles missing payment details", async () => {
      // Configure mock to throw error for missing payer_id
      mockCompleteCart.mockImplementation((args: any) => {
        if (!args.data.payment_method?.payer_id) {
          throw new BadRequestError("unknown", {
            details: [{ description: "A valid payer id is required" }],
          });
        }
        return Promise.resolve({
          id: "firmly-cart-001",
          status: "COMPLETED",
        });
      });

      const invalidEvent = completeCartEvent();
      invalidEvent.body = JSON.stringify({
        payment_method: {
          type: "paypal",
          // Missing payer_id
        },
        checkout_fields: [],
        accepted_policies: ["terms_of_service"]
      });

      const response = await app.request(
        completeCartURL,
        {
          method: "POST",
        },
        {
          event: invalidEvent,
        }
      );

      expect(response.status).toBe(400);
      const responseBody = await response.json();
      expect(responseBody.name).toEqual("BadRequestError");
    });
  });
});