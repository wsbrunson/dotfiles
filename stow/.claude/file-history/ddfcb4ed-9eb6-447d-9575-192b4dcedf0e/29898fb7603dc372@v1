import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { ALBEvent } from "aws-lambda";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { CartController } from "./CartController";
import { CheckOutController } from "./CheckOutController";
import { CheckoutSession } from "./CheckoutSession";
import {
  InternalServerError,
  ProductDiscontinuedError,
  OutOfStockError,
  PaymentDeclinedError,
  PaymentExpiredError,
  ShippingZoneNotCoveredError,
  ConnectionResetError,
  ServiceUnavailableError,
} from "../../shared/errors";
import { verifyAppContext } from "../../shared/helpers/AppContextAuthorizer";
import { getCacheImplementation } from "../../shared/cache/cacheFactory";
import {
  trackInitiatedAddCart,
  trackSuccessAddCart,
  trackFailedAddCart,
} from "../../shared/metrics/emitMetric";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";

vi.mock("./CartController");
vi.mock("./CheckOutController");
vi.mock("./CheckoutSession");
vi.mock("../../shared/cache/cacheFactory");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");

const validCreateCartRequest = {
  cartId: "valid-cart",
  merchantUrl: "https://apple.com",
  products: [
    {
      productId: "product-1",
      quantity: 1,
    },
  ],
  shippingAddress: {
    addressLine1: "123 Main St",
    addressLine2: "Apartment 4B",
    adminArea2: "Los Angeles",
    adminArea1: "CA",
    postalCode: "90001",
    countryCode: "US",
  },
  customer: {
    id: "customer-1",
    email: "customer@example.com",
  },
};

const mockCartResponse = {
  status: "success",
  cartTotal: "$110.25",
  cartTax: "$10.25",
};

const mockCheckoutSession = {
  paypal_payment_link: "https://paypal.com/checkout?token=EC-12345",
};

describe("Apple Create Cart Lambda Handler", () => {
  let mockEvent: ALBEvent;

  beforeEach(() => {
    mockEvent = getMockALBEvent({
      body: JSON.stringify(validCreateCartRequest),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });
    vi.mocked(verifyAppContext).mockReturnValue(true);
    const mockCache = {
      set: vi.fn().mockResolvedValue(undefined),
      get: vi.fn().mockResolvedValue(null),
      delete: vi.fn().mockResolvedValue(undefined),
    };
    vi.mocked(getCacheImplementation).mockReturnValue(mockCache);
    vi.mocked(trackInitiatedAddCart).mockResolvedValue(undefined);
    vi.mocked(trackSuccessAddCart).mockResolvedValue(undefined);
    vi.mocked(trackFailedAddCart).mockResolvedValue(undefined);
    vi.mocked(CheckoutSession).mockImplementation(() => mockCheckoutSession as any);
    vi.mocked(CartController).mockImplementation(() => ({
      cartFlowOrchestrator: vi.fn().mockResolvedValue(mockCartResponse),
    }) as any);
    vi.mocked(CheckOutController).mockImplementation(() => ({
      checkoutOrchestrator: vi.fn().mockResolvedValue(undefined),
    }) as any);
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  it("should create a cart successfully", async () => {
    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(200);
    expect(JSON.parse(response.body)).toMatchObject({
      ecToken: "EC-12345",
      status: "success",
      paymentMethodOptions: expect.arrayContaining([
        expect.objectContaining({
          type: "PAYPAL",
          description: "PayPal",
        }),
      ]),
      shippingOptions: expect.any(Array),
      totalAmount: expect.objectContaining({
        currency: "USD",
        value: "110.25",
      }),
      taxAmount: expect.objectContaining({
        currency: "USD",
        value: "10.25",
      }),
    });
  });

  it("should throw UnauthorizedError when app context verification fails", async () => {
    vi.mocked(verifyAppContext).mockReturnValue(false);

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(401);
    expect(JSON.parse(response.body)).toMatchObject({
      message: expect.stringContaining("Unauthorized"),
    });
  });

  it("should throw BadRequestError when merchant URL is missing", async () => {
    const requestWithoutMerchantUrl = { ...validCreateCartRequest };
    // @ts-expect-error deleting a required field
    delete requestWithoutMerchantUrl.merchantUrl;

    mockEvent = getMockALBEvent({
      body: JSON.stringify(requestWithoutMerchantUrl),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody).toMatchObject({
      details: expect.arrayContaining([
        expect.objectContaining({
          description: expect.stringContaining("Merchant URL is required"),
        }),
      ]),
    });
  });

  it("should handle ProductDiscontinuedError when Apple returns product variant does not exist error", async () => {
    vi.mocked(CartController).mockImplementation(() => ({
      cartFlowOrchestrator: vi.fn().mockRejectedValue(
        new ProductDiscontinuedError("test-debug-id", {
          details: [
            {
              description:
                "The merchandise with id does not exist on Apple store.",
            },
          ],
        })
      ),
    }) as any);

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(422);
    const responseBody = JSON.parse(response.body);
    expect(responseBody).toMatchObject({
      details: expect.arrayContaining([
        expect.objectContaining({
          description: expect.stringContaining("does not exist"),
        }),
      ]),
    });
  });

  it("should handle OutOfStockError when Apple returns out of stock error", async () => {
    vi.mocked(CartController).mockImplementation(() => ({
      cartFlowOrchestrator: vi.fn().mockRejectedValue(
        new OutOfStockError("test-debug-id", {
          details: [
            {
              description:
                "Product is out of stock at the Apple store location",
            },
          ],
        })
      ),
    }) as any);

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(422);
    const responseBody = JSON.parse(response.body);
    expect(responseBody).toMatchObject({
      details: expect.arrayContaining([
        expect.objectContaining({
          description: expect.stringContaining(
            "out of stock at the Apple store location"
          ),
        }),
      ]),
    });
  });

  it("should handle invalid request schema", async () => {
    const invalidRequest = {
      cartId: "valid-cart",
    };

    mockEvent = getMockALBEvent({
      body: JSON.stringify(invalidRequest),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.name).toBe("BadRequestError");
  });

  it("should handle errors during cart creation", async () => {
    vi.mocked(CartController).mockImplementation(() => ({
      cartFlowOrchestrator: vi.fn().mockRejectedValue(new Error("Network error")),
    }) as any);

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(500);
    expect(JSON.parse(response.body)).toMatchObject({
      name: "UnknownError",
    });
  });

  it("should handle errors during checkout orchestration", async () => {
    vi.mocked(CheckOutController).mockImplementation(() => ({
      checkoutOrchestrator: vi.fn().mockRejectedValue(
        new InternalServerError("test-debug-id", {
          details: [{ description: "Failed to process checkout" }],
        })
      ),
    }) as any);

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(500);
    const responseBody = JSON.parse(response.body);
    expect(responseBody).toMatchObject({
      details: expect.arrayContaining([
        expect.objectContaining({
          description: expect.stringContaining("Failed to process checkout"),
        }),
      ]),
    });
  });

  it("should track metrics for successful operations", async () => {
    await handler(mockEvent);

    expect(trackInitiatedAddCart).toHaveBeenCalledWith({
      orchestrator: "Apple",
      merchantUrl: "https://apple.com",
    });

    expect(trackSuccessAddCart).toHaveBeenCalledWith({
      orchestrator: "Apple",
      merchantUrl: "https://apple.com",
      status: "201",
      duration: expect.any(Number),
    });
  });

  it("should track metrics for failed operations", async () => {
    vi.mocked(CartController).mockImplementation(() => ({
      cartFlowOrchestrator: vi.fn().mockRejectedValue(new Error("Network error")),
    }) as any);

    await handler(mockEvent);

    expect(trackInitiatedAddCart).toHaveBeenCalledWith({
      orchestrator: "Apple",
      merchantUrl: "https://apple.com",
    });

    expect(trackFailedAddCart).toHaveBeenCalledWith({
      orchestrator: "Apple",
      merchantUrl: "https://apple.com",
      status: "500",
    });
  });

  it("should truncate postal codes to 5 characters for Apple compatibility", async () => {
    const requestWithLongPostalCode = {
      ...validCreateCartRequest,
      shippingAddress: {
        ...validCreateCartRequest.shippingAddress,
        postalCode: "900123456789",
      },
    };

    mockEvent = getMockALBEvent({
      body: JSON.stringify(requestWithLongPostalCode),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(200);
  });

  describe("Additional Error Scenarios", () => {
    it("should handle PaymentDeclinedError", async () => {
      vi.mocked(CartController).mockImplementation(() => ({
        cartFlowOrchestrator: vi.fn().mockRejectedValue(
          new PaymentDeclinedError("test-debug-id", {
            details: [
              {
                description: "Payment was declined by Apple Pay",
              },
            ],
          })
        ),
      }) as any);

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(422);
      const responseBody = JSON.parse(response.body);
      expect(responseBody).toMatchObject({
        name: "PaymentDeclinedError",
        details: expect.arrayContaining([
          expect.objectContaining({
            issue: "PAYMENT_DECLINED",
          }),
        ]),
      });
    });

    it("should handle PaymentExpiredError", async () => {
      vi.mocked(CheckOutController).mockImplementation(() => ({
        checkoutOrchestrator: vi.fn().mockRejectedValue(
          new PaymentExpiredError("test-debug-id", {
            details: [
              {
                description: "Apple Pay authorization has expired",
              },
            ],
          })
        ),
      }) as any);

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(422);
      const responseBody = JSON.parse(response.body);
      expect(responseBody).toMatchObject({
        name: "PaymentExpiredError",
        details: expect.arrayContaining([
          expect.objectContaining({
            issue: "PAYMENT_EXPIRED",
          }),
        ]),
      });
    });

    it("should handle ShippingZoneNotCoveredError", async () => {
      vi.mocked(CartController).mockImplementation(() => ({
        cartFlowOrchestrator: vi.fn().mockRejectedValue(
          new ShippingZoneNotCoveredError("test-debug-id", {
            details: [
              {
                description: "Shipping is not available to this Apple store location",
              },
            ],
          })
        ),
      }) as any);

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(422);
      const responseBody = JSON.parse(response.body);
      expect(responseBody).toMatchObject({
        name: "ShippingZoneNotCoveredError",
        details: expect.arrayContaining([
          expect.objectContaining({
            issue: "SHIPPING_ZONE_NOT_COVERED",
          }),
        ]),
      });
    });

    it("should handle ConnectionResetError", async () => {
      vi.mocked(CartController).mockImplementation(() => ({
        cartFlowOrchestrator: vi.fn().mockRejectedValue(
          new ConnectionResetError("test-debug-id", {
            details: [
              {
                description: "Connection was reset by Apple server",
              },
            ],
          })
        ),
      }) as any);

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(503);
      const responseBody = JSON.parse(response.body);
      expect(responseBody).toMatchObject({
        name: "ConnectionResetError",
        details: expect.arrayContaining([
          expect.objectContaining({
            issue: "CONNECTION_RESET",
          }),
        ]),
      });
    });

    it("should handle ServiceUnavailableError", async () => {
      vi.mocked(CheckOutController).mockImplementation(() => ({
        checkoutOrchestrator: vi.fn().mockRejectedValue(
          new ServiceUnavailableError("test-debug-id", {
            details: [
              {
                description: "Apple store service is temporarily unavailable",
              },
            ],
          })
        ),
      }) as any);

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(503);
      const responseBody = JSON.parse(response.body);
      expect(responseBody).toMatchObject({
        name: "ServiceUnavailableError",
      });
    });

    it("should handle cache set failure gracefully", async () => {
      const mockCache = {
        set: vi.fn().mockRejectedValue(new Error("Redis connection failed")),
        get: vi.fn().mockResolvedValue(null),
        delete: vi.fn().mockResolvedValue(undefined),
      };
      vi.mocked(getCacheImplementation).mockReturnValue(mockCache);

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(500);
      expect(JSON.parse(response.body)).toMatchObject({
        name: "UnknownError",
      });
    });

    it("should handle malformed JSON in request body", async () => {
      mockEvent = getMockALBEvent({
        body: '{"cartId": "test", "malformed": }',
        headers: {
          "paypal-application-context": "valid-token",
        },
      });

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(500);
      expect(JSON.parse(response.body)).toMatchObject({
        name: "UnknownError",
      });
    });

    it("should handle missing billingAddress gracefully", async () => {
      const requestWithoutBillingAddress = {
        ...validCreateCartRequest,
        billingAddress: undefined,
      };

      mockEvent = getMockALBEvent({
        body: JSON.stringify(requestWithoutBillingAddress),
        headers: {
          "paypal-application-context": "valid-token",
        },
      });

      const response = await handler(mockEvent);

      expect(response.statusCode).toBe(200);
    });
  });
});