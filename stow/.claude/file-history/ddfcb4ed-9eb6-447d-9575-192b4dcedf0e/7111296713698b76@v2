import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { ALBEvent } from "aws-lambda";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { BigCommerceController } from "../../shared/big-commerce/controllers";
import { getCacheImplementation } from "../../shared/cache/cacheFactory";
import { verifyAppContext } from "../../shared/helpers/AppContextAuthorizer";
import {
  trackInitiatedUpdateCart,
  trackSuccessUpdateCart,
  trackFailedUpdateCart,
} from "../../shared/metrics/emitMetric";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";

vi.mock("../../shared/big-commerce/controllers");
vi.mock("../../shared/cache/cacheFactory");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");
vi.mock("../../shared/metrics/alarm-metrics");
vi.mock("../../shared/simulator/server", () => ({
  stopSimulator: vi.fn(),
}));

const validUpdateCartRequest = {
  operations: [
    {
      op: "replace",
      path: "/products/0/quantity",
      value: 3
    }
  ],
  cart: {
    cartId: "cart-123",
    merchantUrl: "https://store.mybigcommerce.com",
    products: [{ productId: "123", quantity: 3 }],
    customer: {
      firstName: "John",
      lastName: "Doe",
      email: "test@paypal.com",
      phone: "1234567890",
    },
    shippingAddress: {
      addressLine1: "123 Main Street",
      addressLine2: "Apt 4B",
      adminArea1: "CA",
      adminArea2: "San Francisco",
      postalCode: "94105",
      countryCode: "US",
    },
    billingAddress: {
      addressLine1: "456 Oak Avenue",
      addressLine2: "Suite 200",
      adminArea1: "NY",
      adminArea2: "New York",
      postalCode: "10001",
      countryCode: "US",
    },
    shippingOptions: [
      {
        id: "option-1",
        label: "Standard Shipping",
        amount: { currency: "USD", value: "5.99" },
        selected: true,
      },
      {
        id: "option-2",
        label: "Express Shipping",
        amount: { currency: "USD", value: "12.99" },
        selected: false,
      }
    ]
  }
};

const validUpdateCartResponse = {
  ecToken: "EC-05M26943AN872754R",
  status: "success",
  paymentMethodOptions: [{ type: "PAYPAL", description: "PayPal" }],
  shippingOptions: [
    {
      id: "option-1",
      label: "Standard Shipping",
      amount: { currency: "USD", value: "5.99" },
      selected: true,
    },
    {
      id: "option-2",
      label: "Express Shipping",
      amount: { currency: "USD", value: "12.99" },
      selected: false,
    }
  ],
  totalAmount: {
    currency: "USD",
    value: "115.97",
  },
  taxAmount: {
    currency: "USD",
    value: "9.98",
  },
  links: [
    {
      rel: "approval_url",
      href: "https://www.paypal.com/approval_url",
      method: "GET",
    },
  ],
};

describe("bigc-update-cart handler", () => {
  let mockCache: any;
  let mockBigCommerceController: any;

  beforeEach(() => {
    mockCache = {
      set: vi.fn(),
      get: vi.fn().mockResolvedValue(null),
      delete: vi.fn(),
    };

    mockBigCommerceController = {
      updateCart: vi.fn(),
      cache: mockCache, // Add cache property to the mock controller
      startSimulator: vi.fn().mockResolvedValue(undefined), // Add startSimulator method
    };

    vi.mocked(getCacheImplementation).mockReturnValue(mockCache);
    vi.mocked(BigCommerceController).mockImplementation(
      () => mockBigCommerceController
    );
    vi.mocked(verifyAppContext).mockReturnValue(true);
    vi.mocked(trackInitiatedUpdateCart).mockResolvedValue(undefined);
    vi.mocked(trackSuccessUpdateCart).mockResolvedValue(undefined);
    vi.mocked(trackFailedUpdateCart).mockResolvedValue(undefined);
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  it("should successfully update a cart", async () => {
    mockBigCommerceController.updateCart.mockResolvedValue(validUpdateCartResponse);

    const event: ALBEvent = getMockALBEvent({
      body: JSON.stringify(validUpdateCartRequest),
      headers: {
        "content-type": "application/json",
        "paypal-correlation-id": "test-correlation-id",
      },
    });

    const response = await handler(event);

    expect(response.statusCode).toBe(200);
    expect(response.headers["Content-Type"]).toBe("application/json");

    const body = JSON.parse(response.body);
    expect(body).toEqual(validUpdateCartResponse);

    expect(mockBigCommerceController.updateCart).toHaveBeenCalledWith({
      data: {
        operations: validUpdateCartRequest.operations,
        cart: {
          products: validUpdateCartRequest.cart.products,
          customer: validUpdateCartRequest.cart.customer,
          shippingAddress: validUpdateCartRequest.cart.shippingAddress,
          billingAddress: validUpdateCartRequest.cart.billingAddress,
          shippingOptions: validUpdateCartRequest.cart.shippingOptions,
        }
      },
      request: event,
    });
  });

  it("should return 400 for invalid request body", async () => {
    const invalidRequest = {
      ...validUpdateCartRequest,
      operations: undefined, // Remove required field
    };

    const event: ALBEvent = getMockALBEvent({
      body: JSON.stringify(invalidRequest),
    });

    const response = await handler(event);

    expect(response.statusCode).toBe(400);
    expect(response.headers["Content-Type"]).toBe("application/json");

    const body = JSON.parse(response.body);
    expect(body).toHaveProperty("name", "BadRequestError");
    expect(body).toHaveProperty("status", 400);
  });

  it("should handle JSON parse errors", async () => {
    const event: ALBEvent = getMockALBEvent({
      body: "invalid-json",
    });

    const response = await handler(event);

    expect(response.statusCode).toBe(500);
    expect(response.headers["Content-Type"]).toBe("application/json");

    const body = JSON.parse(response.body);
    expect(body).toHaveProperty("name", "InternalServerError");
  });

  it("should handle controller errors", async () => {
    mockBigCommerceController.updateCart.mockRejectedValue(
      new Error("Controller error")
    );

    const event: ALBEvent = getMockALBEvent({
      body: JSON.stringify(validUpdateCartRequest),
    });

    const response = await handler(event);

    expect(response.statusCode).toBe(500);
    expect(response.headers["Content-Type"]).toBe("application/json");

    const body = JSON.parse(response.body);
    expect(body).toHaveProperty("name", "InternalServerError");
    expect(body).toHaveProperty("status", 500);
  });

  describe("Authorization", () => {
    it("should return 401 when AppContext verification fails", async () => {
      vi.mocked(verifyAppContext).mockReturnValue(false);

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(validUpdateCartRequest),
        headers: {
          "paypal-application-context": "invalid-token",
        },
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(401);
      expect(response.headers["Content-Type"]).toBe("application/json");

      const body = JSON.parse(response.body);
      expect(body).toHaveProperty("name", "UnauthorizedError");
      expect(body).toHaveProperty("status", 401);
      expect(mockBigCommerceController.updateCart).not.toHaveBeenCalled();
    });

    it("should proceed when AppContext verification succeeds", async () => {
      vi.mocked(verifyAppContext).mockReturnValue(true);
      mockBigCommerceController.updateCart.mockResolvedValue(
        validUpdateCartResponse
      );

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(validUpdateCartRequest),
        headers: {
          "paypal-application-context": "valid-token",
        },
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(200);
      expect(verifyAppContext).toHaveBeenCalledWith(event);
      expect(mockBigCommerceController.updateCart).toHaveBeenCalled();
    });
  });

  describe("Request Validation", () => {
    it("should handle missing required fields", async () => {
      const invalidRequest = { ...validUpdateCartRequest, cart: undefined };

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(invalidRequest),
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(400);
      expect(mockBigCommerceController.updateCart).not.toHaveBeenCalled();
      expect(trackFailedUpdateCart).toHaveBeenCalledWith({
        orchestrator: "BigCommerce",
        merchantUrl: "",
        status: "400",
      });
    });

    it("should handle missing operations field", async () => {
      const invalidRequest = { ...validUpdateCartRequest, operations: undefined };

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(invalidRequest),
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(400);
      expect(mockBigCommerceController.updateCart).not.toHaveBeenCalled();
    });
  });

  describe("Error Handling", () => {
    it("should handle different error types properly", async () => {
      const customError = new Error("Custom error message");
      mockBigCommerceController.updateCart.mockRejectedValue(customError);

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(validUpdateCartRequest),
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(500);
      expect(response.headers["Content-Type"]).toBe("application/json");

      const body = JSON.parse(response.body);
      expect(body).toHaveProperty("name", "InternalServerError");
      expect(body).toHaveProperty("status", 500);
    });
  });

  describe("Quantity Update", () => {
    it("should handle quantity updates correctly", async () => {
      const quantityUpdateRequest = {
        ...validUpdateCartRequest,
        operations: [
          {
            op: "replace",
            path: "/products/0/quantity",
            value: 5
          }
        ],
        cart: {
          ...validUpdateCartRequest.cart,
          products: [{ productId: "123", quantity: 5 }]
        }
      };

      mockBigCommerceController.updateCart.mockResolvedValue({
        ...validUpdateCartResponse,
        totalAmount: { currency: "USD", value: "159.95" }
      });

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(quantityUpdateRequest),
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(200);
      expect(mockBigCommerceController.updateCart).toHaveBeenCalledWith({
        data: {
          operations: quantityUpdateRequest.operations,
          cart: {
            products: quantityUpdateRequest.cart.products,
            customer: quantityUpdateRequest.cart.customer,
            shippingAddress: quantityUpdateRequest.cart.shippingAddress,
            billingAddress: quantityUpdateRequest.cart.billingAddress,
            shippingOptions: quantityUpdateRequest.cart.shippingOptions,
          }
        },
        request: event,
      });
    });
  });

  describe("Shipping Update", () => {
    it("should handle shipping option selection updates", async () => {
      const shippingUpdateRequest = {
        ...validUpdateCartRequest,
        operations: [
          {
            op: "replace",
            path: "/shippingOptions/0/selected",
            value: false
          },
          {
            op: "replace",
            path: "/shippingOptions/1/selected",
            value: true
          }
        ],
        cart: {
          ...validUpdateCartRequest.cart,
          shippingOptions: [
            {
              id: "option-1",
              label: "Standard Shipping",
              amount: { currency: "USD", value: "5.99" },
              selected: false,
            },
            {
              id: "option-2",
              label: "Express Shipping",
              amount: { currency: "USD", value: "12.99" },
              selected: true,
            }
          ]
        }
      };

      mockBigCommerceController.updateCart.mockResolvedValue({
        ...validUpdateCartResponse,
        shippingOptions: [
          {
            id: "option-1",
            label: "Standard Shipping",
            amount: { currency: "USD", value: "5.99" },
            selected: false,
          },
          {
            id: "option-2",
            label: "Express Shipping",
            amount: { currency: "USD", value: "12.99" },
            selected: true,
          }
        ]
      });

      const event: ALBEvent = getMockALBEvent({
        body: JSON.stringify(shippingUpdateRequest),
      });

      const response = await handler(event);

      expect(response.statusCode).toBe(200);
      expect(mockBigCommerceController.updateCart).toHaveBeenCalledWith({
        data: {
          operations: shippingUpdateRequest.operations,
          cart: {
            products: shippingUpdateRequest.cart.products,
            customer: shippingUpdateRequest.cart.customer,
            shippingAddress: shippingUpdateRequest.cart.shippingAddress,
            billingAddress: shippingUpdateRequest.cart.billingAddress,
            shippingOptions: shippingUpdateRequest.cart.shippingOptions,
          }
        },
        request: event,
      });
    });
  });
});