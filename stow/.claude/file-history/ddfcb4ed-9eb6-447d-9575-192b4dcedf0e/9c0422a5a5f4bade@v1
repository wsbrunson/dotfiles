import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { getMockLambdaContext } from "../../shared/test-utils/mockLambdaContext";

// Mock all dependencies first
vi.mock("../../shared/schemas/openapi-schemas");
vi.mock("../../shared/logger/logger", () => ({
  logger: vi.fn(() => ({
    info: vi.fn(),
    error: vi.fn(),
    debug: vi.fn(),
    warn: vi.fn(),
  })),
}));
vi.mock("../../shared/cache");
vi.mock("shared/cache/cacheFactory");
vi.mock("shared/helpers/AppContextAuthorizer");
vi.mock("shared/wix/wix-client");
vi.mock("shared/metrics/emitMetric");
vi.mock("shared/metrics/alarm-metrics");
vi.mock("../../shared/errors");
vi.mock("../../shared/utils");
vi.mock("shared/helpers/extractCartId");
vi.mock("shared/simulator/server");
vi.mock("shared/helpers/SecretsManagerHelper");

// Import mocked modules
import {
    completeCheckoutRequestSchema,
} from "../../shared/schemas/openapi-schemas";
import { logger } from "../../shared/logger/logger";
import { getCacheImplementation } from "shared/cache/cacheFactory";
import { verifyAppContext } from "shared/helpers/AppContextAuthorizer";
import { WixClient } from "shared/wix/wix-client";
import {
    trackInitiatedPaymentFireAndForget,
    trackFailedPaymentFireAndForget,
    trackSuccessPaymentFireAndForget
} from "shared/metrics/emitMetric";
import {
    sendPaymentInitiatedAlarmMetricFireAndForget,
    sendPaymentSuccessAlarmMetricFireAndForget,
    sendPaymentFailureAlarmMetricFireAndForget
} from "shared/metrics/alarm-metrics";
import * as errors from "../../shared/errors";
import { extractCartIdFromCompleteRoute } from "shared/helpers/extractCartId";
import { isProduction } from "../../shared/utils";
import { startSimulatorV2, stopSimulator } from "shared/simulator/server";
import { SecretsManagerHelper } from "shared/helpers/SecretsManagerHelper";

// We'll dynamically import the handler in tests since it uses exports.handler

describe("WixCompleteCart Handler", () => {
    let handler: any;
    const mockLog = {
        info: vi.fn(),
        error: vi.fn(),
        debug: vi.fn(),
        warn: vi.fn(),
    };

    const mockCache = {
        set: vi.fn(),
        get: vi.fn(),
        delete: vi.fn(),
    };

    const mockWixClient = {
        completeCart: vi.fn(),
    };

    const mockEvent = {
        body: JSON.stringify({
            id: "test-cart-123",
            payment_method: {
                token: "test-payment-token",
                payer_id: "test-payer-id",
                type: "paypal",
            },
        }),
        path: "/commerceorchnodeserv/wix/cart/test-cart-123/complete",
        params: {
            id: "test-cart-123",
        },
        headers: {
            "x-correlation-id": "test-correlation-id",
        },
    };

    const mockCompleteCheckoutData = {
        id: "test-cart-123",
        payment_method: {
            token: "test-payment-token",
            payer_id: "test-payer-id",
            type: "paypal" as const,
        },
    };

    const mockCompletedCart = {
        id: "wix-cart-456",
        status: "COMPLETED" as const,
        validation_status: "VALID" as const,
        validation_issues: [],
        payment_confirmation: {
            merchant_order_number: "ORDER-789",
            order_review_page: "https://yourstore.com/orders/789"
        },
        totals: {
            total: {
                currency_code: "USD",
                value: "29.99",
            },
        },
    };

    beforeEach(async () => {
        vi.clearAllMocks();

        // Set up environment variable for secrets
        process.env.SECRET_PATH = "test-secret-path";

        // Mock SecretsManagerHelper
        vi.mocked(SecretsManagerHelper.getInstance).mockReturnValue({
            getSecret: vi.fn().mockResolvedValue({
                clientId: "test-client-id",
                clientSecret: "test-client-secret",
            }),
        } as any);

        // Import handler dynamically after mocks are setup
        const indexModule = await import("./index") as any;
        handler = indexModule.handler;

        // Setup mocks
        vi.mocked(logger).mockReturnValue(mockLog);
        vi.mocked(getCacheImplementation).mockReturnValue(mockCache);
        vi.mocked(errors.getCorrelationIdFromRequest).mockReturnValue("test-correlation-id");
        vi.mocked(extractCartIdFromCompleteRoute).mockReturnValue("test-cart-123");
        mockCache.get.mockResolvedValue(JSON.stringify({
            wixResponse: { id: "wix-cart-456" },
            originalRequest: {}
        }));
        vi.mocked(errors.convertErrorToLambdaResponse).mockImplementation((error) => {
            const debugId = "test-correlation-id";
            const headers = { "Content-Type": "application/json", "paypal-debug-id": debugId };

            if (error instanceof errors.UnauthorizedError) {
                return [error, { statusCode: 401, body: JSON.stringify({ name: "UnauthorizedError" }), headers }];
            } else if (error instanceof errors.BadRequestError) {
                return [error, { statusCode: 400, body: JSON.stringify({ name: "BadRequestError" }), headers }];
            }

            const apiError = new errors.APIError(debugId, {
                name: "UnknownError",
                status: 500,
                message: "Internal Server Error"
            });
            return [apiError, { statusCode: 500, body: JSON.stringify({ name: "UnknownError" }), headers }];
        });
        vi.mocked(errors.logAPIResponseError).mockReturnValue();
        vi.mocked(verifyAppContext).mockReturnValue(true);
        vi.mocked(completeCheckoutRequestSchema.parse).mockReturnValue(mockCompleteCheckoutData as any);
        vi.mocked(WixClient.create).mockResolvedValue(mockWixClient as any);
        mockWixClient.completeCart.mockResolvedValue(mockCompletedCart);
        vi.mocked(trackInitiatedPaymentFireAndForget).mockReturnValue();
        vi.mocked(trackFailedPaymentFireAndForget).mockReturnValue();
        vi.mocked(trackSuccessPaymentFireAndForget).mockReturnValue();
        vi.mocked(sendPaymentInitiatedAlarmMetricFireAndForget).mockReturnValue();
        vi.mocked(sendPaymentSuccessAlarmMetricFireAndForget).mockReturnValue();
        vi.mocked(sendPaymentFailureAlarmMetricFireAndForget).mockReturnValue();
        vi.mocked(isProduction).mockReturnValue(false);
        vi.mocked(startSimulatorV2).mockResolvedValue();
        vi.mocked(stopSimulator).mockReturnValue();
    });

    afterEach(() => {
        vi.restoreAllMocks();
    });

    describe("Successful cart completion", () => {
        it("should complete a cart successfully with valid input", async () => {
            const result = await handler(mockEvent, getMockLambdaContext());

            expect(verifyAppContext).toHaveBeenCalledWith(mockEvent);
            expect(completeCheckoutRequestSchema.parse).toHaveBeenCalledWith(mockCompleteCheckoutData);
            expect(WixClient.create).toHaveBeenCalledWith(mockEvent, "test-client-id", "test-client-secret");
            expect(mockWixClient.completeCart).toHaveBeenCalledWith(
                "wix-cart-456",
                mockCompleteCheckoutData
            );
            expect(extractCartIdFromCompleteRoute).toHaveBeenCalledWith("/commerceorchnodeserv/wix/cart/test-cart-123/complete");
            expect(mockCache.get).toHaveBeenCalledWith("test-cart-123");
            expect(result).toEqual({
                statusCode: 200,
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(mockCompletedCart),
            });
        });

        it("should handle string body correctly", async () => {
            const eventWithStringBody = {
                ...mockEvent,
                body: JSON.stringify(mockCompleteCheckoutData),
            };

            const result = await handler(eventWithStringBody, getMockLambdaContext());

            expect(result).toEqual({
                statusCode: 200,
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(mockCompletedCart),
            });
        });

        it("should handle object body correctly", async () => {
            const eventWithObjectBody = {
                ...mockEvent,
                body: mockCompleteCheckoutData,
            };

            const result = await handler(eventWithObjectBody, getMockLambdaContext());

            expect(result).toEqual({
                statusCode: 200,
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(mockCompletedCart),
            });
        });
    });

    describe("Authorization failures", () => {
        it("should throw UnauthorizedError when AppContext verification fails", async () => {
            vi.mocked(verifyAppContext).mockReturnValue(false);

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(verifyAppContext).toHaveBeenCalledWith(mockEvent);
            expect(result.statusCode).toBe(401);
        });
    });

    describe("Validation failures", () => {
        it("should handle schema validation errors", async () => {
            const validationError = new Error("Invalid checkout data");
            vi.mocked(completeCheckoutRequestSchema.parse).mockImplementation(() => {
                throw validationError;
            });

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(500);
        });

        it("should throw BadRequestError when payment token is missing", async () => {
            const dataWithoutToken = {
                payment_method: {
                    payer_id: "test-payer-id",
                    type: "paypal" as const,
                },
            };
            vi.mocked(completeCheckoutRequestSchema.parse).mockReturnValue(dataWithoutToken as any);

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(400);
        });

        it("should throw BadRequestError when payer_id is missing", async () => {
            const dataWithoutPayerId = {
                payment_method: {
                    token: "test-payment-token",
                    type: "paypal" as const,
                },
            };
            vi.mocked(completeCheckoutRequestSchema.parse).mockReturnValue(dataWithoutPayerId as any);

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(400);
        });
    });

    describe("WixClient failures", () => {
        it("should handle WixClient creation failure", async () => {
            const wixError = new Error("Failed to create Wix client");
            vi.mocked(WixClient.create).mockRejectedValue(wixError);

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(500);
            expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
                orchestrator: 'Wix',
                merchantUrl: '',
                status: '500'
            });
        });

        it("should handle cart completion failure", async () => {
            const completionError = new Error("Failed to complete cart in Wix");
            mockWixClient.completeCart.mockRejectedValue(completionError);

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(500);
            expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
                orchestrator: 'Wix',
                merchantUrl: '',
                status: '500'
            });
        });
    });

    describe("Response schema validation", () => {
        it("should handle response schema validation failure", async () => {
            const schemaError = new Error("Invalid response schema");
            vi.mocked(WixClient.create).mockRejectedValue(schemaError);

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(500);
            expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
                orchestrator: 'Wix',
                merchantUrl: '',
                status: '500'
            });
        });
    });

    describe("Non-Error exceptions", () => {
        it("should handle non-Error exceptions", async () => {
            const nonErrorException = "String exception";
            vi.mocked(completeCheckoutRequestSchema.parse).mockImplementation(() => {
                throw nonErrorException;
            });

            const result = await handler(mockEvent, getMockLambdaContext());

            expect(result.statusCode).toBe(500);
        });
    });

    describe("Logging", () => {
        it("should log all expected information during successful execution", async () => {
            await handler(mockEvent, getMockLambdaContext());

            // Verify the new structured logging pattern
            expect(mockLog.info).toHaveBeenCalledWith(
                "Lambda Function - wix-complete-cart - START",
                expect.objectContaining({
                    correlationId: "test-correlation-id",
                })
            );
            expect(mockLog.info).toHaveBeenCalledWith(
                "Authorization completed",
                expect.objectContaining({
                    correlationId: "test-correlation-id",
                    authorized: true,
                })
            );
            expect(mockLog.info).toHaveBeenCalledWith(
                "Request validation completed",
                expect.objectContaining({
                    correlationId: "test-correlation-id",
                })
            );
            expect(mockLog.info).toHaveBeenCalledWith(
                "Lambda Function - wix-complete-cart - COMPLETED",
                expect.objectContaining({
                    correlationId: "test-correlation-id",
                })
            );
        });

        it("should log error when authorization fails", async () => {
            vi.mocked(verifyAppContext).mockReturnValue(false);

            await handler(mockEvent, getMockLambdaContext());

            expect(mockLog.error).toHaveBeenCalledWith(
                "Unauthorized access: AppContext verification failed",
                { correlationId: "test-correlation-id" }
            );
        });
    });
});