import { createMiddleware } from "hono/factory";
import {
  httpRequestInit,
  httpRequestSuccess,
  httpRequestError,
  type HttpRequestMetrics,
} from "../metrics/httpMetrics";

export function honoMetricsMiddleware(params: {
  orchestrator: string;
  merchant?: string;
  partner?: string;
}) {
  return createMiddleware(async (c, next) => {
    const metrics = httpRequestInit({
      c,
      orchestrator: params.orchestrator,
      merchant: params.merchant,
      partner: params.partner,
    });
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess({ metrics, statusCode: c.res.status });
    } catch (error) {
      httpRequestError({ metrics, error });
      throw error;
    }
  });
}

declare module "hono" {
  interface ContextVariableMap {
    requestMetrics: HttpRequestMetrics;
  }
}
