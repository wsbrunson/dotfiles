/**
 * Transform product data from catalog format to Honey format
 */

// Input format type
interface CatalogProduct {
  name: string;
  url: string;
  images: Array<{
    title: string | null;
    url: string;
  }>;
  client_product_id: string;
  merchant_sku_id: string;
  seller: {
    name: string;
    logo_url: string;
  };
  specifications: Array<{
    display_name: string;
    values: string[];
  }>;
}

interface CatalogFormat {
  products: CatalogProduct[];
}

// Output format type
interface HoneyProduct {
  archived: boolean;
  availability: boolean;
  brand: string;
  canonicalClusterId: string;
  canonicalStats: null;
  canonicalUrl: string;
  categories: string[];
  confidence: {
    image: number;
  };
  currency: string;
  dealScore: number;
  defaultTags: string[];
  description: string;
  extDescription: string;
  finalSale: boolean;
  gtin: string;
  honeyCategories: string[];
  imageUrlPrimary: string;
  imageUrlPrimaryDimension: string;
  imageUrlPrimaryTransformed: {
    xsmall: string;
    small: string;
    medium: string;
    large: string;
  };
  imageUrlSecondary: string[];
  isCanonical: boolean;
  keywords: string[];
  merchantUniqueId: string;
  mpn: string;
  offer: null;
  orderMin: string;
  orderMinAmount: null;
  parentId: string;
  policy: string;
  priceCurrent: number;
  productDetails: {
    age_group?: string;
    color?: string;
    gender?: string;
    size?: string;
  };
  priceHistory: {
    history: any[];
    numChanges: number;
    prevPoint: null;
  };
  priceList: number;
  productId: string;
  productStates: string[];
  quantityAllowed: null;
  quantityIncrement: null;
  quantityInStock: null;
  quantityRequired: null;
  ratingCount: number;
  ratingValue: number;
  related: any[];
  sku: string;
  store: {
    storeId: string;
    name: string;
    label: string;
    publicCouponCount: number;
    hasCartSupport: boolean;
    returnInfo: string;
    returnRequiresLogin: null;
    supportEmail: null;
    supportPhoneNumber: string;
    supportUrl: string;
    tosUrl: string;
    supportHours: string;
    returnInitUrl: string;
    freeShippingThreshold: number;
    __typename: string;
  };
  storeExtraInfo: {};
  title: string;
  twotapPurchaseOption: {};
  upc: null;
  updated: number;
  variantId: string;
}

/**
 * Generate a hash-like ID from a string (simple implementation)
 */
function generateId(input: string): string {
  let hash = 0;
  for (let i = 0; i < input.length; i++) {
    const char = input.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash = hash & hash; // Convert to 32-bit integer
  }
  return Math.abs(hash).toString(16);
}

/**
 * Extract specifications as product details
 */
function extractProductDetails(specifications: Array<{display_name: string; values: string[]}>): HoneyProduct['productDetails'] {
  const details: HoneyProduct['productDetails'] = {};

  for (const spec of specifications) {
    const key = spec.display_name.toLowerCase();
    const value = spec.values[0]; // Take first value

    switch (key) {
      case 'color':
        details.color = value;
        break;
      case 'size':
        details.size = value;
        break;
      case 'gender':
        details.gender = value;
        break;
      case 'age_group':
        details.age_group = value;
        break;
    }
  }

  return details;
}

/**
 * Generate transformed image URLs (mock implementation)
 */
function generateTransformedImages(primaryUrl: string): HoneyProduct['imageUrlPrimaryTransformed'] {
  // In a real implementation, these would be actual transformed URLs
  return {
    xsmall: primaryUrl.replace(/\.(jpg|jpeg|png)$/i, '_150w150h_NoCompression.jpeg'),
    small: primaryUrl.replace(/\.(jpg|jpeg|png)$/i, '_300w300h_NoCompression.jpeg'),
    medium: primaryUrl.replace(/\.(jpg|jpeg|png)$/i, '_355w355h_NoCompression.jpeg'),
    large: primaryUrl
  };
}

/**
 * Transform catalog product to Honey format
 */
function transformProduct(catalogProduct: CatalogProduct): HoneyProduct {
  const productId = generateId(catalogProduct.client_product_id + catalogProduct.merchant_sku_id);
  const storeId = generateId(catalogProduct.seller.name);
  const variantId = generateId(catalogProduct.client_product_id);
  const parentId = generateId(catalogProduct.name);

  return {
    archived: false,
    availability: true,
    brand: catalogProduct.seller.name,
    canonicalClusterId: "",
    canonicalStats: null,
    canonicalUrl: catalogProduct.url,
    categories: [], // Would need mapping logic for specific categories
    confidence: {
      image: 0.8 // Default confidence score
    },
    currency: "USD",
    dealScore: 50, // Default deal score
    defaultTags: [],
    description: catalogProduct.name,
    extDescription: catalogProduct.name,
    finalSale: false,
    gtin: "",
    honeyCategories: [], // Would need category mapping logic
    imageUrlPrimary: catalogProduct.images[0]?.url || "",
    imageUrlPrimaryDimension: "",
    imageUrlPrimaryTransformed: generateTransformedImages(catalogProduct.images[0]?.url || ""),
    imageUrlSecondary: catalogProduct.images.slice(1).map(img => img.url),
    isCanonical: true,
    keywords: [],
    merchantUniqueId: `${storeId}_${catalogProduct.merchant_sku_id}`,
    mpn: catalogProduct.merchant_sku_id,
    offer: null,
    orderMin: "",
    orderMinAmount: null,
    parentId,
    policy: "Standard return policy applies", // Default policy
    priceCurrent: 0, // Would need price extraction logic
    productDetails: extractProductDetails(catalogProduct.specifications),
    priceHistory: {
      history: [],
      numChanges: 0,
      prevPoint: null
    },
    priceList: 0, // Would need price extraction logic
    productId,
    productStates: [],
    quantityAllowed: null,
    quantityIncrement: null,
    quantityInStock: null,
    quantityRequired: null,
    ratingCount: 0,
    ratingValue: 0,
    related: [],
    sku: catalogProduct.merchant_sku_id,
    store: {
      storeId,
      name: catalogProduct.seller.name,
      label: catalogProduct.seller.name.toLowerCase().replace(/\s+/g, ''),
      publicCouponCount: 0,
      hasCartSupport: true,
      returnInfo: "Standard return policy applies",
      returnRequiresLogin: null,
      supportEmail: null,
      supportPhoneNumber: "",
      supportUrl: "",
      tosUrl: "",
      supportHours: "",
      returnInitUrl: "",
      freeShippingThreshold: 0,
      __typename: "Store"
    },
    storeExtraInfo: {},
    title: catalogProduct.name,
    twotapPurchaseOption: {},
    upc: null,
    updated: Date.now(),
    variantId
  };
}

/**
 * Transform catalog format to array of Honey products
 */
export function transformCatalogToHoney(catalogData: CatalogFormat): HoneyProduct[] {
  return catalogData.products.map(transformProduct);
}

