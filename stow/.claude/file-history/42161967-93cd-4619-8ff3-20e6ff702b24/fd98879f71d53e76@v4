describe('startSimulatorWithHandlers', () => {
  beforeEach(() => {
    vi.clearAllMocks();
    h.lastInstance.value = null;
  });

  afterEach(() => {
    // Clean up environment variable
    delete process.env.APP_ENV;
  });

  describe('simulation bypass logic', () => {
    // Filter test cases to exclude bypass email scenarios since startSimulatorWithHandlers doesn't have email context
    const withHandlersTestCases = sharedBypassTestCases.filter(
      testCase => !testCase.expectedLogDetails.isSimulationBypassEmail
    );

    test.each(withHandlersTestCases)(
      '$description',
      async ({ appEnv, simulationHeader, expectedShouldBypass, expectedLogDetails }) => {
        // Setup environment
        process.env.APP_ENV = appEnv;

        // Mock Hono context
        const mockContext = {
          env: {
            event: {
              headers: simulationHeader
                ? { 'PayPal-Commerce-Simulation': simulationHeader }
                : {},
            },
          },
          get: vi.fn().mockReturnValue({
            info: h.infoSpy,
            error: h.errorSpy,
          }),
        };

        await startSimulatorWithHandlers({
          c: mockContext as any,
          handlers: [],
        });

        if (expectedShouldBypass) {
          // Verify the server was not started
          expect(h.listenMock).not.toHaveBeenCalled();

          // Verify the correct log message - note: isSimulationBypassEmail should always be false for this function
          expect(h.infoSpy).toHaveBeenCalledWith(
            'Simulator bypassed - conditions not met',
            {
              ...expectedLogDetails,
              isSimulationBypassEmail: false, // Always false since no email context
            }
          );
        } else {
          // Verify the server was started
          expect(h.listenMock).toHaveBeenCalled();

          // Verify no bypass log message
          expect(h.infoSpy).not.toHaveBeenCalledWith(
            'Simulator bypassed - conditions not met',
            expect.any(Object)
          );
        }
      }
    );
  });
});
