# Datadog Team Module Reference
# This module creates and manages the Commerce Orchestrator team in Datadog

module "datadog_team" {
  source = "./datadog"

  # Pass variables to the module
  team_members = var.team_members_override != null ? var.team_members_override : []
  team_notification_channels = var.team_notification_channels_override != null ? var.team_notification_channels_override : []
  create_environment_specific_teams = false
}

# Variables for optional overrides
variable "team_members_override" {
  description = "Override team members (optional)"
  type        = list(string)
  default     = null
}

variable "team_notification_channels_override" {
  description = "Override notification channels (optional)"
  type        = list(string)
  default     = null
}

# Outputs from the module for use in other resources
output "datadog_team_id" {
  description = "Commerce Orchestrator team ID from module"
  value       = module.datadog_team.commerce_orchestrator_team_id
}

output "datadog_team_handle" {
  description = "Commerce Orchestrator team handle from module"
  value       = module.datadog_team.commerce_orchestrator_team_handle
}

output "datadog_team_tags" {
  description = "Standard team tags from module"
  value       = module.datadog_team.team_tags
}