import { describe, it, expect, beforeAll, beforeEach, vi } from "vitest";
import request from "supertest";
import { setupTestApp } from "../setup";

vi.mock("securitycontext-validation-paypal", () => {
  return {
    default: () => (req: any, _res: any, next: any) => {
      req.securityContext = {
        actor: {
          client_id: "test-client-id",
          id: "test-user-id",
          auth_claims: ["CLIENT_ID_SECRET"],
          auth_state: "LOGGEDIN",
          account_number: "test-account",
          party_id: "test-party-id",
          user_type: "API_CALLER",
          legal_country: "US",
        },
        auth_token: "test-auth-token",
        auth_token_type: "ACCESS_TOKEN",
        scopes: ["https://uri.paypal.com/services/commerce/orchestration"],
      };
      next();
    },
  };
});

vi.mock("environment-paypal", () => ({
  default: {
    isNotProd: vi.fn().mockReturnValue(false),
    isProd: vi.fn().mockReturnValue(false),
    isDev: vi.fn().mockReturnValue(true),
    isStage: vi.fn().mockReturnValue(false),
    isQA: vi.fn().mockReturnValue(false),
    isTest: vi.fn().mockReturnValue(false),
    isLive: vi.fn().mockReturnValue(false),
    isSandbox: vi.fn().mockReturnValue(false),
  },
}));

// Mock httpclient for cart API calls
vi.mock("@paypalcorp/httpclient", () => ({
  httpclient: {
    request: vi.fn(),
  },
}));

describe("Checkout Integration Tests", () => {
  let app: any;

  beforeAll(async () => {
    const setup = setupTestApp();
    app = setup.app;
  });

  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe("POST /commerceorchnodeserv/checkout/wallet", () => {
    it("should get wallet information successfully with valid data using external function", async () => {
      const { externalGetFundingSelection } = vi.mocked(
        await import("@paypalcorp/agentic-checkout-orchestrator"),
        true,
      );

      externalGetFundingSelection.mockResolvedValue({
        correlationId: "test-correlation-wallet-123",
        data: {
          fundingInstruments: [
            {
              id: "paypal-balance-123",
              type: "PAYPAL_BALANCE",
              label: "PayPal Balance",
              imageUrl: { imagePath: "/images/paypal-logo.png" },
              name: "PayPal Balance",
              isPreferred: true,
            },
          ],
          config: {
            selectedInstrumentIds: ["paypal-balance-123"],
            mustUseInstrumentIds: [],
            preferredInstrumentId: "paypal-balance-123",
            balanceEligibility: "ELIGIBLE",
            balanceSelected: "true",
          },
          contingencies: null,
        },
      });

      const walletRequestData = {
        buyerAccessToken: "buyer-access-token-123",
        ecToken: "EC-TOKEN-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/wallet")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(walletRequestData)
        .expect(201);

      expect(response.body).toMatchObject({
        fundingInstruments: expect.arrayContaining([
          expect.objectContaining({
            id: expect.any(String),
            type: expect.any(String),
            label: expect.any(String),
          }),
        ]),
        config: expect.objectContaining({
          selectedInstrumentIds: expect.any(Array),
          mustUseInstrumentIds: expect.any(Array),
        }),
      });
    });

    it("should get wallet information successfully when buyerAccessToken is missing (external function used)", async () => {
      const { externalGetFundingSelection } = vi.mocked(
        await import("@paypalcorp/agentic-checkout-orchestrator"),
        true,
      );

      externalGetFundingSelection.mockResolvedValue({
        correlationId: "test-correlation-wallet-internal-123",
        data: {
          fundingInstruments: [
            {
              id: "paypal-balance-internal",
              type: "PAYPAL_BALANCE",
              label: "PayPal Balance (Internal)",
              imageUrl: { imagePath: "/images/paypal-logo.png" },
              name: "PayPal Balance (Internal)",
              isPreferred: true,
            },
          ],
          config: {
            selectedInstrumentIds: ["paypal-balance-internal"],
            mustUseInstrumentIds: [],
            preferredInstrumentId: "paypal-balance-internal",
            balanceEligibility: "ELIGIBLE",
            balanceSelected: "true",
          },
          contingencies: null,
        },
      });

      const requestData = {
        ecToken: "EC-TOKEN-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/wallet")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(requestData)
        .expect(201);

      expect(response.body).toMatchObject({
        fundingInstruments: expect.arrayContaining([
          expect.objectContaining({
            id: "paypal-balance-internal",
            name: "PayPal Balance (Internal)",
          }),
        ]),
        config: expect.objectContaining({
          selectedInstrumentIds: expect.any(Array),
          mustUseInstrumentIds: expect.any(Array),
        }),
      });

      // Verify external function was called
      expect(externalGetFundingSelection).toHaveBeenCalledTimes(1);
    });

    it("should return 400 when ecToken is missing", async () => {
      const invalidData = {
        buyerAccessToken: "buyer-access-token-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/wallet")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(invalidData);

      expect(response.body).toMatchObject({
        name: "BadRequestError",
        status: 400,
      });
    });

    it("should return 400 when required fields are missing", async () => {
      const invalidData = { not_a: "valid_property" };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/wallet")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(invalidData);

      expect(response.body).toMatchObject({
        name: "BadRequestError",
        status: 400,
      });
    });
  });

  describe("POST /commerceorchnodeserv/checkout/shipping", () => {
    it("should get shipping information successfully", async () => {
      const { externalShippingAddressByTokenOrMerchant } = vi.mocked(
        await import("@paypalcorp/agentic-checkout-orchestrator"),
        true,
      );

      externalShippingAddressByTokenOrMerchant.mockResolvedValue({
        correlationId: "test-correlation-123",
        data: {
          __typename: "externalShippingAddressSuccessResponse",
          addresses: [
            {
              addressId: "address-123",
              type: "HOME",
              name: {
                fullName: "John Doe",
              },
              disableForTransaction: false,
              address: {
                countryCode: "US",
                postalCode: "90210",
                adminArea1: "CA",
                adminArea2: "Los Angeles",
                addressLine1: "123 Main St",
                addressLine2: "Apt 4",
                addressLine3: null,
              },
            },
          ],
          merchantName: "Test Merchant",
          selectedId: "address-123",
          contingencies: [],
          config: {
            isChangeShippingAddressAllowed: true,
            hideShipping: false,
            blockNonDomesticShipping: false,
            isOptionallyShareAddress: true,
            isSntSupported: true,
            category: "DIGITAL_GOODS",
            deliveryType: "STANDARD",
          },
        },
      });

      const shippingRequestData = {
        buyerAccessToken: "buyer-access-token-123",
        merchantAccountId: "test-merchant-123",
        cartId: "cart-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/shipping")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(shippingRequestData)
        .expect(201);

      expect(response.body).toMatchObject({
        __typename: "externalShippingAddressSuccessResponse",
        addresses: expect.arrayContaining([
          expect.objectContaining({
            addressId: expect.any(String),
            type: expect.any(String),
            name: expect.objectContaining({
              fullName: expect.any(String),
            }),
          }),
        ]),
        selectedId: expect.any(String),
        merchantName: expect.any(String),
        config: expect.objectContaining({
          isChangeShippingAddressAllowed: expect.any(Boolean),
          hideShipping: expect.any(Boolean),
          blockNonDomesticShipping: expect.any(Boolean),
          isOptionallyShareAddress: expect.any(Boolean),
          isSntSupported: expect.any(Boolean),
          category: expect.any(String),
          deliveryType: expect.any(String),
        }),
      });
    });

    it("should return 400 when required fields are missing", async () => {
      const invalidData = {};

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/shipping")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(invalidData);

      expect(response.body).toMatchObject({
        name: "BadRequestError",
        status: 400,
      });
    });

    it("should return 400 when buyerAccessToken is missing", async () => {
      const invalidData = {
        merchantAccountId: "test-merchant-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/shipping")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(invalidData);

      expect(response.body).toMatchObject({
        name: "BadRequestError",
        status: 400,
      });
    });
  });

  describe("POST /commerceorchnodeserv/checkout/approve", () => {
    it("should approve payment successfully with valid data", async () => {
      const { externalApprovePurchase } = vi.mocked(
        await import("@paypalcorp/agentic-checkout-orchestrator"),
        true,
      );

      const { httpclient } = vi.mocked(await import("@paypalcorp/httpclient"));

      // Mock the cart API response
      (httpclient.request as any).mockResolvedValue({
        body: {
          gross_total_amount: {
            value: "100.00",
            currency_code: "USD",
          },
        },
      });

      externalApprovePurchase.mockResolvedValue({
        correlationId: "test-correlation-approve-123",
        data: {
          __typename: "externalAuthorizePurchaseSuccessResponse",
          status: true,
          staleDomains: [],
          returnURL:
            "https://paypal.com/return?paymentId=PAYID-12345&PayerID=PAYER123",
          paymentID: "PAYID-12345",
          payerID: "PAYER123",
        },
      });

      const approveRequestData = {
        buyerAccessToken: "buyer-access-token-123",
        ecToken: "EC-TOKEN-123",
        amount: "100.00",
        instrumentId: "instrument-123",
        shippingAddressId: "address-123",
        visitorId: "visitor-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/approve")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(approveRequestData)
        .expect(201);

      expect(response.body).toMatchObject({
        returnURL: expect.any(String),
        paymentID: expect.any(String),
        payerID: expect.any(String),
      });
    });

    it("should approve payment successfully without optional shippingAddressId", async () => {
      const { externalApprovePurchase } = vi.mocked(
        await import("@paypalcorp/agentic-checkout-orchestrator"),
        true,
      );

      const { httpclient } = vi.mocked(await import("@paypalcorp/httpclient"));

      // Mock the cart API response
      (httpclient.request as any).mockResolvedValue({
        body: {
          gross_total_amount: {
            value: "100.00",
            currency_code: "USD",
          },
        },
      });

      externalApprovePurchase.mockResolvedValue({
        correlationId: "test-correlation-approve-no-shipping-123",
        data: {
          __typename: "externalAuthorizePurchaseSuccessResponse",
          status: true,
          staleDomains: [],
          returnURL:
            "https://paypal.com/return?paymentId=PAYID-12345&PayerID=PAYER123",
          paymentID: "PAYID-12345",
          payerID: "PAYER123",
        },
      });

      const approveRequestData = {
        buyerAccessToken: "buyer-access-token-123",
        ecToken: "EC-TOKEN-123",
        amount: "100.00",
        instrumentId: "instrument-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/approve")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(approveRequestData)
        .expect(201);

      expect(response.body).toMatchObject({
        returnURL: expect.any(String),
        paymentID: expect.any(String),
        payerID: expect.any(String),
      });
    });

    it("should return 400 when amount is missing", async () => {
      const invalidData = {
        buyerAccessToken: "buyer-access-token-123",
        ecToken: "EC-TOKEN-123",
        instrumentId: "instrument-123",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/approve")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(invalidData);

      expect(response.body).toMatchObject({
        name: "BadRequestError",
        status: 400,
      });
    });

    it("should return 400 when instrumentId is missing", async () => {
      const invalidData = {
        buyerAccessToken: "buyer-access-token-123",
        ecToken: "EC-TOKEN-123",
        amount: "100.00",
      };

      const response = await request(app)
        .post("/commerceorchnodeserv/checkout/approve")
        .set(
          "x-paypal-security-context",
          JSON.stringify({
            claims: {
              subject_payer_id: "test-payer-id",
            },
          }),
        )
        .set("pp_remote_addr", "127.0.0.1")
        .send(invalidData);

      expect(response.body).toMatchObject({
        name: "BadRequestError",
        status: 400,
      });
    });
  });
});
