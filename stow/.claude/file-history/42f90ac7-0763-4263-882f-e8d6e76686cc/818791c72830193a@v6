import { createMiddleware } from "hono/factory";
import {
  httpRequestInit,
  httpRequestSuccess,
  httpRequestError,
  type HttpRequestMetrics,
} from "./honoMetrics";

export function honoMetricsMiddleware(
  platform?: string,
  options?: {
    merchant?: string;
    partner?: string;
    orchestrator?: string;
  },
) {
  return createMiddleware(async (c, next) => {
    const metrics = httpRequestInit(c, platform);
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess(metrics, c.res.status, options);
    } catch (error) {
      httpRequestError(metrics, error, options);
      throw error;
    }
  });
}

export function honoMetricsMiddlewareAdvanced(options: {
  platform?: string;
  skipRoutes?: string[];
  enableDurationHistogram?: boolean;
  merchant?: string;
  partner?: string;
  orchestrator?: string;
}) {
  const {
    platform,
    skipRoutes = [],
    enableDurationHistogram = false,
    merchant,
    partner,
    orchestrator,
  } = options;

  return createMiddleware(async (c, next) => {
    if (skipRoutes.some((route) => c.req.path.startsWith(route))) {
      await next();
      return;
    }

    const metrics = httpRequestInit(c, platform);
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess(c.get("requestMetrics"), c.res.status, {
        merchant,
        partner,
        orchestrator,
      });
    } catch (error) {
      httpRequestError(c.get("requestMetrics"), error, {
        merchant,
        partner,
        orchestrator,
      });
      throw error;
    }
  });
}

declare module "hono" {
  interface ContextVariableMap {
    requestMetrics: HttpRequestMetrics;
  }
}
