import { describe, it, expect, vi, beforeEach, afterEach } from "vitest";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";
import { APIGatewayRequestAuthorizerEventV2 } from "aws-lambda";
import jwt from "jsonwebtoken";
import crypto from "crypto";

const generateTestKeys = () => {
  const { publicKey, privateKey } = crypto.generateKeyPairSync("rsa", {
    modulusLength: 2048,
    publicKeyEncoding: {
      type: "spki",
      format: "pem",
    },
    privateKeyEncoding: {
      type: "pkcs8",
      format: "pem",
    },
  });

  const publicKeyRaw = publicKey
    .replace("-----BEGIN PUBLIC KEY-----", "")
    .replace("-----END PUBLIC KEY-----", "")
    .replace(/\n/g, "");

  return { privateKey, publicKeyRaw };
};

const { privateKey: TEST_PRIVATE_KEY, publicKeyRaw: TEST_PUBLIC_KEY_RAW } =
  generateTestKeys();

const createValidJWT = (payload: object = { sub: "test" }): string => {
  return jwt.sign(payload, TEST_PRIVATE_KEY, { algorithm: "RS256" });
};

const createInvalidJWT = (): string => {
  return "invalid.jwt.token";
};

describe("AppContext Authorizer", () => {
  const originalEnv = process.env.VERIFICATION_PEM;
  const originalAppEnv = process.env.APP_ENV;
  const originalSandboxEnv = process.env.SANDBOX_VERIFICATION_PEM;

  beforeEach(() => {
    vi.clearAllMocks();
    process.env.VERIFICATION_PEM = TEST_PUBLIC_KEY_RAW;
    process.env.APP_ENV = "prod"; // Default to prod
    delete process.env.SANDBOX_VERIFICATION_PEM; // Default to no sandbox
  });

  afterEach(() => {
    if (originalEnv !== undefined) {
      process.env.VERIFICATION_PEM = originalEnv;
    } else {
      delete process.env.VERIFICATION_PEM;
    }
    if (originalAppEnv !== undefined) {
      process.env.APP_ENV = originalAppEnv;
    } else {
      delete process.env.APP_ENV;
    }
    if (originalSandboxEnv !== undefined) {
      process.env.SANDBOX_VERIFICATION_PEM = originalSandboxEnv;
    } else {
      delete process.env.SANDBOX_VERIFICATION_PEM;
    }
  });

  const createMockEvent = (
    headers: Record<string, string> = {}
  ): APIGatewayRequestAuthorizerEventV2 =>
    ({
      type: "REQUEST",
      headers,
      requestContext: {
        accountId: "123456789012",
        apiId: "abcdef123",
        domainName: "api.example.com",
        stage: "test",
        requestId: "test-request-id",
        http: {
          method: "GET",
          path: "/test",
          protocol: "HTTP/1.1",
          sourceIp: "127.0.0.1",
          userAgent: "test-agent",
        },
        time: new Date().toISOString(),
        timeEpoch: Date.now(),
      },
    } as APIGatewayRequestAuthorizerEventV2);

  it("should authorize successfully when valid JWT token is provided", async () => {
    const validToken = createValidJWT({
      sub: "test-user",
      iat: Math.floor(Date.now() / 1000),
    });
    const mockEvent = createMockEvent({
      "paypal-application-context": validToken,
    });

    const result = await handler(mockEvent);

    expect(result).toEqual({
      isAuthorized: true,
    });
  });

  it("should throw error when paypal-application-context header is missing", async () => {
    const mockEvent = createMockEvent({});

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should throw error when paypal-application-context header is empty", async () => {
    const mockEvent = createMockEvent({
      "paypal-application-context": "",
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should throw error when paypal-application-context header is whitespace only", async () => {
    const mockEvent = createMockEvent({
      "paypal-application-context": "   ",
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should throw error when JWT verification fails", async () => {
    const invalidToken = createInvalidJWT();
    const mockEvent = createMockEvent({
      "paypal-application-context": invalidToken,
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should handle case-insensitive header names", async () => {
    const mockEvent = createMockEvent({
      "PayPal-Application-Context": "valid-jwt-token",
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should work when headers object is undefined", async () => {
    const mockEvent = createMockEvent();
    (mockEvent as any).headers = undefined;

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should construct public key correctly from environment variable", async () => {
    const customPemKey = TEST_PUBLIC_KEY_RAW;
    process.env.VERIFICATION_PEM = customPemKey;

    const validToken = createValidJWT({ sub: "test-user" });
    const mockEvent = createMockEvent({
      "paypal-application-context": validToken,
    });

    const result = await handler(mockEvent);

    expect(result).toEqual({
      isAuthorized: true,
    });
  });

  it("should handle malformed JWT tokens", async () => {
    const malformedToken = "not.a.valid.jwt.format.at.all";
    const mockEvent = createMockEvent({
      "paypal-application-context": malformedToken,
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should handle expired JWT tokens", async () => {
    const expiredToken = jwt.sign(
      {
        sub: "test-user",
        iat: Math.floor(Date.now() / 1000) - 3600,
        exp: Math.floor(Date.now() / 1000) - 1800,
      },
      TEST_PRIVATE_KEY,
      { algorithm: "RS256" }
    );

    const mockEvent = createMockEvent({
      "paypal-application-context": expiredToken,
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should handle JWT with wrong algorithm", async () => {
    const wrongAlgorithmToken = jwt.sign({ sub: "test-user" }, "secret-key", {
      algorithm: "HS256",
    });

    const mockEvent = createMockEvent({
      "paypal-application-context": wrongAlgorithmToken,
    });

    await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
  });

  it("should verify JWT with correct algorithm constraints", async () => {
    const validToken = createValidJWT({ sub: "test-user" });
    const mockEvent = createMockEvent({
      "paypal-application-context": validToken,
    });

    const result = await handler(mockEvent);

    expect(result).toEqual({
      isAuthorized: true,
    });
  });

  describe("Dual PEM Verification", () => {
    const { privateKey: sandboxPrivateKey, publicKeyRaw: sandboxPublicKeyRaw } = generateTestKeys();

    it("should use regular PEM in non-test environment even if sandbox PEM is available", async () => {
      process.env.APP_ENV = "prod";
      process.env.SANDBOX_VERIFICATION_PEM = sandboxPublicKeyRaw;

      const validToken = createValidJWT({ sub: "test-user" });
      const mockEvent = createMockEvent({ "paypal-application-context": validToken });

      const result = await handler(mockEvent);
      expect(result).toEqual({ isAuthorized: true });
    });

    it("should use regular PEM first in test environment", async () => {
      process.env.APP_ENV = "test";
      process.env.SANDBOX_VERIFICATION_PEM = sandboxPublicKeyRaw;

      const validToken = createValidJWT({ sub: "test-user" });
      const mockEvent = createMockEvent({ "paypal-application-context": validToken });

      const result = await handler(mockEvent);
      expect(result).toEqual({ isAuthorized: true });
    });

    it("should fallback to sandbox PEM in test environment when regular PEM fails", async () => {
      process.env.APP_ENV = "test";
      process.env.SANDBOX_VERIFICATION_PEM = sandboxPublicKeyRaw;

      // Create token with sandbox key that won't verify with regular key
      const sandboxToken = jwt.sign({ sub: "sandbox-user" }, sandboxPrivateKey, { algorithm: "RS256" });
      const mockEvent = createMockEvent({ "paypal-application-context": sandboxToken });

      const result = await handler(mockEvent);
      expect(result).toEqual({ isAuthorized: true });
    });

    it("should fail when both PEMs fail in test environment", async () => {
      process.env.APP_ENV = "test";
      process.env.SANDBOX_VERIFICATION_PEM = sandboxPublicKeyRaw;

      const invalidToken = "invalid.jwt.token";
      const mockEvent = createMockEvent({ "paypal-application-context": invalidToken });

      await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
    });

    it("should not try sandbox PEM in test environment if SANDBOX_VERIFICATION_PEM is not set", async () => {
      process.env.APP_ENV = "test";
      delete process.env.SANDBOX_VERIFICATION_PEM;

      const sandboxToken = jwt.sign({ sub: "sandbox-user" }, sandboxPrivateKey, { algorithm: "RS256" });
      const mockEvent = createMockEvent({ "paypal-application-context": sandboxToken });

      await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
    });

    it("should not try sandbox PEM in non-test environment", async () => {
      process.env.APP_ENV = "prod";
      process.env.SANDBOX_VERIFICATION_PEM = sandboxPublicKeyRaw;

      const sandboxToken = jwt.sign({ sub: "sandbox-user" }, sandboxPrivateKey, { algorithm: "RS256" });
      const mockEvent = createMockEvent({ "paypal-application-context": sandboxToken });

      await expect(handler(mockEvent)).rejects.toThrow("Unauthorized");
    });
  });
});
