import { Context, Hono } from 'hono';
import { logger } from 'shared/logger/logger';
import { auth } from 'shared/middleware/auth';
import { datadogTracing } from 'shared/middleware/datadogTracing';
import { adoramaCreateCartMiddleware, adoramaUpdateCartMiddleware, adoramaCompleteCartMiddleware } from 'shared/middleware/adoramaValidation';
import { ALBEvent } from 'aws-lambda';
import { AdoramaController } from 'shared/adorama/controllers';
import { StatusCode } from 'hono/utils/http-status';
import { requestLogger } from 'shared/middleware/requestLogger';
import { parseRequestBodyWithZod } from 'shared/middleware/parseRequestBodyWithZod';
import { cartMetrics } from 'shared/middleware/cartMetrics';
import { createErrorHandler } from 'shared/handlers/createErrorHandler';
import { paymentMetrics } from 'shared/middleware/paymentMetrics';
import { updateCartMetrics } from 'shared/middleware/updateCartMetric';
import { getCacheImplementation } from 'shared/cache/cacheFactory';
import { datadogCartMetrics, datadogUpdateCartMetrics, datadogPaymentMetrics } from 'shared/middleware/datadogMetrics';
import {  payPalCartSchema, completeCheckoutRequestSchema } from 'shared/schemas/openapi-schemas';
import { convertV1CreateCartResponse, convertV1UpdateCartResponse, convertV1CompleteCartResponse } from 'shared/adorama/v1toV2ResponseConverter';
// Module-level cache optimization for connection reuse
let cachedRedisClient: any = undefined;

const getOptimizedCache = () => {
  if (!cachedRedisClient) {
    cachedRedisClient = getCacheImplementation();
  }
  return cachedRedisClient;
};

const log = logger("Adorama");
const app = new Hono();
const cache = getOptimizedCache();
const adoramaController = new AdoramaController({ cache, log });

app.use('*', datadogTracing('adorama'));
app.use('*', auth);

const BASE_PATH = '/commerceorchnodeserv/v2/adorama';

app.post(
    `${BASE_PATH}/cart`,
    requestLogger({ type: 'create-cart' }),
    parseRequestBodyWithZod({ schema: payPalCartSchema }),
    adoramaCreateCartMiddleware(),
    cartMetrics({ orchestrator: 'Adorama' }),
    datadogCartMetrics({ orchestrator: 'Adorama' }),
    async (c: Context) => {
        const event = c.env.event as unknown as ALBEvent;
        // Get v1 data from middleware (already validated and converted)
        const v1Data = c.get('v1Data');
        const cartData = await adoramaController.createCart({ data: v1Data, request: event });
        c.status(201 as StatusCode);
        // Convert v1->v2 response
        return c.json(convertV1CreateCartResponse(c,cartData));
    }
);

app.onError(createErrorHandler('Adorama'));

app.post(
    `${BASE_PATH}/cart/:cartId/complete`,
    requestLogger({ type: 'complete-cart' }),
    parseRequestBodyWithZod({ schema: completeCheckoutRequestSchema }),
    adoramaCompleteCartMiddleware(), // Validates and converts v2 -> v1
    paymentMetrics({ orchestrator: 'Adorama' }),
    datadogPaymentMetrics({ orchestrator: 'Adorama' }),
    async (c: Context) => {
        const event = c.env.event as unknown as ALBEvent;
        const data = c.get('data');
        // Get v1 data from middleware (already validated and converted)
        const v1CompleteData = c.get('v1CompleteData');
        // Call controller - returns object with transactionId, status, ecToken, total_amount, tax_amount, reviewOrderPage
        const completeCart = await adoramaController.completeCart({ data: v1CompleteData, request: event });
        c.status(201 as StatusCode);
        // Convert v1 response to v2 schema
        return c.json(convertV1CompleteCartResponse(completeCart as any, data));
    }
);


app.put(
    `${BASE_PATH}/cart/:cartId`,
    requestLogger({ type: 'update-cart' }),
    parseRequestBodyWithZod({ schema: payPalCartSchema }),
    adoramaUpdateCartMiddleware(), // Validates and converts v2 -> v1
    updateCartMetrics({ orchestrator: 'Adorama' }),
    datadogUpdateCartMetrics({ orchestrator: 'Adorama' }),
    async (c: Context) => {
        const event = c.env.event as unknown as ALBEvent;
        // Get v1 data from middleware (already validated and converted)
        const v1UpdateData = c.get('v1UpdateData');
        // Call controller with converted params
        const updateCart = await adoramaController.updateCart({ data: v1UpdateData, request: event });
        c.status(200 as StatusCode);
        // Convert v1 response to v2 schema via helper
        return c.json(convertV1UpdateCartResponse(c, updateCart));
    }
);


export { app };