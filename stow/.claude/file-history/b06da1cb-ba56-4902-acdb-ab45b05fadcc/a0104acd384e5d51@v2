import { describe, it, expect, vi, beforeEach } from 'vitest'
import type { Context, Next } from 'hono'
import type { ALBEvent } from 'aws-lambda'

vi.mock('shared/metrics/emitMetric', () => ({
  __esModule: true,
  trackInitiatedPayment: vi.fn(),
  trackSuccessPayment: vi.fn(),
}))

vi.mock('../logger/logger', () => {
  const factory = vi.fn(() => ({
    info: vi.fn(),
    error: vi.fn(),
  }))
  return { __esModule: true, logger: factory }
})

import { paymentMetrics } from './paymentMetrics'
import { trackInitiatedPayment, trackSuccessPayment } from 'shared/metrics/emitMetric'
function makeAlbEvent(overrides?: Partial<ALBEvent>): ALBEvent {
  return {
    httpMethod: 'POST',
    path: '/commerceorchnodeserv/v2/shopify/cart/complete',
    headers: { 'paypal-debug-id': 'hdr-123' },
    multiValueHeaders: {},
    queryStringParameters: null,
    multiValueQueryStringParameters: null,
    body: null,
    isBase64Encoded: false,
    requestContext: { elb: { targetGroupArn: 'arn:aws:elasticloadbalancing:xx:acct:tg/name/id' } },
    ...overrides,
  } as any
}

function makeCtx(opts?: { debugId?: string; start?: number; event?: Partial<ALBEvent> }): Context {
  const logMock = {
    info: vi.fn(),
    error: vi.fn(),
  }
  const store = new Map<string, any>([
    ['debugId', opts?.debugId ?? 'dbg-123'],
    ['overallStartTime', opts?.start ?? 1000],
    ['storeMetaData', {}],
    ['logger', logMock],
  ])
  return {
    env: { event: makeAlbEvent(opts?.event) },
    get: (k: string) => store.get(k),
    set: (k: string, v: any) => store.set(k, v),
  } as unknown as Context
}

async function runWithResponse(
  status: number,
  c: Context,
  body: any = { ok: true },
  headers: Record<string, string> = { 'content-type': 'application/json' }
) {
  const nextImpl = async () => {
    ;(c as any).res = new Response(
      headers['content-type']?.includes('application/json') ? JSON.stringify(body) : String(body),
      { status, headers }
    )
  }
  const next: Next = vi.fn(nextImpl)
  const mw = paymentMetrics({ orchestrator: 'Shopify' })
  await mw(c, next)
  return next
}

describe('paymentMetrics middleware', () => {
  beforeEach(() => {
    vi.clearAllMocks()
    vi.spyOn(performance, 'now').mockReturnValue(1500)
  })

  it('emits initiated + success metrics and logs on 2xx', async () => {
    const c = makeCtx({ start: 1000, debugId: 'dbg-xyz' })
    const next = await runWithResponse(201, c)

    expect(next).toHaveBeenCalledTimes(1)

    expect(trackInitiatedPayment).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
    })

    expect(trackSuccessPayment).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: '201',
      duration: 500,
    })
    const logMock = c.get('logger')
    expect(logMock.info).toHaveBeenCalledWith('complete-cart-start', {
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
    })
    expect(logMock.info).toHaveBeenCalledWith('complete-cart-success', {
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: 201,
      duration: 500,
      response: '{"ok":true}',
    })
  })

  it('does NOT emit success metrics on non-2xx (e.g., 422) but still emits initiated metric', async () => {
    const c = makeCtx()
    await runWithResponse(422, c, { error: 'failed' })

    expect(trackInitiatedPayment).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
    })
    expect(trackSuccessPayment).not.toHaveBeenCalled()

    const logMock = c.get('logger')
    expect(logMock.info).toHaveBeenCalledWith('complete-cart-start', {
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
    })
    expect(logMock.info).not.toHaveBeenCalledWith('complete-cart-success', expect.any(Object))
  })
})
