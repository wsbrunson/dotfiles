module "lambda_functions" {
  for_each = { for lambda in local.lambdas : lambda.name => lambda }

  source             = "./lambda_function"
  function_name      = each.value.name
  role_arn           = aws_iam_role.lambda_executor.arn
  memory_size        = lookup(each.value, "memory_size", 1024) # Default to 1024 for better performance
  timeout            = 900
  security_group_ids = [aws_security_group.hello_world_SG.id]
  subnet_ids         = data.aws_subnets.protected.ids
  environment_name   = local.environment
  app_version        = local.app_version
  disable_otel       = lookup(each.value, "disable_otel", false)
  environment = merge(
    {
      REGION           = local.region
      APP_ENV          = local.environment
      REDIS_HOST       = aws_elasticache_replication_group.elasticache.primary_endpoint_address
      REDIS_PORT       = aws_elasticache_replication_group.elasticache.port
      REDIS_PASSWORD   = aws_elasticache_replication_group.elasticache.auth_token
      VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_verification_pem.value
      SANDBOX_VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_sandbox_verification_pem.value
      JWT_VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_jwt_verification_pem.value
      JWT_AWS_VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_jwt_aws_verification_pem.value
      COMMERCE_ONBOARDING_URL = data.aws_ssm_parameter.commerce_onboarding_url.value
      # API key used by monitor Lambda and notification processor
      # Fetched from SSM Parameter Store (parameter must be manually created in AWS Console)
      # Web app and CartAPI use APPLICATION_CONTEXT authentication instead

      # Datadog Configuration
      DD_SITE    = "datadoghq.eu"
      DD_SERVICE = "commerce-orchestrator"
      DD_ENV     = local.environment
      DD_VERSION = "2.0.0"
      DD_API_KEY = local.datadog_secret.apikey

      # Datadog tracer settings
      DD_TRACE_ENABLED           = "true"
      DD_SERVERLESS_LOGS_ENABLED = "true"
      DD_CAPTURE_LAMBDA_PAYLOAD  = "true"
      DD_LOG_LEVEL               = "info"
      DD_TRACE_AGENT_URL         = "http://localhost:8126"  # Datadog Extension agent endpoint

      # Enable custom span tags to be searchable in DataDog APM
      DD_TRACE_SPAN_ATTRIBUTE_SCHEMA = "v1"
      DD_TRACE_REMOVE_INTEGRATION_SERVICE_NAMES_ENABLED = "false"

      COMMERCE_ONBOARDING_API_KEY = data.aws_ssm_parameter.commerce_onboarding_api_key.value
      APPCONFIG_APP_ID = local.appconfig[local.environment]["app_id"]
      APPCONFIG_ENV_ID = local.appconfig[local.environment]["env_id"]
      APPCONFIG_PROFILE_ID = local.appconfig[local.environment]["profile_id"]
      MOCK_SECRET_PATH = "arn:aws:secretsmanager:${local.region}:${local.account_id}:secret:${local.secret_paths["mock"][local.environment]}"
    },
    each.value.secret_path != null ? { SECRET_PATH = "arn:aws:secretsmanager:${local.region}:${local.account_id}:secret:${each.value.secret_path}" } : {},
    lookup(each.value, "environment", {}) # Use an empty map if "environment" is not defined
  )
}

# Store deployment state in SSM Parameter Store
resource "aws_ssm_parameter" "deployment_state" {
  for_each = { for lambda in local.lambdas : lambda.name => lambda }
  name     = "/commerce-orchestrator/${local.environment}/lambda/${each.key}/deployment-state"
  type     = "String"
  value    = jsonencode({
    active_color = "blue"
    blue_version = "$LATEST"
    green_version = "$LATEST"
    traffic_weight = {
      blue = 100
      green = 0
    }
    last_deployment = formatdate("YYYY-MM-DD'T'HH:mm:ssZ", timestamp())
  })
  
  lifecycle {
    ignore_changes = [value]
  }
  
  tags = local.default_tags
}

# Blue alias - represents stable/production version
resource "aws_lambda_alias" "blue" {
  for_each         = { for lambda in local.lambdas : lambda.name => lambda }
  name             = "blue"
  function_name    = module.lambda_functions[each.key].function_name
  function_version = module.lambda_functions[each.key].lambda_version

  lifecycle {
    ignore_changes = [function_version]
  }
}

# Green alias - represents new deployment version
resource "aws_lambda_alias" "green" {
  for_each         = { for lambda in local.lambdas : lambda.name => lambda }
  name             = "green"
  function_name    = module.lambda_functions[each.key].function_name
  function_version = module.lambda_functions[each.key].lambda_version

  lifecycle {
    ignore_changes = [function_version]
  }
}

# Live alias - routes traffic between blue and green
resource "aws_lambda_alias" "live" {
  for_each         = { for lambda in local.lambdas : lambda.name => lambda }
  name             = "live"
  function_name    = module.lambda_functions[each.key].function_name
  function_version = aws_lambda_alias.blue[each.key].function_version

  dynamic "routing_config" {
    for_each = var.blue_green_traffic_weight > 0 ? [1] : []
    content {
      additional_version_weights = {
        (aws_lambda_alias.green[each.key].function_version) = var.blue_green_traffic_weight / 100
      }
    }
  }

  lifecycle {
    ignore_changes = [function_version, routing_config]
  }
}

# Provisioned concurrency for commerce orchestrator functions to reduce cold starts
# Apply to all functions that handle customer traffic (contain "commerceorchnodeserv" in path)
resource "aws_lambda_provisioned_concurrency_config" "commerce_functions" {
  for_each = {
    for lambda in local.orchestrator_lambdas : lambda.name => lambda
    if lambda.path != null && can(regex("commerceorchnodeserv", lambda.path))
  }

  function_name                     = module.lambda_functions[each.key].function_name
  provisioned_concurrent_executions = 3  # Conservative starting point
  qualifier                         = aws_lambda_alias.live[each.key].name

  depends_on = [
    aws_lambda_alias.live
  ]
}

# Internal ALB configurations for orchestrator lambdas (cart operations)
module "alb_configurations" {
  for_each = { for lambda in local.orchestrator_lambdas : lambda.name => lambda if lambda.path != null && lambda.priority != null }

  source               = "./alb_configuration"
  name                 = each.value.name
  lambda_function_name = module.lambda_functions[each.key].function_name
  lambda_function_arn  = aws_lambda_alias.live[each.key].arn
  lambda_alias         = "live"
  listener_arn         = aws_lb_listener.https.arn
  path_pattern         = each.value.path
  priority             = each.value.priority
  http_method          = lookup(each.value, "http_method", ["POST"])

  depends_on = [
    module.lambda_functions,
    aws_lambda_alias.live
  ]
}

# Public ALB configurations for public lambdas (notifications, webhooks)
module "alb_configurations_public" {
  for_each = { for lambda in local.public_lambdas : lambda.name => lambda if lambda.path != null && lambda.priority != null }

  source               = "./alb_configuration"
  name                 = "${each.value.name}"
  lambda_function_name = module.lambda_functions[each.key].function_name
  lambda_function_arn  = aws_lambda_alias.live[each.key].arn
  lambda_alias         = "live"
  listener_arn         = aws_lb_listener.public_https.arn
  path_pattern         = each.value.path
  priority             = each.value.priority
  http_method          = lookup(each.value, "http_method", "POST")
  host_header          = var.cname[local.environment]

  depends_on = [
    module.lambda_functions,
    aws_lambda_alias.live,
    aws_lb_listener.public_https
  ]
}

module "appcontext_authorizer_lambda" {
  source = "./lambda_function"
  environment_name = local.environment

  function_name = "orchestrator-appcontext-authorizer"
  role_arn      = aws_iam_role.lambda_executor.arn
  memory_size   = 256  # Authorizer needs moderate memory for JWT processing
  timeout       = 120

  environment = {
    APP_ENV          = local.environment
    NODE_ENV         = "prod"
    VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_verification_pem.value
    SANDBOX_VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_sandbox_verification_pem.value
    JWT_VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_jwt_verification_pem.value
    JWT_AWS_VERIFICATION_PEM = data.aws_ssm_parameter.appcontext_jwt_aws_verification_pem.value
  }
}

# Blue alias for appcontext-authorizer - represents stable/production version
resource "aws_lambda_alias" "appcontext_authorizer_blue" {
  name             = "blue"
  function_name    = module.appcontext_authorizer_lambda.function_name
  function_version = module.appcontext_authorizer_lambda.lambda_version

  lifecycle {
    ignore_changes = [function_version]
  }
}

# Green alias for appcontext-authorizer - represents new deployment version
resource "aws_lambda_alias" "appcontext_authorizer_green" {
  name             = "green"
  function_name    = module.appcontext_authorizer_lambda.function_name
  function_version = module.appcontext_authorizer_lambda.lambda_version

  lifecycle {
    ignore_changes = [function_version]
  }
}

# Live alias for appcontext-authorizer - routes traffic between blue and green
resource "aws_lambda_alias" "appcontext_authorizer_live" {
  name             = "live"
  function_name    = module.appcontext_authorizer_lambda.function_name
  function_version = aws_lambda_alias.appcontext_authorizer_blue.function_version

  dynamic "routing_config" {
    for_each = var.blue_green_traffic_weight > 0 ? [1] : []
    content {
      additional_version_weights = {
        (aws_lambda_alias.appcontext_authorizer_green.function_version) = var.blue_green_traffic_weight / 100
      }
    }
  }

  lifecycle {
    ignore_changes = [function_version, routing_config]
  }
