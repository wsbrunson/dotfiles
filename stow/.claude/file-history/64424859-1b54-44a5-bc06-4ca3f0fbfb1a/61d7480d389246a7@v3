resource "aws_lambda_permission" "appcontext_authorizer_lambda_permission" {
  statement_id  = "AllowInvocationFromApiGateway"
  action        = "lambda:InvokeFunction"
  function_name = module.appcontext_authorizer_lambda.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "${aws_apigatewayv2_api.orchestrator_api.execution_arn}/*"
}

resource "aws_apigatewayv2_authorizer" "appcontext_authorizer" {
  api_id                            = aws_apigatewayv2_api.orchestrator_api.id
  name                              = "orchestrator-appcontext_authorizer"
  authorizer_type                   = "REQUEST"
  authorizer_uri                    = aws_lambda_alias.appcontext_authorizer_live.invoke_arn
  identity_sources                  = ["$request.header.Paypal-Application-Context"]
  authorizer_payload_format_version = "2.0"
  enable_simple_responses           = true
}

variable "blue_green_traffic_weight" {
  description = "Percentage of traffic to route to green alias (0-100)"
  type        = number
  default     = 0
}

variable "blue_green_deployment_mode" {
  description = "Blue-green deployment mode: canary, all-at-once, or manual"
  type        = string
  default     = "canary"
  validation {
    condition     = contains(["canary", "all-at-once", "manual"], var.blue_green_deployment_mode)
    error_message = "Deployment mode must be one of: canary, all-at-once, manual."
  }
}

variable "blue_green_canary_steps" {
  description = "Canary deployment traffic distribution steps (percentages)"
  type        = list(number)
  default     = [10, 25, 50, 100]
}

variable "blue_green_health_check_grace_period" {
  description = "Grace period in minutes before health checks start after deployment"
  type        = number
  default     = 1
}
