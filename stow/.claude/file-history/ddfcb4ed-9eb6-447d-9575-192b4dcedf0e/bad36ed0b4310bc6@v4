import { describe, it, beforeEach, vi, expect } from "vitest";
import { createCart, updateCart, completeCart } from "./paypalTestOrder";
import { PayPalOrderManager } from "./PayPalOrderManager";
import { InternalServerError } from "../errors";

vi.mock("./PayPalOrderManager");

// Mock global fetch API
global.fetch = vi.fn();

// Mock btoa for Base64 encoding in auth header generation
global.btoa = vi.fn().mockImplementation((str) => `base64_${str}`);

// Mock the logger to prevent side effects during tests
vi.mock("../logger/logger", () => ({
  logger: () => ({
    info: vi.fn(),
    error: vi.fn(),
    warn: vi.fn(),
    debug: vi.fn(),
  }),
}));

// Mock SecretsManagerHelper
vi.mock("./SecretsManagerHelper", () => ({
  SecretsManagerHelper: {
    getInstance: vi.fn().mockReturnValue({
      getSecret: vi.fn().mockResolvedValue({
        mock: JSON.stringify({
          client_id: "test-client-id",
          client_secret: "test-client-secret",
          hostname: "https://test.paypal.com",
        }),
      }),
    }),
  },
}));

describe("PayPal Test Order", () => {
  beforeEach(() => {
    PayPalOrderManager.prototype.getAccessToken = vi
      .fn()
      .mockResolvedValue(undefined);
    process.env.MOCK_SECRET_PATH = "test/secret/path"; // Set MOCK_SECRET_PATH for all tests
  });

  describe("createCart", () => {
    const mockCreateCartRequest = {
      cartId: "valid-cart",
      merchantUrl: "https://merchant.com",
      products: [
        {
          productId: "product-1",
          quantity: 1,
        },
      ],
      shippingAddress: {
        addressLine1: "123 Main St",
        addressLine2: "Apartment 4B",
        adminArea2: "Los Angeles",
        adminArea1: "CA",
        postalCode: "90001",
        countryCode: "US",
      },
      customer: {
        id: "customer-1",
        email: "customer@example.com",
      },
    };

    it("should successfully create a cart and return Shopify-compatible response", async () => {
      PayPalOrderManager.prototype.createOrder = vi.fn().mockResolvedValue({
        id: "test-order-id",
        status: "CREATED",
        links: [
          {
            href: "https://example.com/approve",
            rel: "approve",
            method: "GET",
          },
        ],
        purchase_units: [
          {
            amount: {
              currency_code: "USD",
              value: "39.98",
            },
          },
        ],
      });

      const result = await createCart(mockCreateCartRequest);

      expect(result.status).toBe("success");
      expect(result.ecToken).toBe("test-order-id");
      expect(result.totalAmount).toEqual({
        currencyCode: "USD",
        value: "39.98",
      });
    });

    it("should handle order creation errors", async () => {
      PayPalOrderManager.prototype.createOrder = vi
        .fn()
        .mockRejectedValue(new Error("Failed to create PayPal order"));

      expect.assertions(1);

      try {
        await createCart(mockCreateCartRequest);
      } catch (error) {
        expect(error).toMatchObject(
          new InternalServerError("unknown", {
            details: [{ description: "Failed to create PayPal order" }],
          })
        );
      }
    });
  });

  describe("updateCart", () => {
    const mockUpdateCartRequest = {
      cart: {
        shippingAddress: {
          addressLine1: "456 New St",
          adminArea1: "CA",
          adminArea2: "Los Angeles",
          postalCode: "54321",
          countryCode: "US",
          givenName: "Jane",
          surname: "Smith",
        },
      },
      operations: [
        {
          op: "replace" as const,
          path: "/shippingAddress/addressLine1",
          value: "456 New St",
        },
      ],
    };

    it("should successfully update product quantities using patch operations", async () => {
      // Mock PayPalOrderManager methods needed for patch operations
      PayPalOrderManager.prototype.updateOrder = vi
        .fn()
        .mockResolvedValue(undefined);
      PayPalOrderManager.prototype.getOrder = vi.fn().mockResolvedValue({
        id: "test-order-id",
        purchase_units: [
          {
            amount: {
              currency_code: "USD",
              value: "75.00",
            },
          },
        ],
      });

      const requestWithProductChanges = {
        cart: {
          products: [
            {
              productId: "prod-1",
              quantity: 3, // Quantity change - now patchable following ACP handlers pattern
            },
          ],
        },
        operations: [],
      };

      const result = await updateCart(
        requestWithProductChanges,
        "test-order-id"
      );

      expect(result.status).toBe("success");
      expect(result.ecToken).toBe("test-order-id");
      expect(result.orderId).toBe("test-order-id");
      // Verify that updateOrder was called with patch operations
      expect(PayPalOrderManager.prototype.updateOrder).toHaveBeenCalledWith({
        orderId: "test-order-id",
        operations: expect.arrayContaining([
          expect.objectContaining({
            op: "replace",
            path: "/purchase_units/@reference_id=='default'/amount",
          }),
          expect.objectContaining({
            op: "replace",
            path: "/purchase_units/@reference_id=='default'/items",
          }),
        ]),
      });
    });

    it("should successfully update cart with patchable fields", async () => {
      PayPalOrderManager.prototype.updateOrder = vi
        .fn()
        .mockResolvedValue(undefined);
      PayPalOrderManager.prototype.getOrder = vi.fn().mockResolvedValue({
        id: "test-order-id",
        status: "CREATED",
        links: [
          {
            href: "https://example.com/approve",
            rel: "approve",
            method: "GET",
          },
        ],
        purchase_units: [
          {
            amount: {
              currency_code: "USD",
              value: "39.98",
            },
          },
        ],
      });

      const result = await updateCart(mockUpdateCartRequest, "test-order-id");

      expect(result.status).toBe("success");
      expect(result.ecToken).toBe("test-order-id");
      expect(result.totalAmount).toEqual({
        currencyCode: "USD",
        value: "39.98",
      });
    });

    it("should return original cart when no patchable operations are found", async () => {
      const result = await updateCart(
        { cart: {}, operations: [] },
        "test-order-id"
      );

      expect(result.status).toBe("success");
      expect(result.ecToken).toBe("test-order-id");
      expect(result.orderId).toBe("test-order-id");
      expect(global.fetch).not.toHaveBeenCalled();
    });

    it("should handle PATCH error and return error response", async () => {
      PayPalOrderManager.prototype.updateOrder = vi
        .fn()
        .mockRejectedValue(new Error("Failed to update PayPal order"));

      const result = await updateCart(mockUpdateCartRequest, "test-order-id");

      expect(result.status).toBe("error");
      expect(result.errorDetails).toBeDefined();
      expect(result.errorDetails?.errorCode).toBe("PATCH_ERROR");
      expect(result.errorDetails?.message).toContain(
        "Failed to update PayPal order"
      );
    });
  });

  describe("completeCart", () => {
    beforeEach(() => {
      vi.clearAllMocks();
    });

    const mockCompleteCartRequest = {
      cartId: "test-cart-123",
      paymentDetails: {
        ecToken: "EC-TEST123",
        payerId: "PAYER123",
        paymentMethod: "PAYPAL" as const,
      },
    };

    it("should successfully complete a cart with EC token", async () => {
      const result = await completeCart(mockCompleteCartRequest);

      expect(result.transactionId).toBe("EC-TEST123");
      expect(result.ecToken).toBe("EC-TEST123");
      expect(result.reviewOrderPage).toContain("EC-TEST123");
      expect(global.fetch).not.toHaveBeenCalled(); // No actual API calls in this mock implementation
    });
  });
});
