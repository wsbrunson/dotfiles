#!/usr/bin/env bash
set -euo pipefail

# AWS Profile Switcher
# Sets AWS_PROFILE environment variable to avoid --profile on every command
#
# Usage: aws-profile --env {stage|sandbox|prod}
#        aws-profile --show     (shows current profile)
#        aws-profile --list     (lists available profiles)

show_usage() {
    cat << EOF
AWS Profile Switcher

Usage:
  aws-profile --env stage     # Switch to stage environment
  aws-profile --env sandbox   # Switch to sandbox environment
  aws-profile --env prod      # Switch to production environment
  aws-profile --show          # Show current active profile
  aws-profile --list          # List available profiles
  aws-profile --help          # Show this help

Features:
- Automatically handles AWS SSO login if not authenticated
- Sets AWS_PROFILE in your current shell session
- Eliminates need for --profile flags on AWS commands

Usage in your shell:
Bash/Zsh: source aws-profile --env <environment>
Fish:      aws-profile --env <environment> | source

After switching, all AWS commands use the selected profile automatically.
EOF
}

show_current() {
    if [[ -n "${AWS_PROFILE:-}" ]]; then
        echo "Current AWS_PROFILE: $AWS_PROFILE"
    else
        echo "AWS_PROFILE not set (using default profile)"
    fi
}

list_profiles() {
    echo "Available profiles:"
    aws configure list-profiles
}

# Profile mapping function (bash 3.2 compatible)
get_profile_for_env() {
    local env="$1"
    case "$env" in
        stage)   echo "PowerUser-120569643495" ;;
        sandbox) echo "PowerUser-699475925820" ;;
        prod)    echo "PowerUser-982081089354" ;;
        *)       return 1 ;;
    esac
}

# Check if profile is authenticated and login if needed
ensure_profile_authenticated() {
    local profile="$1"
    local env="$2"

    echo "# Checking authentication for $env environment..." >&2

    # Try to get caller identity to check if authenticated
    if aws sts get-caller-identity --profile "$profile" --output json >/dev/null 2>&1; then
        echo "# Already authenticated to $env environment" >&2
        return 0
    fi

    echo "# Not authenticated to $env environment, initiating SSO login..." >&2

    # Attempt SSO login
    if aws sso login --profile "$profile"; then
        echo "# Successfully authenticated to $env environment" >&2
        return 0
    else
        echo "# SSO login failed for $env environment" >&2
        return 1
    fi
}

# Parse command line arguments
if [[ $# -eq 0 ]]; then
    show_usage
    exit 1
fi

case "$1" in
    --env)
        if [[ $# -ne 2 ]]; then
            echo "Error: --env requires an environment argument"
            echo "Valid environments: stage, sandbox, prod"
            exit 1
        fi

        env="$2"
        if ! profile=$(get_profile_for_env "$env"); then
            echo "Error: Unknown environment '$env'"
            echo "Valid environments: stage, sandbox, prod"
            exit 1
        fi

        # Check if profile exists
        if ! aws configure list-profiles | grep -q "^$profile$"; then
            echo "Warning: Profile '$profile' not found in AWS config"
            echo "Available profiles:"
            list_profiles
            exit 1
        fi

        # Ensure profile is authenticated
        if ! ensure_profile_authenticated "$profile" "$env"; then
            echo "# Failed to authenticate to $env environment" >&2
            exit 1
        fi

        # Check if we can detect the calling shell from environment
        if [[ -n "${FISH_VERSION:-}" ]] || pgrep -f "fish" >/dev/null 2>&1; then
            # Fish shell detected
            echo "set -gx AWS_PROFILE '$profile'; echo '# Switched to $env environment (profile: $profile)' >&2"
        else
            # Default to bash/zsh syntax
            echo "export AWS_PROFILE='$profile'"
            echo "# Switched to $env environment (profile: $profile)" >&2
            echo "# Current profile: $profile" >&2
        fi
        ;;
    --show)
        show_current
        ;;
    --list)
        list_profiles
        ;;
    --help|-h)
        show_usage
        ;;
    *)
        echo "Error: Unknown option '$1'"
        show_usage
        exit 1
        ;;
esac