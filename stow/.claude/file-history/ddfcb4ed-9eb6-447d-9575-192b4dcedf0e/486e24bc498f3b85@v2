// Import AFTER mocks
import { cartFailureMetrics } from './cartFailureMetric' // adjust path if needed
import { trackFailedAddCartFireAndForget } from 'shared/metrics/emitMetric'
import { sendAddCartFailureAlarmMetricFireAndForget } from 'shared/metrics/alarm-metrics'
import { ProductDiscontinuedError } from '../errors'

// ── Minimal Context helper ──
function makeContext(opts?: {
  debugId?: string
  start?: number
  merchantUrl?: string | undefined
  eventOverrides?: Partial<ALBEvent>
}): Context {
  const start = opts?.start ?? 1000
  const map = new Map<string, any>([
    ['debugId', opts?.debugId ?? 'dbg-123'],
    ['overallStartTime', start],
    ['data', opts?.merchantUrl !== undefined ? { merchantUrl: opts.merchantUrl } : undefined],
  ])

  const baseEvent: ALBEvent = {
    httpMethod: 'POST',
    path: '/commerceorchnodeserv/v2/shopify/cart',
    headers: {},
    multiValueHeaders: {},
    queryStringParameters: null,
    multiValueQueryStringParameters: null,
    body: null,
    isBase64Encoded: false,
    requestContext: { elb: { targetGroupArn: 'arn:aws:elasticloadbalancing:xx:acct:tg/name/id' } },
  } as any

  const event = { ...baseEvent, ...(opts?.eventOverrides ?? {}) } as ALBEvent

  return {
    env: { event },
    get: (k: string) => map.get(k),
  } as unknown as Context
}

describe('cartFailureMetrics', () => {
  beforeEach(() => {
    vi.clearAllMocks()
    vi.spyOn(performance, 'now').mockReturnValue(1500) // deterministic duration
  })

 it('logs & emits failure metrics and returns converted error response', async () => {
    // Arrange
    const err = new ProductDiscontinuedError('dbg-123', {
      details: [
        {
          description: 'discontinued',
        },
      ],
    });

    const c = makeContext({ start: 1000, merchantUrl: 'https://merchant.example' });
    const fn = cartFailureMetrics({ orchestrator: 'Shopify' });

    // Act
    const res = await fn(err, c);

    // Assert: return value
    expect(res).toEqual({
      statusCode: 422,
      headers: {
        'Content-Type': 'application/json',
        'paypal-debug-id': 'unknown',
      },
      body: JSON.stringify({
        name: 'ProductDiscontinuedError',
        status: 422,
        message: 'Unprocessable Entity',
        details: [
          {
            description: 'discontinued',
            issue: 'ITEM_DISCONTINUED',
          },
        ],
      }),
    });

    // Assert: metrics
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: 'https://merchant.example',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: '422',
    });
    expect(sendAddCartFailureAlarmMetricFireAndForget).toHaveBeenCalledWith({ orchestrator: 'Shopify' });

  });

 it('defaults merchantUrl to empty string when missing', async () => {
    // Arrange
    const err = new Error('oops');
    const c = makeContext({ merchantUrl: undefined, debugId: 'dbg-999' });
    const fn = cartFailureMetrics({ orchestrator: 'Shopify' });

    // Act
    const res = await fn(err, c);

    // Assert: return value
    expect(res).toEqual({
      statusCode: 500,
      headers: {
        'Content-Type': 'application/json',
        'paypal-debug-id': 'unknown',
      },
      body: JSON.stringify({
        name: 'InternalServerError',
        status: 500,
        message: 'Internal Server Error',
        details: [
          {
            description: 'oops',
          },
        ],
      }),
    });

    // Assert: metrics
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: '',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: '500',
    });
  });
})
