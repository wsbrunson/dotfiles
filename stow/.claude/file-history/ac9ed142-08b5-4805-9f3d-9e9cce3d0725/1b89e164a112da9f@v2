import { emitDatadogMetricFireAndForget } from "./datadogMetrics";
import type { Context } from "hono";
import { routePath } from "hono/route";

export type HttpRequestMetrics = {
  method: string;
  route: string;
  startTime: number;
  env?: string;
};

type BaseMetricParams = {
  method: string;
  route: string;
  env?: string;
};

export function httpRequestInit({
  c,
}: {
  c: Context;
}): HttpRequestMetrics {
  const method = c.req.method;
  const route = routePath(c) || c.req.path;
  const env = process.env.APP_ENV;

  const baseParams: BaseMetricParams = {
    method,
    route,
    env,
  };

  emitDatadogMetricFireAndForget("http.requests.count", baseParams, 1);

  return {
    method,
    route,
    startTime: performance.now(),
    env,
  };
}

// Standalone version for non-Hono contexts (Lambda functions)
export function httpRequestInitStandalone({
  method,
  route,
}: {
  method: string;
  route: string;
}): HttpRequestMetrics {
  const env = process.env.APP_ENV;

  const baseParams: BaseMetricParams = {
    method,
    route,
    env,
  };

  emitDatadogMetricFireAndForget("http.requests.count", baseParams, 1);

  return {
    method,
    route,
    startTime: performance.now(),
    env,
  };
}

export function httpRequestSuccess({
  metrics,
  statusCode,
}: {
  metrics: HttpRequestMetrics;
  statusCode: number;
}): void {
  const duration = performance.now() - metrics.startTime;

  const successParams = {
    method: metrics.method,
    route: metrics.route,
    env: metrics.env,
    status_code: statusCode.toString(),
    status_class: getStatusClass(statusCode),
  };

  emitDatadogMetricFireAndForget(
    "http.requests.success.count",
    successParams,
    1,
  );
  emitDatadogMetricFireAndForget(
    "http.request.duration",
    successParams,
    duration,
  );
}

export function httpRequestError({
  metrics,
  error,
}: {
  metrics: HttpRequestMetrics;
  error: Error | number | unknown;
}): void {
  const duration = performance.now() - metrics.startTime;

  let statusCode = 500;
  let errorType = "unknown";

  if (typeof error === "number") {
    statusCode = error;
    errorType = "http_error";
  } else if (error instanceof Error) {
    errorType = error.constructor.name;
    if ("statusCode" in error && typeof error.statusCode === "number") {
      statusCode = error.statusCode;
    } else if ("status" in error && typeof error.status === "number") {
      statusCode = error.status;
    }
  }

  const errorParams = {
    method: metrics.method,
    route: metrics.route,
    env: metrics.env,
    status_code: statusCode.toString(),
    status_class: getStatusClass(statusCode),
    error_type: errorType,
  };

  emitDatadogMetricFireAndForget("http.requests.error.count", errorParams, 1);
  emitDatadogMetricFireAndForget(
    "http.request.duration",
    errorParams,
    duration,
  );
}

export type CommerceOrchestratorMetrics = {
  orchestrator: string;
  merchant?: string;
  partner?: string;
  env?: string;
  startTime: number;
};

type CommerceMetricParams = {
  orchestrator: string;
  merchant?: string;
  partner?: string;
  env?: string;
};

export function commerceOrchestratorRequestInit({
  orchestrator,
  merchant,
  partner,
}: {
  orchestrator: string;
  merchant?: string;
  partner?: string;
}): CommerceOrchestratorMetrics {
  const env = process.env.APP_ENV;

  const baseParams: CommerceMetricParams = {
    orchestrator,
    env,
    ...(merchant && { merchant }),
    ...(partner && { partner }),
  };

  emitDatadogMetricFireAndForget("commerce.orchestrator.requests.count", baseParams, 1);

  return {
    orchestrator,
    env,
    startTime: performance.now(),
    ...(merchant && { merchant }),
    ...(partner && { partner }),
  };
}

// Standalone version that's the same as above (no Hono dependency)
export const commerceOrchestratorRequestInitStandalone = commerceOrchestratorRequestInit;

export function commerceOrchestratorRequestSuccess({
  metrics,
  statusCode,
}: {
  metrics: CommerceOrchestratorMetrics;
  statusCode: number;
}): void {
  const duration = performance.now() - metrics.startTime;

  const successParams = {
    orchestrator: metrics.orchestrator,
    env: metrics.env,
    status_code: statusCode.toString(),
    status_class: getStatusClass(statusCode),
    ...(metrics.merchant && { merchant: metrics.merchant }),
    ...(metrics.partner && { partner: metrics.partner }),
  };

  emitDatadogMetricFireAndForget(
    "commerce.orchestrator.requests.success.count",
    successParams,
    1,
  );
  emitDatadogMetricFireAndForget(
    "commerce.orchestrator.request.duration",
    successParams,
    duration,
  );
}

export function commerceOrchestratorRequestError({
  metrics,
  error,
  statusCode,
}: {
  metrics: CommerceOrchestratorMetrics;
  error: Error | number | unknown;
  statusCode?: number;
}): void {
  const duration = performance.now() - metrics.startTime;

  let finalStatusCode = statusCode || 500;
  let errorType = "unknown";

  if (typeof error === "number") {
    finalStatusCode = error;
    errorType = "http_error";
  } else if (error instanceof Error) {
    errorType = error.constructor.name;
    if (!statusCode) {
      if ("statusCode" in error && typeof error.statusCode === "number") {
        finalStatusCode = error.statusCode;
      } else if ("status" in error && typeof error.status === "number") {
        finalStatusCode = error.status;
      }
    }
  }

  const errorParams = {
    orchestrator: metrics.orchestrator,
    env: metrics.env,
    status_code: finalStatusCode.toString(),
    status_class: getStatusClass(finalStatusCode),
    error_type: errorType,
    ...(metrics.merchant && { merchant: metrics.merchant }),
    ...(metrics.partner && { partner: metrics.partner }),
  };

  emitDatadogMetricFireAndForget("commerce.orchestrator.requests.error.count", errorParams, 1);
  emitDatadogMetricFireAndForget(
    "commerce.orchestrator.request.duration",
    errorParams,
    duration,
  );
}

function getStatusClass(statusCode: number): string {
  if (statusCode >= 200 && statusCode < 300) return "2xx";
  if (statusCode >= 300 && statusCode < 400) return "3xx";
  if (statusCode >= 400 && statusCode < 500) return "4xx";
  if (statusCode >= 500 && statusCode < 600) return "5xx";
  return "unknown";
}
