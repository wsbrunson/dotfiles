import { camelCase } from "lodash";
import { logger } from "../logger/logger";
import * as dgram from "dgram";

// StatsD configuration
const DD_AGENT_HOST = process.env.DD_AGENT_HOST || "127.0.0.1";
const DD_DOGSTATSD_PORT = parseInt(process.env.DD_DOGSTATSD_PORT || "8125", 10);

type MetricParams = Record<string, string | number | boolean | undefined>;

/**
 * Emit custom metric to Datadog via StatsD (DogStatsD)
 * Uses UDP to send metrics to the Datadog Lambda extension
 */
export async function emitDatadogMetric(
  metricName: string,
  params: MetricParams,
  value: number = 1,
): Promise<void> {
  const log = logger("DatadogMetrics");

  try {
    const tags: string[] = Object.keys(params).map((key) => {
      if (key === "merchantUrl") {
        try {
          const url = new URL(params.merchantUrl as string);
          return `merchant_url:${url.hostname}`;
        } catch {
          return `merchant_url:${params.merchantUrl}`;
        }
      }

      return `${camelCase(key)}:${params[key]}`;
    });

    if (process.env.AWS_LAMBDA_FUNCTION_NAME) {
      tags.push(`resource_name:${process.env.AWS_LAMBDA_FUNCTION_NAME}`);
    }

    tags.push("service:commerce-orchestrator");

    // Format: metric.name:value|c|#tag1:value1,tag2:value2
    const tagString = tags.length > 0 ? `|#${tags.join(",")}` : "";
    const statsdMessage = `commerce_orchestrator.${metricName}:${value}|c${tagString}`;

    const client = dgram.createSocket("udp4");
    const buffer = Buffer.from(statsdMessage);

    await new Promise<void>((resolve, reject) => {
      client.send(
        buffer,
        0,
        buffer.length,
        DD_DOGSTATSD_PORT,
        DD_AGENT_HOST,
        (err) => {
          client.close();
          if (err) {
            reject(err);
          } else {
            log.info("Datadog metric emitted via StatsD", {
              metricName,
              tags,
              value,
            });
            resolve();
          }
        },
      );
    });
  } catch (error) {
    log.error("Failed to emit Datadog metric via StatsD", {
      metricName,
      error: error instanceof Error ? error : new Error(String(error)),
    });
  }
}

/**
 * Fire-and-forget version that immediately returns without blocking
 * Use this for latency-sensitive operations
 */
export function emitDatadogMetricFireAndForget(
  metricName: string,
  params: MetricParams,
  value: number = 1,
): void {
  setImmediate(() => {
    /* v8 ignore start */
    emitDatadogMetric(metricName, params, value).catch((error) => {
      const log = logger("DatadogMetrics");
      log.error("Failed to emit Datadog metric (fire-and-forget)", {
        metricName,
        error: error instanceof Error ? error : new Error(String(error)),
      });
    });
    /* v8 ignore stop */
  });
}
