import { describe, it, expect } from "vitest";
import { StatusCodes, ReasonPhrases } from "http-status-codes";
import { ALBEvent } from "aws-lambda";
import { ZodError } from "zod/v4";
import {
  convertErrorToLambdaResponse,
  APIError,
  BlockedByBotDetectionError,
  ForbiddenError,
  AppErrorCodes,
} from "./index";
import { getMockALBEvent } from "../test-utils/mockALBEvent";

describe("convertErrorToLambdaResponse", () => {
  const mockALBEvent = {
    headers: {},
    body: "",
    isBase64Encoded: false,
    httpMethod: "POST",
    path: "/test",
    queryStringParameters: undefined,
    multiValueQueryStringParameters: undefined,
    pathParameters: undefined,
    stageVariables: undefined,
    requestContext: {
      elb: {
        targetGroupArn:
          "arn:aws:elasticloadbalancing:region:123456789012:targetgroup/test/1234567890123456",
      },
    },
  } as ALBEvent;

  it("should convert APIError to Lambda response format", () => {
    const apiError = new APIError("test-debug-id", {
      name: "TestError",
      status: StatusCodes.BAD_REQUEST,
      message: "Test error message",
      details: [{ field: "test", issue: "invalid" }],
    });

    const [returnedApiError, result] = convertErrorToLambdaResponse(
      apiError,
      mockALBEvent,
    );

    expect(returnedApiError).toBe(apiError);
    expect(result).toEqual({
      statusCode: StatusCodes.BAD_REQUEST,
      headers: {
        "Content-Type": "application/json",
        "paypal-debug-id": "unknown",
      },
      body: JSON.stringify({
        name: "TestError",
        status: StatusCodes.BAD_REQUEST,
        message: "Test error message",
        details: [{ field: "test", issue: "invalid" }],
      }),
    });
  });

  it("should convert unknown error to APIError and Lambda response", () => {
    const unknownError = new Error("Unknown error");

    const [apiError, result] = convertErrorToLambdaResponse(
      unknownError,
      mockALBEvent,
    );

    expect(apiError).toBeInstanceOf(APIError);
    expect(result).toEqual({
      statusCode: StatusCodes.INTERNAL_SERVER_ERROR,
      headers: {
        "Content-Type": "application/json",
        "paypal-debug-id": "unknown",
      },
      body: JSON.stringify({
        name: "InternalServerError",
        status: StatusCodes.INTERNAL_SERVER_ERROR,
        message: ReasonPhrases.INTERNAL_SERVER_ERROR,
        details: [{ description: "Unknown error" }],
      }),
    });
  });

  it("should use correlation ID from event in headers", () => {
    const eventWithDebugId = {
      ...mockALBEvent,
      headers: {
        "paypal-debug-id": "test-debug-id",
      },
    };

    const error = new Error("Test error");
    const [, result] = convertErrorToLambdaResponse(error, eventWithDebugId);

    expect(result.headers?.["paypal-debug-id"]).toBe("test-debug-id");
  });

  it("should convert ZodError to APIError and Lambda response", () => {
    const zodError = new ZodError([
      {
        code: "invalid_type",
        expected: "string",
        path: ["user", "name"],
        message: "Expected string, received number",
        input: undefined,
      } as any,
      {
        code: "too_small",
        minimum: 1,
        inclusive: true,
        exact: false,
        path: ["user", "email"],
        message: "String must contain at least 1 character(s)",
        input: undefined,
      } as any,
    ]);

    const [apiError, result] = convertErrorToLambdaResponse(
      zodError,
      mockALBEvent,
    );

    expect(apiError).toBeInstanceOf(APIError);
    expect(result).toEqual({
      statusCode: StatusCodes.BAD_REQUEST,
      headers: {
        "Content-Type": "application/json",
        "paypal-debug-id": "unknown",
      },
      body: JSON.stringify({
        name: "ZodError",
        status: StatusCodes.BAD_REQUEST,
        message: ReasonPhrases.BAD_REQUEST,
        details: [
          {
            field: "user.name",
            issue: "invalid_type",
            description: "Expected string, received number",
          },
          {
            field: "user.email",
            issue: "too_small",
            description: "String must contain at least 1 character(s)",
          },
        ],
      }),
    });
  });

  it("should handle ZodError with empty path", () => {
    const zodError = new ZodError([
      {
        code: "custom",
        path: [],
        message: "Root level validation error",
        input: undefined,
      },
    ]);

    const [, result] = convertErrorToLambdaResponse(zodError, mockALBEvent);

    expect(result.statusCode).toBe(StatusCodes.BAD_REQUEST);
    const responseBody = JSON.parse(result.body);
    expect(responseBody.name).toBe("ZodError");
    expect(responseBody.details).toEqual([
      {
        field: "",
        issue: "custom",
        description: "Root level validation error",
      },
    ]);
  });

  it("should handle ZodError with nested paths", () => {
    const zodError = new ZodError([
      {
        code: "invalid_type",
        expected: "object",
        path: ["data", "user", "profile", "settings"],
        message: "Expected object, received null",
        input: undefined,
      } as any,
    ]);

    const [, result] = convertErrorToLambdaResponse(zodError, mockALBEvent);

    expect(result.statusCode).toBe(StatusCodes.BAD_REQUEST);
    const responseBody = JSON.parse(result.body);
    expect(responseBody.details).toEqual([
      {
        field: "data.user.profile.settings",
        issue: "invalid_type",
        description: "Expected object, received null",
      },
    ]);
  });
});

describe("ForbiddenError", () => {
  it("should create a ForbiddenError with default values", () => {
    const error = new ForbiddenError("test-debug-id");

    expect(error.name).toBe("ForbiddenError");
    expect(error.status).toBe(StatusCodes.FORBIDDEN);
    expect(error.message).toBe(ReasonPhrases.FORBIDDEN);
    expect(error.debugId).toBe("test-debug-id");
    expect(error.details).toEqual([]);
  });

  it("should create a ForbiddenError with custom values", () => {
    const customDetails = [{ description: "Custom forbidden message" }];
    const error = new ForbiddenError("test-debug-id", {
      name: "CustomForbiddenError",
      message: "Custom forbidden message",
      details: customDetails,
    });

    expect(error.name).toBe("CustomForbiddenError");
    expect(error.status).toBe(StatusCodes.FORBIDDEN);
    expect(error.message).toBe("Custom forbidden message");
    expect(error.debugId).toBe("test-debug-id");
    expect(error.details).toEqual(customDetails);
  });
});

describe("BlockedByBotDetectionError", () => {
  it("should create a BlockedByBotDetectionError with default values", () => {
    const error = new BlockedByBotDetectionError("test-debug-id");

    expect(error.name).toBe("BlockedByBotDetectionError");
    expect(error.status).toBe(StatusCodes.FORBIDDEN);
    expect(error.message).toBe("Access blocked by bot detection");
    expect(error.debugId).toBe("test-debug-id");
    expect(error.details).toEqual([
      {
        description: "Bot prevented",
        issue: AppErrorCodes.BLOCKED_BY_BOT_DETECTION,
      },
    ]);
  });

  it("should create a BlockedByBotDetectionError with custom details", () => {
    const customDetails = [
      {
        description:
          "Unable to fetch initial merchant page properties: https://supplyme.com",
      },
    ];
    const error = new BlockedByBotDetectionError("test-debug-id", {
      details: customDetails,
    });

    expect(error.name).toBe("BlockedByBotDetectionError");
    expect(error.status).toBe(StatusCodes.FORBIDDEN);
    expect(error.message).toBe("Access blocked by bot detection");
    expect(error.debugId).toBe("test-debug-id");
    expect(error.details).toEqual([
      {
        description:
          "Unable to fetch initial merchant page properties: https://supplyme.com",
        issue: AppErrorCodes.BLOCKED_BY_BOT_DETECTION,
      },
    ]);
  });

  it("should create a BlockedByBotDetectionError with custom name", () => {
    const error = new BlockedByBotDetectionError("test-debug-id", {
      name: "CustomBotBlockedError",
    });

    expect(error.name).toBe("CustomBotBlockedError");
    expect(error.status).toBe(StatusCodes.FORBIDDEN);
    expect(error.message).toBe("Access blocked by bot detection");
  });

  it("should extend ForbiddenError", () => {
    const error = new BlockedByBotDetectionError("test-debug-id");

    expect(error).toBeInstanceOf(ForbiddenError);
    expect(error).toBeInstanceOf(APIError);
  });

  it("should convert BlockedByBotDetectionError to Lambda response format", () => {
    const mockALBEvent = getMockALBEvent({
      headers: { "paypal-debug-id": "test-debug-id" },
    });

    const error = new BlockedByBotDetectionError("test-debug-id", {
      details: [
        {
          description:
            "Unable to fetch initial merchant page properties: https://supplyme.com",
        },
      ],
    });

    const [apiError, result] = convertErrorToLambdaResponse(
      error,
      mockALBEvent,
    );

    expect(apiError).toBe(error);
    expect(result).toEqual({
      statusCode: StatusCodes.FORBIDDEN,
      headers: {
        "Content-Type": "application/json",
        "paypal-debug-id": "test-debug-id",
      },
      body: JSON.stringify({
        name: "BlockedByBotDetectionError",
        status: StatusCodes.FORBIDDEN,
        message: "Access blocked by bot detection",
        details: [
          {
            description:
              "Unable to fetch initial merchant page properties: https://supplyme.com",
            issue: AppErrorCodes.BLOCKED_BY_BOT_DETECTION,
          },
        ],
      }),
    });
  });
});
