name: Publish NPM Package

on:
  push:
    branches:
      - main
    paths:
      - 'packages/npm/agentic-commerce-spec/**'
      - 'v1/api-spec.yaml'

  # Allow manual trigger
  workflow_dispatch:

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20.19.1'

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: latest

      - name: Configure npm registry
        run: |
          echo "//npm.dev.paypalinc.com/:_authToken=${{ secrets.NPM_TOKEN }}" > ~/.npmrc
          echo "registry=https://npm.dev.paypalinc.com/" >> ~/.npmrc

      - name: Install dependencies
        run: |
          cd packages/npm
          pnpm install

      - name: Build package
        run: |
          cd packages/npm/agentic-commerce-spec
          pnpm build

      - name: Publish to npm registry
        run: |
          cd packages/npm/agentic-commerce-spec
          pnpm publish --no-git-checks
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}