import { describe, it, expect, vi, beforeEach, afterEach, Mock } from "vitest";
import * as jwt from "jsonwebtoken";
import { verifyAppContext } from "../services/AppContextAuthorizer";
import { Logger } from "../logger";

vi.mock("jsonwebtoken", () => ({
  verify: vi.fn(),
}));

describe("verifyAppContext", () => {
  let mockLogger: Logger;
  let mockRequest: any;
  const ORIGINAL_ENV = process.env;

  beforeEach(() => {
    vi.clearAllMocks();
    process.env = { ...ORIGINAL_ENV };

    mockLogger = {
      info: vi.fn(),
      warn: vi.fn(),
      error: vi.fn(),
    } as unknown as Logger;

    mockRequest = {
      headers: {
        "paypal-application-context": "mockAppContext",
        // "application-api-key": undefined by default
      },
    };
  });

  afterEach(() => {
    process.env = ORIGINAL_ENV;
  });

  it("returns true when a valid API key header matches the environment variable (short-circuits JWT)", async () => {
    process.env.COMMERCE_ONBOARDING_API_KEY = "super-secret";
    mockRequest.headers["application-api-key"] = "super-secret";

    const result = await verifyAppContext(mockRequest, mockLogger);

    expect(result).toBe(true);
    expect(jwt.verify).not.toHaveBeenCalled();
  });

  it("returns true for a valid app context when JWT verification succeeds", async () => {
    process.env.VERIFICATION_PEM = "mockPublicKey";
    (jwt.verify as Mock).mockImplementation(() => true);

    const result = await verifyAppContext(mockRequest, mockLogger);

    expect(jwt.verify).toHaveBeenCalledWith(
      "mockAppContext",
      "-----BEGIN PUBLIC KEY-----\nmockPublicKey\n-----END PUBLIC KEY-----",
      { algorithms: ["RS256"] },
    );
    expect(result).toBe(true);

    expect(mockLogger.info).toHaveBeenCalledWith("Using public key for verification", {
      hasPublicKey: true,
    });
    expect(mockLogger.info).toHaveBeenCalledWith("Verifying AppContext", {
      hasVerificationPem: true,
    });
  });

  it("returns false if app context is missing (and API key auth fails)", async () => {
    // API key path will fail: env set but header missing
    process.env.COMMERCE_ONBOARDING_API_KEY = "super-secret";
    mockRequest.headers["paypal-application-context"] = "";

    const result = await verifyAppContext(mockRequest, mockLogger);

    expect(result).toBe(false);
    expect(mockLogger.warn).toHaveBeenCalledWith("AppContext is missing");
    expect(jwt.verify).not.toHaveBeenCalled();
  });

  it("returns false if VERIFICATION_PEM is not set", async () => {
    delete process.env.VERIFICATION_PEM; // ensure undefined
    mockRequest.headers["paypal-application-context"] = "mockAppContext";

    const result = await verifyAppContext(mockRequest, mockLogger);

    expect(result).toBe(false);
    expect(mockLogger.error).toHaveBeenCalledWith(
      "VERIFICATION_PEM is not set in environment variables",
    );
    expect(jwt.verify).not.toHaveBeenCalled();
  });

  it("returns false and logs an error when JWT verification throws", async () => {
    process.env.VERIFICATION_PEM = "mockPublicKey";
    (jwt.verify as Mock).mockImplementation(() => {
      throw new Error("bad jwt");
    });

    const result = await verifyAppContext(mockRequest, mockLogger);

    expect(result).toBe(false);
    expect(mockLogger.error).toHaveBeenCalledWith("JWT verification failed", {
      error: "bad jwt",
    });
  });

  it("prefers API key auth over JWT when both API key and app context are present", async () => {
    process.env.COMMERCE_ONBOARDING_API_KEY = "super-secret";
    mockRequest.headers["application-api-key"] = "super-secret";
    mockRequest.headers["paypal-application-context"] = "stillPresent";

    const result = await verifyAppContext(mockRequest, mockLogger);

    expect(result).toBe(true);
    expect(jwt.verify).not.toHaveBeenCalled(); // short-circuited
  });

  describe("Dual PEM Verification", () => {
    beforeEach(() => {
      process.env.VERIFICATION_PEM = "MIIB...regular-key";
      process.env.SANDBOX_VERIFICATION_PEM = "MIIB...sandbox-key";
    });

    it("should use regular PEM first and succeed", async () => {
      process.env.ENVIRONMENT = "test";
      (jwt.verify as Mock).mockReturnValue({} as any);

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(true);
      expect(jwt.verify).toHaveBeenCalledWith(
        "mockAppContext",
        "-----BEGIN PUBLIC KEY-----\nMIIB...regular-key\n-----END PUBLIC KEY-----",
        { algorithms: ["RS256"] }
      );
    });

    it("should fallback to sandbox PEM in test environment when regular fails", async () => {
      process.env.ENVIRONMENT = "test";
      (jwt.verify as Mock)
        .mockImplementationOnce(() => { throw new Error("Regular key failed"); })
        .mockReturnValueOnce({} as any);

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(true);
      expect(jwt.verify).toHaveBeenCalledTimes(2);
      expect(jwt.verify).toHaveBeenNthCalledWith(1,
        "mockAppContext",
        "-----BEGIN PUBLIC KEY-----\nMIIB...regular-key\n-----END PUBLIC KEY-----",
        { algorithms: ["RS256"] }
      );
      expect(jwt.verify).toHaveBeenNthCalledWith(2,
        "mockAppContext",
        "-----BEGIN PUBLIC KEY-----\nMIIB...sandbox-key\n-----END PUBLIC KEY-----",
        { algorithms: ["RS256"] }
      );
    });

    it("should not try sandbox PEM in non-test environment", async () => {
      process.env.ENVIRONMENT = "prod";
      (jwt.verify as Mock).mockImplementation(() => { throw new Error("Regular key failed"); });

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(false);
      expect(jwt.verify).toHaveBeenCalledTimes(1);
      expect(jwt.verify).toHaveBeenCalledWith(
        "mockAppContext",
        "-----BEGIN PUBLIC KEY-----\nMIIB...regular-key\n-----END PUBLIC KEY-----",
        { algorithms: ["RS256"] }
      );
    });

    it("should not try sandbox PEM when SANDBOX_VERIFICATION_PEM is not set", async () => {
      process.env.ENVIRONMENT = "test";
      delete process.env.SANDBOX_VERIFICATION_PEM;
      (jwt.verify as Mock).mockImplementation(() => { throw new Error("Regular key failed"); });

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(false);
      expect(jwt.verify).toHaveBeenCalledTimes(1);
    });

    it("should return false when both PEMs fail in test environment", async () => {
      process.env.ENVIRONMENT = "test";
      (jwt.verify as Mock)
        .mockImplementationOnce(() => { throw new Error("Regular key failed"); })
        .mockImplementationOnce(() => { throw new Error("Sandbox key failed"); });

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(false);
      expect(jwt.verify).toHaveBeenCalledTimes(2);
    });
  });

  describe("parseKey helper (indirect testing through verification)", () => {
    it("should handle PEM without BEGIN/END markers", async () => {
      const rawPem = "MIIB...raw-key-content";
      process.env.VERIFICATION_PEM = rawPem;

      (jwt.verify as Mock).mockReturnValue({} as any);

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(true);
      expect(jwt.verify).toHaveBeenCalledWith(
        "mockAppContext",
        "-----BEGIN PUBLIC KEY-----\nMIIB...raw-key-content\n-----END PUBLIC KEY-----",
        { algorithms: ["RS256"] }
      );
    });

    it("should handle PEM that already has BEGIN/END markers", async () => {
      const formattedPem = "-----BEGIN PUBLIC KEY-----\nMIIB...formatted-key\n-----END PUBLIC KEY-----";
      process.env.VERIFICATION_PEM = formattedPem;

      (jwt.verify as Mock).mockReturnValue({} as any);

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(true);
      expect(jwt.verify).toHaveBeenCalledWith(
        "mockAppContext",
        formattedPem,
        { algorithms: ["RS256"] }
      );
    });

    it("should handle sandbox PEM formatting in test environment", async () => {
      process.env.ENVIRONMENT = "test";
      process.env.VERIFICATION_PEM = "MIIB...regular-key";
      process.env.SANDBOX_VERIFICATION_PEM = "MIIB...sandbox-raw-key";

      (jwt.verify as Mock)
        .mockImplementationOnce(() => { throw new Error("Regular failed"); })
        .mockReturnValueOnce({} as any);

      const result = await verifyAppContext(mockRequest, mockLogger);

      expect(result).toBe(true);
      expect(jwt.verify).toHaveBeenCalledTimes(2);
      expect(jwt.verify).toHaveBeenNthCalledWith(2,
        "mockAppContext",
        "-----BEGIN PUBLIC KEY-----\nMIIB...sandbox-raw-key\n-----END PUBLIC KEY-----",
        { algorithms: ["RS256"] }
      );
    });
  });
});
