/* eslint-disable no-console */

import express from "express";
import bodyParser from "body-parser";
import setupRoutes from "../../../src/routes";

export function setupTestApp() {
  // Create Express app
  const app = express();

  // Add mock logger middleware
  app.use((req, res, next) => {
    (req as any).log = (level: string, message: string, data?: any) => {
      console.log(
        `[${level.toUpperCase()}] ${message}`,
        data ? JSON.stringify(data, null, 2) : "",
      );
    };
    next();
  });

  const mockAuth = {
    authorize: () => (req: any, res: any, next: any) => {
      req.user = {
        actor: {
          client_id: "test-client-id",
          id: "test-user-id",
          auth_claims: ["CLIENT_ID_SECRET"],
          auth_state: "LOGGEDIN",
          account_number: "test-account",
          party_id: "test-party-id",
          user_type: "API_CALLER",
          legal_country: "US",
        },
        auth_token: "test-auth-token",
        auth_token_type: "ACCESS_TOKEN",
        scopes: ["https://uri.paypal.com/services/commerce/orchestration"],
      };
      next();
    },
  };

  app.set("auth", mockAuth);

  // Add body parser middleware
  app.use(bodyParser.json());
  app.use(bodyParser.urlencoded({ extended: true }));

  setupRoutes(app);

  return {
    app,
  };
}
