#!/usr/bin/env bash

# GitHub Actions Workflow Dispatcher
# A CLI tool for dispatching GitHub Actions workflows with input validation

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Global variables
REPO=""
WORKFLOW=""
BRANCH=""
INPUTS=()
VERBOSE=false
WATCH=false
GET_URL=false

# Print colored output
print_info() {
    echo -e "${BLUE}INFO:${NC} $1"
}

print_success() {
    echo -e "${GREEN}SUCCESS:${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}WARNING:${NC} $1"
}

print_error() {
    echo -e "${RED}ERROR:${NC} $1" >&2
}

print_verbose() {
    if [[ "$VERBOSE" == true ]]; then
        echo -e "${BLUE}VERBOSE:${NC} $1"
    fi
}

# Show usage information
show_help() {
    cat << EOF
GitHub Actions Workflow Dispatcher

USAGE:
    gha-dispatch --repo OWNER/REPO --workflow WORKFLOW_FILE --branch BRANCH [OPTIONS]

REQUIRED ARGUMENTS:
    --repo OWNER/REPO       Repository in format owner/repo
    --workflow FILE         Workflow file name (e.g., deploy-test.yaml)
    --branch BRANCH         Branch or ref to run workflow on

OPTIONS:
    --input KEY=VALUE       Input field for workflow (can be used multiple times)
    --watch                 Monitor workflow execution until completion
    --get-url               Return the GitHub Actions run URL
    --verbose               Enable verbose output
    --help                  Show this help message

EXAMPLES:
    # Basic usage
    gha-dispatch --repo PayPal-Zettle/commerce-orchestrator \\
                 --workflow deploy-test.yaml \\
                 --branch test-sephora

    # With inputs
    gha-dispatch --repo PayPal-Zettle/commerce-orchestrator \\
                 --workflow deploy-test.yaml \\
                 --branch test-sephora \\
                 --input functions="generic-create-cart" \\
                 --input deployment-mode="all-at-once" \\
                 --input action-type="deploy"

    # Watch workflow execution
    gha-dispatch --repo owner/repo \\
                 --workflow workflow.yaml \\
                 --branch main \\
                 --watch

    # Get run URL
    gha-dispatch --repo owner/repo \\
                 --workflow workflow.yaml \\
                 --branch main \\
                 --get-url

REQUIREMENTS:
    - GitHub CLI (gh) must be installed and authenticated
    - Repository access permissions for workflow dispatch
    - yq tool for YAML parsing (install with: brew install yq)

EOF
}

# Check required dependencies
check_dependencies() {
    print_verbose "Checking required dependencies..."

    if ! command -v gh &> /dev/null; then
        print_error "GitHub CLI (gh) is not installed. Please install it first."
        print_info "Install with: brew install gh (macOS) or visit https://cli.github.com/"
        exit 1
    fi

    if ! command -v yq &> /dev/null; then
        print_error "yq is not installed. This tool is required for YAML parsing."
        print_info "Install with: brew install yq (macOS) or visit https://github.com/mikefarah/yq"
        exit 1
    fi

    # Check if gh is authenticated
    if ! gh auth status &> /dev/null; then
        print_error "GitHub CLI is not authenticated. Please run 'gh auth login' first."
        exit 1
    fi

    print_verbose "All dependencies are available"
}

# Parse command line arguments
parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --repo)
                REPO="$2"
                shift 2
                ;;
            --workflow)
                WORKFLOW="$2"
                shift 2
                ;;
            --branch)
                BRANCH="$2"
                shift 2
                ;;
            --input)
                if [[ "$2" =~ ^([^=]+)=(.*)$ ]]; then
                    INPUTS+=("$2")
                else
                    print_error "Invalid input format: $2. Use KEY=VALUE format."
                    exit 1
                fi
                shift 2
                ;;
            --watch)
                WATCH=true
                shift
                ;;
            --get-url)
                GET_URL=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            --help)
                show_help
                exit 0
                ;;
            *)
                print_error "Unknown option: $1"
                print_info "Use --help for usage information"
                exit 1
                ;;
        esac
    done

    # Validate required arguments
    if [[ -z "$REPO" ]]; then
        print_error "Repository is required. Use --repo OWNER/REPO"
        exit 1
    fi

    if [[ -z "$WORKFLOW" ]]; then
        print_error "Workflow file is required. Use --workflow FILE"
        exit 1
    fi

    if [[ -z "$BRANCH" ]]; then
        print_error "Branch is required. Use --branch BRANCH"
        exit 1
    fi

    # Validate repo format
    if [[ ! "$REPO" =~ ^[^/]+/[^/]+$ ]]; then
        print_error "Invalid repository format: $REPO. Use OWNER/REPO format."
        exit 1
    fi

    print_verbose "Arguments parsed successfully"
    print_verbose "Repository: $REPO"
    print_verbose "Workflow: $WORKFLOW"
    print_verbose "Branch: $BRANCH"
    if [[ ${#INPUTS[@]} -gt 0 ]]; then
        print_verbose "Inputs: ${INPUTS[*]}"
    else
        print_verbose "Inputs: none"
    fi
}

# Fetch workflow file content from GitHub API
fetch_workflow_content() {
    print_info "Fetching workflow file: $WORKFLOW" >&2

    local api_url="repos/$REPO/contents/.github/workflows/$WORKFLOW"
    print_verbose "API URL: $api_url" >&2

    # Fetch the file content
    local response
    if ! response=$(gh api "$api_url" 2>/dev/null); then
        print_error "Failed to fetch workflow file: $WORKFLOW"
        print_error "Please check that:"
        print_error "  - Repository '$REPO' exists and you have access"
        print_error "  - Workflow file '$WORKFLOW' exists in .github/workflows/"
        exit 1
    fi

    # Extract and decode base64 content
    local base64_content
    base64_content=$(echo "$response" | yq '.content' | tr -d '"')

    if [[ -z "$base64_content" || "$base64_content" == "null" ]]; then
        print_error "Failed to extract content from workflow file response"
        exit 1
    fi

    # Decode base64 content
    local workflow_content
    if ! workflow_content=$(echo "$base64_content" | base64 -d 2>/dev/null); then
        print_error "Failed to decode workflow file content"
        exit 1
    fi

    echo "$workflow_content"
}

# Extract workflow input fields from YAML content
extract_workflow_inputs() {
    local workflow_content="$1"
    print_info "Extracting workflow input definitions..."

    # Create temporary file for workflow content
    local temp_file=$(mktemp)
    echo "$workflow_content" > "$temp_file"

    print_verbose "Temp file: $temp_file"
    print_verbose "First 10 lines of workflow content:"
    if [[ "$VERBOSE" == true ]]; then
        head -10 "$temp_file" | sed 's/^/  /'
    fi

    # Extract input field names using yq
    local input_fields
    local yq_error
    input_fields=$(yq '.on.workflow_dispatch.inputs | keys | .[]' "$temp_file" 2>&1)
    local yq_exit_code=$?

    print_verbose "yq exit code: $yq_exit_code"
    print_verbose "yq output: '$input_fields'"

    # If yq failed, let's try to understand why
    if [[ $yq_exit_code -ne 0 ]]; then
        print_verbose "yq failed, trying with stderr:"
        yq_error=$(yq '.on.workflow_dispatch.inputs | keys | .[]' "$temp_file" 2>&1)
        print_verbose "yq error: $yq_error"
    fi

    if [[ $yq_exit_code -ne 0 || -z "$input_fields" || "$input_fields" == "null" ]]; then
        print_warning "No workflow_dispatch inputs found in workflow file"
        rm -f "$temp_file"
        return 0
    fi

    # Clean up temporary file
    rm -f "$temp_file"

    # Remove quotes from field names and convert to array
    local -a expected_inputs=()
    while IFS= read -r field; do
        field=$(echo "$field" | tr -d '"')
        expected_inputs+=("$field")
        print_verbose "Found input field: $field"
    done <<< "$input_fields"

    # Return the array (print to stdout for capture)
    printf '%s\n' "${expected_inputs[@]}"
}

# Validate provided inputs against workflow definition
validate_inputs() {
    local workflow_content="$1"

    print_info "Validating input fields..."

    # Get expected input fields
    local expected_inputs
    expected_inputs=$(extract_workflow_inputs "$workflow_content")

    if [[ -z "$expected_inputs" ]]; then
        if [[ ${#INPUTS[@]} -gt 0 ]]; then
            print_warning "Workflow has no input fields defined, but inputs were provided"
            print_warning "Provided inputs will be ignored"
        fi
        return 0
    fi

    # Convert expected inputs to array
    local -a expected_array=()
    while IFS= read -r field; do
        [[ -n "$field" ]] && expected_array+=("$field")
    done <<< "$expected_inputs"

    if [[ ${#expected_array[@]} -gt 0 ]]; then
        print_verbose "Expected inputs: ${expected_array[*]}"
    else
        print_verbose "Expected inputs: none"
    fi
    if [[ ${#INPUTS[@]} -gt 0 ]]; then
        print_verbose "Provided inputs: ${INPUTS[*]}"
    else
        print_verbose "Provided inputs: none"
    fi

    # Check for unexpected inputs
    if [[ ${#INPUTS[@]} -gt 0 ]]; then
        for provided_input in "${INPUTS[@]}"; do
            # Extract key from KEY=VALUE format
            local input_key="${provided_input%%=*}"
            local found=false
            for expected_input in "${expected_array[@]}"; do
                if [[ "$input_key" == "$expected_input" ]]; then
                    found=true
                    break
                fi
            done

            if [[ "$found" == false ]]; then
                print_error "Unexpected input field: $input_key"
                if [[ ${#expected_array[@]} -gt 0 ]]; then
                    print_error "Expected fields: ${expected_array[*]}"
                else
                    print_error "This workflow expects no input fields"
                fi
                exit 1
            fi
        done
    fi

    print_success "Input validation passed"
}

# Get the latest run ID for the workflow
get_latest_run_id() {
    print_info "Fetching latest run ID..."

    # Wait a moment for the dispatch to register
    sleep 2

    local run_id
    # Get the most recent run for this workflow
    run_id=$(gh run list --repo "$REPO" --workflow "$WORKFLOW" --limit 1 --json databaseId --jq '.[0].databaseId' 2>/dev/null)

    if [[ -z "$run_id" || "$run_id" == "null" ]]; then
        print_warning "Could not retrieve run ID. The workflow may still be starting."
        return 1
    fi

    print_verbose "Latest run ID: $run_id"
    echo "$run_id"
}

# Generate GitHub Actions run URL
generate_run_url() {
    local run_id="$1"
    echo "https://github.com/$REPO/actions/runs/$run_id"
}

# Monitor workflow execution
watch_workflow() {
    local run_id="$1"

    print_info "Monitoring workflow execution (Run ID: $run_id)..."
    print_info "Press Ctrl+C to stop monitoring (workflow will continue running)"

    local status=""
    local conclusion=""
    local start_time=$(date +%s)

    while true; do
        # Get run status
        local run_info
        run_info=$(gh run view "$run_id" --repo "$REPO" --json status,conclusion,displayTitle 2>/dev/null)

        if [[ -z "$run_info" ]]; then
            print_warning "Could not fetch run status"
            sleep 5
            continue
        fi

        status=$(echo "$run_info" | yq '.status' | tr -d '"')
        conclusion=$(echo "$run_info" | yq '.conclusion' | tr -d '"')
        local title=$(echo "$run_info" | yq '.displayTitle' | tr -d '"')

        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))
        local elapsed_min=$((elapsed / 60))
        local elapsed_sec=$((elapsed % 60))

        printf "\r${BLUE}Status:${NC} %-12s ${BLUE}Elapsed:${NC} %02d:%02d" "$status" "$elapsed_min" "$elapsed_sec"

        # Check if workflow is complete
        if [[ "$status" == "completed" ]]; then
            echo ""
            if [[ "$conclusion" == "success" ]]; then
                print_success "Workflow completed successfully!"
            elif [[ "$conclusion" == "failure" ]]; then
                print_error "Workflow failed"
            elif [[ "$conclusion" == "cancelled" ]]; then
                print_warning "Workflow was cancelled"
            else
                print_info "Workflow completed with conclusion: $conclusion"
            fi
            break
        fi

        sleep 5
    done
}

# Dispatch the workflow
dispatch_workflow() {
    print_info "Dispatching workflow..."

    # Build the gh workflow run command
    local cmd_args=("gh" "workflow" "run" "$WORKFLOW" "--repo" "$REPO" "--ref" "$BRANCH")

    # Add input fields
    if [[ ${#INPUTS[@]} -gt 0 ]]; then
        for input in "${INPUTS[@]}"; do
            cmd_args+=("--field" "$input")
            print_verbose "Adding input: $input"
        done
    fi

    print_verbose "Command: ${cmd_args[*]}"

    # Execute the command
    if "${cmd_args[@]}"; then
        print_success "Workflow dispatched successfully!"
        print_info "Repository: $REPO"
        print_info "Workflow: $WORKFLOW"
        print_info "Branch: $BRANCH"
        if [[ ${#INPUTS[@]} -gt 0 ]]; then
            print_info "Inputs:"
            for input in "${INPUTS[@]}"; do
                print_info "  $input"
            done
        fi

        # Get run ID for tracking
        local run_id
        run_id=$(get_latest_run_id)
        local get_run_id_exit_code=$?

        if [[ $get_run_id_exit_code -eq 0 && -n "$run_id" ]]; then
            print_info "Run ID: $run_id"

            # Generate and display URL
            local run_url
            run_url=$(generate_run_url "$run_id")
            print_info "Run URL: $run_url"

            # Output URL if requested
            if [[ "$GET_URL" == true ]]; then
                echo "$run_url"
            fi

            # Watch workflow if requested
            if [[ "$WATCH" == true ]]; then
                echo ""
                watch_workflow "$run_id"
            fi
        else
            print_warning "Could not retrieve run ID for tracking"
            if [[ "$WATCH" == true ]]; then
                print_error "Cannot watch workflow without run ID"
            fi
            if [[ "$GET_URL" == true ]]; then
                print_error "Cannot generate URL without run ID"
            fi
        fi
    else
        print_error "Failed to dispatch workflow"
        exit 1
    fi
}

# Main function
main() {
    print_info "GitHub Actions Workflow Dispatcher"

    # Check dependencies first
    check_dependencies

    # Parse command line arguments
    parse_arguments "$@"

    # Fetch workflow content (disable verbose during fetch to avoid contamination)
    local old_verbose="$VERBOSE"
    VERBOSE=false
    local workflow_content
    workflow_content=$(fetch_workflow_content)
    VERBOSE="$old_verbose"

    # Validate inputs against workflow definition
    validate_inputs "$workflow_content"

    # Dispatch the workflow
    dispatch_workflow

    print_success "Done!"
}

# Run main function if script is executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi