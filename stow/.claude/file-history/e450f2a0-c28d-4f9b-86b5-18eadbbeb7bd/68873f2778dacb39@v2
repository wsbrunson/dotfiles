### Lambda Handler Structure

Following the established handler pattern from `commerce-orchestrator/lambda/`:

```typescript
// POST /webhooks/order-events
exports.handler = async (event: ALBEvent): Promise<APIGatewayProxyStructuredResultV2> => {
  const debugId = getCorrelationIdFromRequest(event);
  const log = logger("MerchantWebhook", event);

  try {
    // 1. Authenticate merchant
    const merchantContext = await authenticateMerchant(event);

    // 2. Parse and validate webhook payload
    const body = typeof event.body === "string" ? JSON.parse(event.body) : event.body;
    const webhookEvent = MerchantWebhookEventSchema.parse(body);

    // 3. Track receipt
    await trackWebhookReceived({
      eventType: webhookEvent.event_type,
      merchantId: merchantContext.merchantId,
    });

    // 4. Transform to partner format
    const partnerPayload = transformToPartnerSchema(webhookEvent, merchantContext);

    // 5. Forward to LLM partner
    await notifyLLMPartner(partnerPayload);

    // 6. Track success
    await trackWebhookProcessed({ eventType: webhookEvent.event_type, status: "success" });

    return {
      statusCode: 202,
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ received: true, event_id: webhookEvent.event_id }),
    };
  } catch (error) {
    const [apiError, errorResponse] = convertErrorToLambdaResponse(error, event);
    logAPIResponseError(log, apiError);
    await trackWebhookProcessed({ status: "failed" });
    return errorResponse;
  }
};
```

