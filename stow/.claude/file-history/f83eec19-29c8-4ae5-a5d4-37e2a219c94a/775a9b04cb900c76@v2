'use strict';

var Thing = require('core-util-is');
var Passport = require('passport');
var Utils = require('./utils');

module.exports.create = function create(strategyName, args) {
    return function (options, customHandler) {
        if (!options) {
            options = {};
        }
        if (Thing.isFunction(options)) {
            customHandler = options;
            options = {};
        }

        //Disable session by default
        options.session = options.session === true ? true : false;
        options.args = args;

        return function auth(req, res, next) {
            console.log('[auth-paypal handler] auth called');
            console.log('[auth-paypal handler] req.user:', req.user);
            console.log('[auth-paypal handler] req.securityContext:', req.securityContext);

            function defaultHandler(error, user, info) {
                console.log('[auth-paypal handler] defaultHandler called');
                console.log('[auth-paypal handler] error:', error);
                console.log('[auth-paypal handler] user:', user);
                console.log('[auth-paypal handler] info:', info);
                if (error) {
                    console.log('[auth-paypal handler] returning 401 due to error');
                    error.status = 401;
                    next(error);
                    return;
                }
                if (!user) {
                    console.log('[auth-paypal handler] no user found');
                    if (options.failureRedirect) {
                        Utils.calLogEvent({failureRedirect: options.failureRedirect}, 'ERROR');
                        Utils.debug('redirecting to %s.', options.failureRedirect);

                        res.redirect(req.xhr ? 401 : 302, options.failureRedirect);
                        return;
                    } else {
                        Utils.calLogEvent({msg: 'missing_failure_redirect_option'}, 'SUCCESS');
                    }

                    Utils.debug('no failure redirect, sending unauthorized status code.');

                    console.log('[auth-paypal handler] returning 401 - no user and no failureRedirect');
                    res.writeHead(401);
                    res.end(info && info.message);
                    return;
                }

                if (options.successRedirect) {
                    Utils.calLogEvent({successRedirect: options.successRedirect}, 'SUCCESS');
                    res.redirect(options.successRedirect);
                    return;
                } else {
                    Utils.calLogEvent({msg: 'missing_success_redirect_option'}, 'SUCCESS');
                }

                res.header('cache-control', 'no-cache, private, no-store, must-revalidate, max-stale=0, post-check=0, pre-check=0');

                //If there is user and no success redirect, assume we want to render something here.
                next();
            }

            Passport.authenticate(strategyName, options, customHandler || defaultHandler).apply(Passport, arguments);
        };
    };
};
