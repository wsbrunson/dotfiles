import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { ALBEvent, Context as LambdaContext } from "aws-lambda";
import { ZodError } from "zod/v4";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { createCommerceOnboardingService } from "../../shared/commerce-onboarding";
import { parseJwtFromCartApi } from "../../shared/helpers/AppContextAuthorizer";
import {
  trackInitiatedAddCartFireAndForget,
  trackFailedAddCartFireAndForget,
} from "../../shared/metrics/emitMetric";
import { logAPIResponseError } from "../../shared/errors";
import { getCacheImplementation } from "../../shared/cache/cacheFactory";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";
import {
  sendAddCartInitiatedAlarmMetric,
  sendAddCartSuccessAlarmMetric,
  sendAddCartFailureAlarmMetric,
} from "shared/metrics/alarm-metrics";

vi.mock("../../shared/cache/cacheFactory", () => {
  const mockCache = {
    set: vi.fn().mockResolvedValue(undefined),
    get: vi.fn().mockResolvedValue(undefined),
    delete: vi.fn().mockResolvedValue(undefined),
  };

  return {
    getCacheImplementation: vi.fn(() => mockCache),
  };
});
vi.mock("../../shared/commerce-onboarding");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");
vi.mock("../../shared/errors", async () => {
  const actual = await vi.importActual("../../shared/errors");
  return {
    ...actual,
    logAPIResponseError: vi.fn(),
  };
});
vi.mock("../../shared/logger/logger", () => ({
  logger: vi.fn(() => ({
    error: vi.fn(),
    info: vi.fn(),
    warn: vi.fn(),
  })),
}));

vi.mock("shared/metrics/alarm-metrics");

const validCreateCartRequest = {
  id: "valid-cart-id",
  items: [
    {
      item_id: "product-123",
      quantity: 1,
      name: "Test Product",
      price: {
        currency_code: "USD",
        value: "100.00",
      },
    },
  ],
};

const mockCreateCartResponse = {
  id: "cart-123",
  items: [
    {
      item_id: "product-123",
      quantity: 1,
      name: "Test Product",
      price: {
        currency_code: "USD",
        value: "100.00",
      },
    },
  ],
};

describe("Generic Create Cart Lambda Handler", () => {
  let mockEvent: ALBEvent;
  let mockContext: LambdaContext;
  let mockMerchantClient: any;

  beforeEach(() => {
    // Mock the COMMERCE_ONBOARDING environment variables
    process.env.COMMERCE_ONBOARDING_API_KEY = "test-api-key";
    process.env.COMMERCE_ONBOARDING_URL =
      "https://test-commerce-onboarding.com";

    mockEvent = getMockALBEvent({
      body: JSON.stringify(validCreateCartRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    mockContext = {
      functionName: "generic-create-cart",
      invokedFunctionArn:
        "arn:aws:lambda:us-east-1:123456789012:function:generic-create-cart",
      awsRequestId: "test-request-id",
      callbackWaitsForEmptyEventLoop: true,
      functionVersion: "1",
      memoryLimitInMB: "128",
      logGroupName: "/aws/lambda/generic-create-cart",
      logStreamName: "2024/01/01/[$LATEST]test",
      getRemainingTimeInMillis: () => 3000,
      done: vi.fn(),
      fail: vi.fn(),
      succeed: vi.fn(),
    };

    mockMerchantClient = {
      createCart: vi.fn().mockResolvedValue(mockCreateCartResponse),
    };

    vi.mocked(createCommerceOnboardingService).mockReturnValue({
      setStoreContext: vi.fn(),
      createCart: mockMerchantClient.createCart,
    } as any);

    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });
    vi.mocked(trackInitiatedAddCartFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(trackFailedAddCartFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(logAPIResponseError).mockImplementation(() => {});

    vi.mocked(sendAddCartInitiatedAlarmMetric).mockResolvedValue(undefined);
    vi.mocked(sendAddCartSuccessAlarmMetric).mockResolvedValue(undefined);
    vi.mocked(sendAddCartFailureAlarmMetric).mockResolvedValue(undefined);
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  it("should create a cart successfully with shopware orchestrator", async () => {
    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(201);
    expect(response.headers?.["Content-Type"]).toBe("application/json");
    expect(JSON.parse(response.body)).toEqual(mockCreateCartResponse);

    expect(parseJwtFromCartApi).toHaveBeenCalledWith({
      event: mockEvent,
      logger: expect.any(Object),
    });

    expect(mockMerchantClient.createCart).toHaveBeenCalledWith({
      data: validCreateCartRequest,
      event: mockEvent,
    });
  });

  it("should create a cart successfully with ultracart orchestrator", async () => {
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "ultracart.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(201);
    expect(mockMerchantClient.createCart).toHaveBeenCalledWith({
      data: validCreateCartRequest,
      event: mockEvent,
    });
  });

  it("should track metrics for successful operations", async () => {
    await handler(mockEvent, mockContext);

    expect(trackInitiatedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
    });

    expect(trackFailedAddCartFireAndForget).not.toHaveBeenCalled();
  });

  it("should handle invalid JSON in request body", async () => {
    mockEvent = getMockALBEvent({
      body: '{"invalid": json}',
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "500",
    });
  });

  it("should handle Zod validation errors", async () => {
    const invalidRequest = {
      id: "valid-cart-id",
      items: [
        {
          // Missing item_id and quantity
          name: "Test Product",
        },
      ],
    };

    mockEvent = getMockALBEvent({
      body: JSON.stringify(invalidRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "400",
    });
  });

  it("should handle JWT parsing errors", async () => {
    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw new Error("Invalid JWT token");
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      status: "500",
    });
  });

  it("should handle invalid JWT payload structure", async () => {
    const zodError = new ZodError([
      {
        code: "invalid_type",
        expected: "string",
        path: ["aud"],
        message: "Required",
      } as any,
    ]);

    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw zodError;
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      status: "400",
    });
  });

  it("should handle MerchantClient errors", async () => {
    mockMerchantClient.createCart.mockRejectedValue(new Error("Network error"));

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "500",
    });
  });

  it("should log errors using logAPIResponseError", async () => {
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });
    mockMerchantClient.createCart.mockRejectedValue(new Error("Test error"));

    await handler(mockEvent, mockContext);

    expect(logAPIResponseError).toHaveBeenCalledWith(
      expect.any(Object), // logger
      expect.any(Object), // APIError
    );
  });

  it("should handle MerchantClient createCart returning a response with missing ID", async () => {
    // Return an object without an ID property
    mockMerchantClient.createCart.mockResolvedValue({
      someOtherProperty: "value",
    });

    const response = await handler(mockEvent, mockContext);

    // The handler should return a 400 Bad Request as ID is required
    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.details).toContainEqual(
      expect.objectContaining({
        description: expect.stringContaining("merchantCartId is missing"),
      }),
    );
    expect(vi.mocked(getCacheImplementation)().set).not.toHaveBeenCalled();
  });

  it("should handle empty request body", async () => {
    mockEvent = getMockALBEvent({
      body: "",
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalled();
  });

  it("should handle missing Authorization header", async () => {
    mockEvent = getMockALBEvent({
      body: JSON.stringify(validCreateCartRequest),
      headers: {},
    });

    // JWT parsing should fail without Authorization header
    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw new Error("Missing Authorization header");
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      status: "500",
    });
  });
});
