import {
  NotFoundError,
  convertErrorToLambdaResponse,
  getCorrelationIdFromRequest,
  logAPIResponseError,
} from "shared/errors";
import { ALBEvent, APIGatewayProxyStructuredResultV2 } from "aws-lambda";
import { parseJwtFromCartApi } from "shared/helpers/AppContextAuthorizer";
import { PayPalCartSchema } from "@paypal/commerce-cart-zod";
import { createCommerceOnboardingService } from "shared/commerce-onboarding";
import { logger } from "shared/logger/logger";
import {
  BaseMetricParams,
  trackInitiatedUpdateCartFireAndForget,
  trackSuccessUpdateCartFireAndForget,
  trackFailedUpdateCartFireAndForget,
} from "shared/metrics/emitMetric";
import {
  trackDatadogInitiatedUpdateCartFireAndForget,
  trackDatadogSuccessUpdateCartFireAndForget,
  trackDatadogUpdateCartErrorByStatus,
} from "shared/metrics/emitDatadogMetric";
import { extractExternalIdsFromJwt } from "shared/helpers";
import { getCacheImplementation } from "shared/cache/cacheFactory";
import { Cache } from "../../shared/cache";
import { extractCartIdFromPath } from "shared/helpers/extractCartId";
import { startSimulatorV2, stopSimulator } from "shared/simulator/server";
import { wrapHandlerWithTracing } from "shared/instrumentation";
import {
  httpRequestInit,
  httpRequestSuccess,
  httpRequestError,
  commerceOrchestratorRequestInit,
  commerceOrchestratorRequestSuccess,
  commerceOrchestratorRequestError,
} from "shared/metrics/httpMetrics";

const cache: Cache = getCacheImplementation();

// Create a mock context for httpMetrics functions that need route information
const createMockContext = (event: ALBEvent) => {
  return {
    req: {
      method: event.httpMethod || "PUT",
      path: "/commerceorchnodeserv/v1/generic/cart/:cartId",
    },
  };
};

const handler = async (
  event: ALBEvent,
): Promise<APIGatewayProxyStructuredResultV2> => {
  const overallStartTime = performance.now();
  const log = logger("Generic_Update_Cart", event);
  log.info("Received event", { event });

  // Initialize HTTP metrics
  const mockContext = createMockContext(event);
  const httpMetrics = httpRequestInit({ c: mockContext as any });
  let commerceMetrics = commerceOrchestratorRequestInit({
    c: mockContext as any,
    orchestrator: "generic",
  });

  let orchestrator = "Unknown";

  const baseMetricParams: BaseMetricParams = {
    orchestrator,
  };

  try {
    const paypalCartId = extractCartIdFromPath(event.path);

    if (!paypalCartId) {
      throw new NotFoundError(getCorrelationIdFromRequest(event), {
        details: [
          {
            description: "No cart id in path",
          },
        ],
      });
    }
    const cachedCartResponse = await cache.get(paypalCartId);

    if (!cachedCartResponse) {
      throw new NotFoundError(getCorrelationIdFromRequest(event), {
        details: [
          {
            description: `Cache: No cart response found: ${paypalCartId}`,
          },
        ],
      });
    }

    const cartResponse = JSON.parse(cachedCartResponse);
    const merchantCartId = cartResponse.id;

    if (!merchantCartId) {
      throw new NotFoundError(getCorrelationIdFromRequest(event), {
        details: [
          {
            description: `Cache: Missing Cart ID: ${paypalCartId}`,
          },
        ],
      });
    }

    const jwt = parseJwtFromCartApi({ event, logger: log });
    // TEMP: Cart api is sending ".com" at the end of "aud" field ...
    orchestrator = jwt.aud.replace(/\.com$/, "") || "unknown";
    const { encryptedMerchantId, honeyStoreId } = extractExternalIdsFromJwt(
      jwt,
      log,
    );
    baseMetricParams.orchestrator = orchestrator;
    baseMetricParams.encryptedMerchantId = encryptedMerchantId;
    baseMetricParams.honeyStoreId = honeyStoreId;

    trackInitiatedUpdateCartFireAndForget(baseMetricParams);
    trackDatadogInitiatedUpdateCartFireAndForget({
      ...baseMetricParams,
      env: process.env.APP_ENV || "unknown",
    });

    const body =
      typeof event.body === "string" ? JSON.parse(event.body) : event.body;

    log.info("Event body", { body });

    const data = PayPalCartSchema.parse(body);

    const commerceOnboardingService = createCommerceOnboardingService({
      debugId: getCorrelationIdFromRequest(event),
      cache,
    });

    commerceOnboardingService.setStoreContext({
      honeyStoreId,
      platformName: orchestrator,
      logger: log,
    });

    log.info("Commerce Onboarding Service", baseMetricParams);

    // Get store config to update commerce metrics with merchant and partner info
    try {
      const storeConfig = await commerceOnboardingService.getStoreConfig();
      commerceMetrics = {
        ...commerceMetrics,
        merchant: storeConfig.storeConfig.name,
        partner: storeConfig.platformConfig.name,
      };
    } catch (storeConfigError) {
      log.warn("Failed to get store config for metrics", { error: storeConfigError });
    }

    try {
      // Convert null values to undefined for simulator compatibility
      const simulatorData = JSON.parse(
        JSON.stringify(data, (_key, value) =>
          value === null ? undefined : value,
        ),
      );
      const platformBaseUrl =
        await commerceOnboardingService.getPlatformApiBaseUrl();
      if (platformBaseUrl) {
        await startSimulatorV2({
          type: "update",
          data: simulatorData,
          orchestrator: "generic",
          platformBaseUrl,
          headers: event.headers,
        });
      }
    } catch (e) {
      log.error("Failed to start simulator", { error: e });
    }

    const commerceServiceStartTime = performance.now();
    const updateCartResponse = await commerceOnboardingService.updateCart({
      cartId: merchantCartId,
      data,
      event,
    });
    const duration = performance.now() - commerceServiceStartTime;

    const cart = {
      ...data,
      ...updateCartResponse,
      items: data.items,
    };
    log.info("Caching cart (merged)", { response: cart });
    cache.set(paypalCartId, JSON.stringify(cart));

    log.info("Generic Merchant Update Cart Response", {
      updateCartResponse,
      honeyStoreId,
      paypalCartId,
      merchantCartId,
      timestamp: new Date().toISOString(),
      duration,
    });

    const finalDuration = performance.now() - overallStartTime;

    // Track success metric
    trackSuccessUpdateCartFireAndForget({
      ...baseMetricParams,
      status: "200",
      duration: finalDuration,
    });

    // Check cart status for Datadog metrics
    let isDatadogSuccess = false;
    if (updateCartResponse.status !== "INCOMPLETE") {
      isDatadogSuccess = true;
      log.warn("Cart status indicates success despite 200 HTTP status", {
        httpStatus: 200,
        cartStatus: updateCartResponse.status,
      });
    }

    if (isDatadogSuccess) {
      trackDatadogSuccessUpdateCartFireAndForget({
        ...baseMetricParams,
        env: process.env.APP_ENV || "unknown",
        status: "200",
        duration: finalDuration,
      });
    } else {
      trackDatadogUpdateCartErrorByStatus({
        ...baseMetricParams,
        env: process.env.APP_ENV || "unknown",
        status:
          updateCartResponse?.status &&
          updateCartResponse.status === "INCOMPLETE"
            ? "400"
            : "500",
      });
    }

    // Emit HTTP metrics for success
    httpRequestSuccess({ metrics: httpMetrics, statusCode: 200 });
    commerceOrchestratorRequestSuccess({ metrics: commerceMetrics, statusCode: 200 });

    return {
      statusCode: 200,
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(cart),
    };
  } catch (e) {
    const [apiError, errorResponse] = convertErrorToLambdaResponse(e, event);
    logAPIResponseError(log, apiError);

    // Emit HTTP metrics for error
    httpRequestError({ metrics: httpMetrics, error: e });
    commerceOrchestratorRequestError({
      metrics: commerceMetrics,
      error: e,
      statusCode: errorResponse.statusCode
    });

    trackFailedUpdateCartFireAndForget({
      ...baseMetricParams,
      status: errorResponse.statusCode.toString(),
    });

    trackDatadogUpdateCartErrorByStatus({
      ...baseMetricParams,
      env: process.env.APP_ENV || "unknown",
      status: errorResponse.statusCode.toString(),
    });

    return errorResponse;
  } finally {
    stopSimulator();
  }
};
exports.handler = wrapHandlerWithTracing(handler);
