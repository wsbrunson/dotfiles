import { createMiddleware } from "hono/factory";
import {
  httpRequestInit,
  httpRequestSuccess,
  httpRequestError,
  type HttpRequestMetrics,
} from "../metrics/httpMetrics";

export function honoMetricsMiddleware(params: {
  orchestrator: string;
  merchant?: string;
  partner?: string;
}) {
  return createMiddleware(async (c, next) => {
    const metrics = httpRequestInit({
      context: c,
      orchestrator: params.orchestrator,
      merchant: params.merchant,
      partner: params.partner,
    });
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess({ metrics, statusCode: c.res.status });
    } catch (error) {
      httpRequestError({ metrics, error });
      throw error;
    }
  });
}

export function honoMetricsMiddlewareAdvanced(params: {
  orchestrator: string;
  skipRoutes?: string[];
  enableDurationHistogram?: boolean;
  merchant?: string;
  partner?: string;
}) {
  const {
    orchestrator,
    skipRoutes = [],
    enableDurationHistogram = false,
    merchant,
    partner,
  } = params;

  return createMiddleware(async (c, next) => {
    if (skipRoutes.some((route) => c.req.path.startsWith(route))) {
      await next();
      return;
    }

    const metrics = httpRequestInit({
      context: c,
      orchestrator,
      merchant,
      partner,
    });
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess({
        metrics: c.get("requestMetrics"),
        statusCode: c.res.status
      });
    } catch (error) {
      httpRequestError({
        metrics: c.get("requestMetrics"),
        error
      });
      throw error;
    }
  });
}

declare module "hono" {
  interface ContextVariableMap {
    requestMetrics: HttpRequestMetrics;
  }
}
