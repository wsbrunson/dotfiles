vi.mock("shared/errors", async (importOriginal) => {
  const actual = (await importOriginal()) as any;
  return {
    ...actual,
    BadRequestError: class BadRequestError extends Error {
      constructor(
        public debugId: string,
        public details: any,
      ) {
        super("Bad Request");
        this.name = "BadRequestError";
      }
    },
  };
});

vi.mock("shared/handlers/createErrorHandler", () => ({
  createErrorHandler: () => (err: any, c: any) => {
    const status = err.name === "BadRequestError" ? 400 : 500;
    let message = err.message || "Internal Server Error";

    // Extract detailed message from error details if available
    if (
      err.details &&
      err.details.details &&
      Array.isArray(err.details.details)
    ) {
      const descriptions = err.details.details
        .map((d: any) => d.description)
        .filter(Boolean);
      if (descriptions.length > 0) {
        message = descriptions.join(", ");
      }
    }

    return c.json(
      {
        message,
        debugId: err.debugId || "test-debug-id",
      },
      status,
    );
  },
}));

// Helper function to create ALB event
function createALBEvent(overrides: Partial<ALBEvent> = {}): ALBEvent {
  return {
    requestContext: {
      elb: {
        targetGroupArn:
          "arn:aws:elasticloadbalancing:us-east-1:123456789012:targetgroup/test/1234567890123456",
      },
    },
    httpMethod: "POST",
    path: "/commerceorchnodeserv/v1/pcp/cart",
    queryStringParameters: null,
    headers: {
      "content-type": "application/json",
      authorization: "Bearer test-token",
    },
    multiValueHeaders: {},
    body: "{}",
    isBase64Encoded: false,
    multiValueQueryStringParameters: null,
    ...overrides,
  } as ALBEvent;
}

describe("pcp App", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe("POST /commerceorchnodeserv/v1/pcp/cart", () => {
    it("should create a cart successfully", async () => {
      const cartData = {
        id: "paypal-cart-123",
        items: [
          {
            item_id: "item-1",
            quantity: 1,
          },
        ],
      };

      const merchantCartResponse = {
        id: "merchant-cart-456",
        total: 100,
      };

      mockCreateCart.mockResolvedValue(merchantCartResponse);

      const event = createALBEvent({
        httpMethod: "POST",
        path: "/commerceorchnodeserv/v1/pcp/cart",
        body: JSON.stringify(cartData),
      });

      const res = await app.fetch(
        new Request("http://localhost/commerceorchnodeserv/v1/pcp/cart", {
          method: "POST",
          headers: {
            "content-type": "application/json",
            authorization: "Bearer test-token",
          },
          body: JSON.stringify(cartData),
        }),
        { event },
      );

      expect(res.status).toBe(201);
      expect(res.headers.get("content-type")).toBe("application/json");

      const responseBody = await res.json();
      expect(responseBody).toEqual(merchantCartResponse);

      // Verify commerce onboarding service was called correctly
      expect(mockSetStoreContext).toHaveBeenCalledWith({
        honeyStoreId: "honey-store-123",
        platformName: "ultracart",
        logger: expect.any(Object),
      });

      expect(mockCreateCart).toHaveBeenCalledWith({
        data: cartData,
        event: expect.any(Object),
      });

      // Verify cache was set
      expect((vi as any).mockCache.set).toHaveBeenCalledWith(
        "paypal-cart-123",
        "merchant-cart-456",
      );
    });

    it("should throw error when paypal cart id is missing", async () => {
      const cartData = {
        items: [
          {
            item_id: "item-1",
            quantity: 1,
          },
        ],
      };

      const merchantCartResponse = {
        id: "merchant-cart-456",
        total: 100,
      };

      mockCreateCart.mockResolvedValue(merchantCartResponse);

      const event = createALBEvent({
        httpMethod: "POST",
        path: "/commerceorchnodeserv/v1/pcp/cart",
        body: JSON.stringify(cartData),
      });

      const res = await app.fetch(
        new Request("http://localhost/commerceorchnodeserv/v1/pcp/cart", {
          method: "POST",
          headers: {
            "content-type": "application/json",
            authorization: "Bearer test-token",
          },
          body: JSON.stringify(cartData),
        }),
        { event },
      );

      expect(res.status).toBe(400);
      // Using shared mockCacheImpl directly
      expect((vi as any).mockCache.set).not.toHaveBeenCalled();
    });

    it("should throw error when merchant cart id is missing", async () => {
      const cartData = {
        id: "paypal-cart-123",
        items: [
          {
            item_id: "item-1",
            quantity: 1,
          },
        ],
      };

      const merchantCartResponse = {
        // id is missing
