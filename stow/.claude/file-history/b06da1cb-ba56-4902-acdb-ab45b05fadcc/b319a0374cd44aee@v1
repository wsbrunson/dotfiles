// updateCartMetrics.test.ts
import { describe, it, expect, vi, beforeEach } from 'vitest';
import type { Context, Next } from 'hono';
import type { ALBEvent } from 'aws-lambda';

// Shared logger mock instance (same object every time)
const logMock = {
  info: vi.fn(),
  error: vi.fn(),
};

// Module mocks
vi.mock('../logger/logger', () => ({
  logger: vi.fn(() => logMock),
}));

vi.mock('shared/metrics/emitMetric', () => ({
  trackInitiatedUpdateCart: vi.fn(),
  trackSuccessUpdateCart: vi.fn(),
}));

vi.mock('shared/metrics/alarm-metrics', () => ({
  sendUpdateCartInitiatedAlarmMetric: vi.fn(),
  sendUpdateCartSuccessAlarmMetric: vi.fn(),
}));

// Import AFTER mocks// <-- make sure the path matches your file name
import {
  trackInitiatedUpdateCart,
  trackSuccessUpdateCart,
} from 'shared/metrics/emitMetric';
import {
  sendUpdateCartInitiatedAlarmMetric,
  sendUpdateCartSuccessAlarmMetric,
} from 'shared/metrics/alarm-metrics';
import { updateCartMetrics } from './updateCartMetric';

describe('updateCartMetrics', () => {
  let mockContext: Context;
  let mockEvent: ALBEvent;

  beforeEach(() => {
    vi.clearAllMocks();

    mockEvent = {
      requestContext: { requestId: 'mockRequestId' },
    } as unknown as ALBEvent;

    // Minimal Context stub
    mockContext = {
      env: { event: mockEvent },
      get: vi.fn((key: string) => {
        if (key === 'debugId') return 'mockDebugId';
        if (key === 'overallStartTime') return 1000;
        if (key === 'data') return { merchantUrl: 'https://mock-merchant.com' };
        if (key === 'storeMetaData') return {}; // Add empty storeMetaData
        return undefined;
      }),
      // res will be assigned by `next` (like real Hono handlers do)
      res: undefined as unknown as Response,
    } as unknown as Context;
  });

  it('logs initiation, emits initiated metrics, and calls next()', async () => {
    const orchestrator = 'mockOrchestrator';

    // next() that does nothing (so status falls back to 500 later)
    const next: Next = vi.fn(async () => { /* no-op */ });

    const mw = updateCartMetrics({ orchestrator });
    await mw(mockContext, next);

    // Initiation alarm + metric
    expect(sendUpdateCartInitiatedAlarmMetric).toHaveBeenCalledWith({ orchestrator });
    expect(trackInitiatedUpdateCart).toHaveBeenCalledWith({
      orchestrator,
      merchantUrl: 'https://mock-merchant.com',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
    });

    // Initiation log
    expect(logMock.info).toHaveBeenCalledWith(
      'UpdateCartInitiated',
      expect.objectContaining({
        level: 'info',
        timestamp: 1000,
        event: 'UpdateCartInitiated',
        message: 'UpdateCartInitiated',
        debugId: 'mockDebugId',
        orchestrator,
        merchantUrl: 'https://mock-merchant.com',
        encryptedMerchantId: undefined,
        honeyStoreId: undefined,
      }),
    );

    expect(next).toHaveBeenCalled();
  });

  it('tracks success metrics when downstream sets a 2xx response', async () => {
    const orchestrator = 'mockOrchestrator';

    // Make downstream handler set a 200 Response
    const next: Next = vi.fn(async () => {
      mockContext.res = new Response('ok', { status: 200 });
    });

    const mw = updateCartMetrics({ orchestrator });
    await mw(mockContext, next);

    expect(trackSuccessUpdateCart).toHaveBeenCalledWith({
      orchestrator,
      merchantUrl: 'https://mock-merchant.com',
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: '200',
      duration: expect.any(Number),
    });
    expect(sendUpdateCartSuccessAlarmMetric).toHaveBeenCalledWith({ orchestrator });

    expect(logMock.info).toHaveBeenCalledWith(
      'UpdateCartSuccess',
      expect.objectContaining({
        level: 'info',
        message: 'UpdateCartSuccess',
        timestamp: 1000,
        event: 'UpdateCartSuccess',
        orchestrator,
        merchantUrl: 'https://mock-merchant.com',
        encryptedMerchantId: undefined,
        honeyStoreId: undefined,
        status: '200',
        debugId: 'mockDebugId',
        duration: expect.any(Number), // performance.now() - overallStartTime
      }),
    );
  });

  it('does NOT track success metrics when status is non-2xx', async () => {
    const orchestrator = 'mockOrchestrator';

    // Downstream sets a 500 Response
    const next: Next = vi.fn(async () => {
      mockContext.res = new Response('err', { status: 500 });
    });

    const mw = updateCartMetrics({ orchestrator });
    await mw(mockContext, next);

    expect(trackSuccessUpdateCart).not.toHaveBeenCalled();
    expect(sendUpdateCartSuccessAlarmMetric).not.toHaveBeenCalled();

    // Confirms the status log after next()
    expect(logMock.info).toHaveBeenCalledWith('c.res.status', { status: 500 });
  });
});
