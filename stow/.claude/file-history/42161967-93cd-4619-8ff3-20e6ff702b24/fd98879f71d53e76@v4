describe('startSimulator', () => {

  beforeEach(() => {
    vi.clearAllMocks();
    h.lastInstance.value = null;
    // Set APP_ENV to 'test' to enable simulation
    process.env.APP_ENV = 'test';
    // Default to successful validation
    h.isValidForShopifyCreateCartMock.mockReturnValue({ isValid: true });
    h.isValidForShopifyUpdateCartMock.mockReturnValue({ isValid: true });
    // Default getErrorIdFromEmail to return null (no valid simulation pattern)
    h.getErrorIdFromEmailMock.mockReturnValue(null);
  });

  afterEach(() => {
    // Clean up environment variable
    delete process.env.APP_ENV;
  });

  it('uses onUnhandledRequest="error" in replay mode', async () => {

    await startSimulator({ type: 'create', data: validCreateCartRequest, merchantUrl: 'https://example.com', orchestrator: 'shopify' }, 'replay');

    expect(h.listenMock).toHaveBeenCalledWith({ onUnhandledRequest: 'error' });
    // Check that info log contains the correct mode, but don't require exact match
    // since the log message now includes context type and lambda information
    expect(h.infoSpy).toHaveBeenCalledWith(
      expect.stringContaining('Simulator started in replay mode')
    );

    // server.ts calls shopifyHandlers(...) with the entire context object
    expect(h.shopifyHandlersMock).toHaveBeenCalledWith({
      type: 'create',
      data: validCreateCartRequest,
      merchantUrl: 'https://example.com',
      orchestrator: 'shopify'
    });
  });

  it('uses onUnhandledRequest="bypass" in bypass mode', async () => {
    await startSimulator({ type: 'complete', data: validCompelteCartRequest, merchantUrl: 'https://example.com', orchestrator: 'shopify' }, 'bypass');

    expect(h.listenMock).toHaveBeenCalledWith({ onUnhandledRequest: 'bypass' });
    // Check that info log contains the correct mode, but don't require exact match
    // since the log message now includes context type information
    expect(h.infoSpy).toHaveBeenCalledWith(
      expect.stringContaining('Simulator started in bypass mode')
    );

    // Update the assertion to match the expected arguments
    expect(h.shopifyCompleteHandlersMock).toHaveBeenCalledWith({
      type: 'complete',
      data: validCompelteCartRequest,
      merchantUrl: 'https://example.com',
      orchestrator: 'shopify'
    });
  });

  it('stops and restarts the server if already running', async () => {
    await startSimulator({ type: 'create', data: validCreateCartRequest, merchantUrl: 'https://example.com', orchestrator: 'shopify' }, 'bypass');
    expect(h.listenMock).toHaveBeenCalledTimes(1);

    await startSimulator({ type: 'update', data: validUpdateCartRequest, merchantUrl: 'https://example.com', ecToken: 'test-ec-token', orchestrator: 'shopify' }, 'bypass');
    expect(h.closeMock).toHaveBeenCalled();
    expect(h.listenMock).toHaveBeenCalledTimes(2);
  });

  it('wires event listeners that log request lifecycle events', async () => {
    await startSimulator({ type: 'create', data: validCreateCartRequest, merchantUrl: 'https://example.com', orchestrator: 'shopify' }, 'bypass');
    const inst = h.lastInstance.value;
    const fakeReq = { url: new URL('https://example.test'), method: 'GET', headers: new Map() };

    inst.events.emit('request:start', fakeReq);
    inst.events.emit('request:match', fakeReq);
    inst.events.emit('request:unhandled', fakeReq);
  });

  it('validates email patterns for shopify-create-cart lambda', async () => {
    // Prepare mock data
    const createRequestWithInvalidEmail = {
      ...validCreateCartRequest,
      customer: {
        ...validCreateCartRequest.customer,
        email: 'invalid-pattern@example.com'
      }
    };

    // Ensure getErrorIdFromEmail returns null (not a valid simulation pattern)
    h.getErrorIdFromEmailMock.mockReturnValue(null);

    // Mock isValidForShopifyCreateCart to return invalid
    h.isValidForShopifyCreateCartMock.mockReturnValue({
      isValid: false,
      pattern: {
        pattern: 'invalid-pattern',
        id: 'INVALID_SCENARIO',
        description: 'This is an invalid pattern'
      },
      message: 'Invalid simulation scenario for testing'
    });

    // Expect the startSimulator to throw a BadRequestError with specific message
    await expect(startSimulator({
      type: 'create',
      data: createRequestWithInvalidEmail,
      merchantUrl: 'https://example.com', 
      orchestrator: 'shopify'
    }, 'bypass'))
      .rejects.toThrow(BadRequestError);

    // Expect the error message to contain our validation message
    try {
      await startSimulator({
        type: 'create',
        data: createRequestWithInvalidEmail,
        merchantUrl: 'https://example.com',
        orchestrator: 'shopify'
      }, 'bypass');
    } catch (error) {
      expect(error instanceof BadRequestError).toBe(true);
      expect((error as BadRequestError).message).toContain('Invalid simulation scenario for shopify-create-cart');
      expect((error as BadRequestError).status).toBe(400); // Ensure it's a 400 Bad Request
    }

    // Verify both validation functions were called with the email
    expect(h.getErrorIdFromEmailMock).toHaveBeenCalledWith('invalid-pattern@example.com');
    expect(h.isValidForShopifyCreateCartMock).toHaveBeenCalledWith('invalid-pattern@example.com');

    // Verify the server was not started
    expect(h.listenMock).not.toHaveBeenCalled();
  });

  it('allows valid email patterns for shopify-create-cart lambda', async () => {
    // Prepare mock data with a valid email pattern
    const createRequestWithValidEmail = {
      ...validCreateCartRequest,
      customer: {
        ...validCreateCartRequest.customer,
        email: 'valid-pattern@example.com'
      }
    };

    // Mock isValidForShopifyCreateCart to return valid
    h.isValidForShopifyCreateCartMock.mockReturnValue({
      isValid: true,
      errorId: 'SOME_ERROR_TYPE' // This won't trigger an error, just used for validation
    });

    // Should not throw an error
    await startSimulator({
      type: 'create',
      data: createRequestWithValidEmail,
      merchantUrl: 'https://example.com', 
      orchestrator: 'shopify'
    }, 'bypass');

    // Verify the validation functions were called with the email
    expect(h.getErrorIdFromEmailMock).toHaveBeenCalledWith('valid-pattern@example.com');
    expect(h.isValidForShopifyCreateCartMock).toHaveBeenCalledWith('valid-pattern@example.com');

    // Verify the server was started
    expect(h.listenMock).toHaveBeenCalled();
  });

  it('allows GET_PROPOSAL error patterns for shopify-create-cart lambda', async () => {
    // Prepare mock data with a GET_PROPOSAL error pattern
    const createRequestWithGetProposalError = {
      ...validCreateCartRequest,
      customer: {
        ...validCreateCartRequest.customer,
        email: 'out-of-stock@example.com'
      }
    };

    // Mock getErrorIdFromEmail to return a valid error ID (bypassing flow validation)
    h.getErrorIdFromEmailMock.mockReturnValue('MERCHANDISE_OUT_OF_STOCK');

    // Should not throw an error
    await startSimulator({
      type: 'create',
      data: createRequestWithGetProposalError,
      merchantUrl: 'https://example.com',
      orchestrator: 'shopify'
    }, 'bypass');

    // Verify the getErrorIdFromEmail function was called with the email
    expect(h.getErrorIdFromEmailMock).toHaveBeenCalledWith('out-of-stock@example.com');

    // Verify validateForShopifyCreateCart wasn't called since we already found a valid pattern
    expect(h.isValidForShopifyCreateCartMock).not.toHaveBeenCalled();

    // Verify the server was started
    expect(h.listenMock).toHaveBeenCalled();
  });

  describe('simulation bypass logic', () => {
    test.each(sharedBypassTestCases)(
      '$description',
      async ({ appEnv, simulationHeader, email, expectedShouldBypass, expectedLogDetails }) => {
        // Setup environment
        process.env.APP_ENV = appEnv;

        // Create V1 context for startSimulator (uses .email not .email_address)
        const contextWithTestEmail = {
          type: 'create' as const,
          data: {
            ...validCreateCartRequest,
            customer: {
              ...validCreateCartRequest.customer,
              email: email, // V1 context uses email
            },
          },
          merchantUrl: 'https://example.com',
          orchestrator: 'shopify' as const,
          ...(simulationHeader && {
            headers: {
              'PayPal-Commerce-Simulation': simulationHeader,
            },
          }),
        };

        await startSimulator(contextWithTestEmail, 'bypass');

        if (expectedShouldBypass) {
          // Verify the server was not started
          expect(h.listenMock).not.toHaveBeenCalled();

          // Verify the correct log message
          expect(h.infoSpy).toHaveBeenCalledWith(
            'Simulator bypassed - conditions not met',
            expectedLogDetails
          );
        } else {
          // Verify the server was started
          expect(h.listenMock).toHaveBeenCalled();

          // Verify no bypass log message
          expect(h.infoSpy).not.toHaveBeenCalledWith(
            'Simulator bypassed - conditions not met',
            expect.any(Object)
          );
        }
      }
    );
  });
});

describe('stopSimulator', () => {
  beforeEach(() => {
    vi.clearAllMocks();
    // Set APP_ENV to 'test' to enable simulation
    process.env.APP_ENV = 'test';
  });

  afterEach(() => {
    // Clean up environment variable
    delete process.env.APP_ENV;
  });

  it('stops the server if running', async () => {
    // Ensure server is running
    await startSimulator({ type: 'update', data: validUpdateCartRequest, merchantUrl: 'https://example.com', ecToken: 'test-ec-token', orchestrator: "shopify" }, 'bypass');
    vi.clearAllMocks(); // ignore logs from start

    stopSimulator();

    expect(h.closeMock).toHaveBeenCalledTimes(1);
    expect(h.infoSpy).toHaveBeenCalledWith('Simulator stopped.');
  });

  it('does nothing if the server is not running', () => {
    // Immediately stopping without a start
    stopSimulator();
    // close should not be called
    expect(h.closeMock).not.toHaveBeenCalled();
  });
});

