import { createMiddleware } from "hono/factory";
import {
  httpRequestInit,
  httpRequestSuccess,
  httpRequestError,
  type HttpRequestMetrics,
} from "../metrics/httpMetrics";

export function honoMetricsMiddleware(
  orchestrator: string,
  options?: {
    merchant?: string;
    partner?: string;
  },
) {
  return createMiddleware(async (c, next) => {
    const metrics = httpRequestInit(c, orchestrator, options);
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess(metrics, c.res.status, options);
    } catch (error) {
      httpRequestError(metrics, error, options);
      throw error;
    }
  });
}

export function honoMetricsMiddlewareAdvanced(
  orchestrator: string,
  options?: {
    skipRoutes?: string[];
    enableDurationHistogram?: boolean;
    merchant?: string;
    partner?: string;
  },
) {
  const {
    skipRoutes = [],
    enableDurationHistogram = false,
    merchant,
    partner,
  } = options || {};

  return createMiddleware(async (c, next) => {
    if (skipRoutes.some((route) => c.req.path.startsWith(route))) {
      await next();
      return;
    }

    const metrics = httpRequestInit(c, orchestrator, {
      merchant,
      partner,
    });
    c.set("requestMetrics", metrics);

    try {
      await next();
      httpRequestSuccess(c.get("requestMetrics"), c.res.status, {
        merchant,
        partner,
      });
    } catch (error) {
      httpRequestError(c.get("requestMetrics"), error, {
        merchant,
        partner,
      });
      throw error;
    }
  });
}

declare module "hono" {
  interface ContextVariableMap {
    requestMetrics: HttpRequestMetrics;
  }
}
