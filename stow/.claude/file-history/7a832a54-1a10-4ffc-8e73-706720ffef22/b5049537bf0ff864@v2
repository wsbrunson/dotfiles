{
  "family": "<SERVICE_NAME>-task",
  "taskRoleArn": "<SERVICE_NAME>-service-task-role",
  "executionRoleArn": "<SERVICE_NAME>-service-task-role",
  "cpu": "<SERVICE_CPU>",
  "memory": "<SERVICE_MEMORY>",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "containerDefinitions": [
    {
      "name": "<SERVICE_CONTAINER_NAME>",
      "image": "396765463261.dkr.ecr.us-west-2.amazonaws.com/commerce-onboarding:<IMAGE_TAG>",
      "cpu": 0,
      "memory": 8192,
      "memoryReservation": 4096,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        },
        {
          "containerPort": 8443,
          "hostPort": 8443,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "entryPoint": [
        "node",
        "--require",
        "./ecs/commerceonboardingserv/dd-trace-init.js",
        "dist/index.js"
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "LAUNCH_TYPE",
          "value": "fargate"
        },
        {
          "name": "ENVIRONMENT",
          "value": "<DEPLOYMENT_ENV>"
        },
        {
          "name": "CONTAINER_NAME",
          "value": "<SERVICE_CONTAINER_NAME>"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "NODE_ENV",
          "value": "<DEPLOYMENT_ENV>"
        },
        {
          "name": "HTTPS_PORT",
          "value": "8443"
        },
        {
          "name": "AWS_REGION",
          "value": "us-west-2"
        },
        {
          "name": "DYNAMODB_TABLE_NAME",
          "value": "commerce-onboarding-merchant-configs-<DEPLOYMENT_ENV>"
        },
        {
          "name": "DYNAMODB_CONFIGS_TABLE_NAME",
          "value": "commerce-onboarding-configs"
        },
        {
          "name": "DD_SERVICE",
          "value": "commerce-onboarding"
        },
        {
          "name": "DD_ENV",
          "value": "<DEPLOYMENT_ENV>"
        },
        {
          "name": "DD_LOGS_INJECTION",
          "value": "true"
        },
        {
          "name": "DD_TRACE_ENABLED",
          "value": "true"
        },
        {
          "name": "DD_RUNTIME_METRICS_ENABLED",
          "value": "true"
        },
        {
          "name": "DD_TRACE_HTTP_URL_QUERY_STRING_DISABLED",
          "value": "true"
        },
        {
          "name": "DD_TRACE_AGENT_URL",
          "value": "http://localhost:8126"
        },
        {
          "name": "DD_PROFILING_ENABLED",
          "value": "true"
        },
        {
          "name": "DD_TRACE_PROPAGATION_STYLE_INJECT",
          "value": "tracecontext,datadog"
        },
        {
          "name": "DD_TRACE_PROPAGATION_STYLE_EXTRACT",
          "value": "tracecontext,datadog"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "HONEY_API_TOKEN",
          "valueFrom": "/commerce-onboarding/honey-api-token"
        },
        {
          "name": "COMMERCE_ONBOARDING_API_KEY",
          "valueFrom": "/commerce-onboarding/api-key"
        },
        {
          "name": "VERIFICATION_PEM",
          "valueFrom": "/commerce-onboarding/appcontext_verification_pem"
        },
        {
          "name": "SANDBOX_VERIFICATION_PEM",
          "valueFrom": "/commerce-onboarding/appcontext_verification_pem_sandbox"
        }
      ],
      "disableNetworking": false,
      "privileged": false,
      "readonlyRootFilesystem": false,
      "logConfiguration": {
        "logDriver": "splunk",
        "options": {
          "mode": "non-blocking",
          "splunk-verify-connection": "false",
          "splunk-sourcetype": "log4j",
          "max-buffer-size": "25m",
          "splunk-index": "commerce-onboarding",
          "splunk-source": "http:commerce-onboarding-<DEPLOYMENT_ENV>",
          "tag": "",
          "splunk-insecureskipverify": "True",
          "splunk-format": "raw"
        },
        "secretOptions": [
          {
            "name": "splunk-url",
            "valueFrom": "/commerce-onboarding/splunk-url"
          },
          {
            "name": "splunk-token",
            "valueFrom": "/commerce-onboarding/splunk-token"
          }
        ]
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --spider http://127.0.0.1:8080/system/ping || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 300
      },
      "systemControls": []
    }
  ]
}