import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { ALBEvent } from "aws-lambda";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { FirmlyClient } from "../../shared/firmly/firmly-client";

import { verifyAppContext } from "../../shared/helpers/AppContextAuthorizer";
import { getCacheImplementation } from "../../shared/cache/cacheFactory";
import {
  trackInitiatedAddCart,
  trackSuccessAddCart,
  trackFailedAddCart,
} from "../../shared/metrics/emitMetric";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";

vi.mock("../../shared/firmly/firmly-client");
vi.mock("../../shared/cache/cacheFactory");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");

const validCreateCartRequest = {
  id: "firmly-cart-1",
  items: [
    {
      item_id: "item-1",
      item_url: "https://merchant.com/item-1",
      quantity: 2,
    },
  ],
  shipping_address: {
    address_line_1: "123 Main St",
    address_line_2: "Apt 4B",
    admin_area_2: "Los Angeles",
    admin_area_1: "CA",
    postal_code: "90001",
    country_code: "US",
  },
  customer: {
    name: { given_name: "Alice", surname: "Smith" },
    phone: { country_code: "1", national_number: "5551234567" },
    email_address: "alice@example.com",
  },
};

describe("Firmly Create Cart Lambda Handler", () => {
  let mockEvent: ALBEvent;
  let mockFirmlyClient: any;
  let mockCache: any;

  beforeEach(() => {
    mockEvent = getMockALBEvent({
      body: JSON.stringify(validCreateCartRequest),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    vi.mocked(verifyAppContext).mockReturnValue(true);

    vi.mocked(trackInitiatedAddCart).mockResolvedValue(undefined);
    vi.mocked(trackSuccessAddCart).mockResolvedValue(undefined);
    vi.mocked(trackFailedAddCart).mockResolvedValue(undefined);

    // Mock FirmlyClient
    mockFirmlyClient = {
      addItem: vi.fn().mockResolvedValue(undefined),
      setShippingInfo: vi.fn().mockResolvedValue(undefined),
      startCheckout: vi.fn().mockResolvedValue({
        cart_status: "active",
        shipping_total: { currency: "USD", value: 5.0 },
        tax: { currency: "USD", value: 1.0 },
        sub_total: { currency: "USD", value: 10.0 },
        total: { currency: "USD", value: 16.0 },
        payment_method: {
          attributes: { paypal_token: "paypal-token" },
        },
      }),
    };

    vi.mocked(FirmlyClient).create = vi
      .fn()
      .mockResolvedValue(mockFirmlyClient);

    // Mock cache
    mockCache = {
      set: vi.fn().mockResolvedValue(undefined),
      get: vi.fn().mockResolvedValue(
        JSON.stringify({
          client: mockFirmlyClient,
          response: {
            id: "firmly-cart-1",
            status: "CREATED",
          },
        })
      ),
    };
    vi.mocked(getCacheImplementation).mockReturnValue(mockCache);
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  it("should create a cart successfully", async () => {
    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(200);
    const body = JSON.parse(response.body);
    expect(body).toMatchObject({
      id: "firmly-cart-1",
      status: "CREATED",
      items: expect.any(Array),
      payment_method: expect.objectContaining({
        type: "paypal",
        token: "paypal-token",
      }),
      totals: expect.objectContaining({
        shipping: expect.any(Object),
        tax: expect.any(Object),
        subtotal: expect.any(Object),
        total: expect.any(Object),
      }),
    });

    // Verify FirmlyClient was created and methods were called
    expect(FirmlyClient.create).toHaveBeenCalledWith("merchant.com", "");
    expect(mockFirmlyClient.addItem).toHaveBeenCalledWith("item-1", "2");
    expect(mockFirmlyClient.setShippingInfo).toHaveBeenCalledWith(
      expect.objectContaining({
        first_name: "Alice",
        last_name: "Smith",
        address1: "123 Main St",
        address2: "Apt 4B",
        city: "Los Angeles",
        state_or_province: "CA",
        postal_code: "90001",
        country: "US",
        phone: "5551234567",
        email: "alice@example.com",
      })
    );
    expect(mockFirmlyClient.startCheckout).toHaveBeenCalled();

    // Verify cache was used
    expect(mockCache.set).toHaveBeenCalledWith(
      "firmly-cart-1",
      expect.any(String)
    );
    expect(mockCache.get).toHaveBeenCalledWith("firmly-cart-1");
  });

  it("should throw UnauthorizedError when app context verification fails", async () => {
    vi.mocked(verifyAppContext).mockReturnValue(false);

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(401);
    expect(JSON.parse(response.body)).toMatchObject({
      message: expect.stringContaining("Unauthorized"),
    });

    // Verify FirmlyClient was not created
    expect(FirmlyClient.create).not.toHaveBeenCalled();
  });

  it("should handle invalid request schema", async () => {
    const invalidRequest = {
      id: "valid-cart",
      // Missing required fields
    };

    mockEvent = getMockALBEvent({
      body: JSON.stringify(invalidRequest),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.name).toBe("BadRequestError");
    expect(responseBody.details).toEqual(
      expect.arrayContaining([
        expect.objectContaining({
          description: expect.stringContaining("required"),
        }),
      ])
    );
  });

  it("should handle errors during cart creation", async () => {
    mockFirmlyClient.startCheckout = vi
      .fn()
      .mockRejectedValue(new Error("Network error"));

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(500);
    expect(JSON.parse(response.body)).toMatchObject({
      name: "UnknownError",
    });
  });

  it("should track metrics for successful operations", async () => {
    await handler(mockEvent);

    expect(trackInitiatedAddCart).toHaveBeenCalledWith({
      orchestrator: "Firmly",
      merchantUrl: "merchant.com",
    });

    expect(trackSuccessAddCart).toHaveBeenCalledWith({
      orchestrator: "Firmly",
      merchantUrl: "merchant.com",
      status: "201",
      duration: expect.any(Number),
    });
  });

  it("should track metrics for failed operations", async () => {
    mockFirmlyClient.startCheckout = vi
      .fn()
      .mockRejectedValue(new Error("Network error"));

    await handler(mockEvent);

    expect(trackInitiatedAddCart).toHaveBeenCalledWith({
      orchestrator: "Firmly",
      merchantUrl: "merchant.com",
    });

    expect(trackFailedAddCart).toHaveBeenCalledWith({
      orchestrator: "Firmly",
      merchantUrl: "merchant.com",
      status: "500",
    });
  });

  it("should handle malformed JSON in request body", async () => {
    mockEvent = getMockALBEvent({
      body: '{"id": "test", "malformed": }',
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(500);
    expect(JSON.parse(response.body)).toMatchObject({
      name: "UnknownError",
    });
  });

  it("should extract merchant URL from item URL", async () => {
    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(200);
    expect(trackInitiatedAddCart).toHaveBeenCalledWith(
      expect.objectContaining({
        merchantUrl: "merchant.com",
      })
    );
  });

  it("should handle items without item_url gracefully", async () => {
    const requestWithoutItemUrl = {
      ...validCreateCartRequest,
      items: [
        {
          item_id: "item-1",
          quantity: 2,
          // No item_url
        },
      ],
    };

    mockEvent = getMockALBEvent({
      body: JSON.stringify(requestWithoutItemUrl),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    await handler(mockEvent);

    // Should still process but with empty merchantUrl
    expect(trackInitiatedAddCart).toHaveBeenCalledWith(
      expect.objectContaining({
        merchantUrl: "",
      })
    );
  });

  it("should handle missing required fields in request", async () => {
    const requestWithoutCustomer = {
      ...validCreateCartRequest,
      customer: undefined,
    };

    mockEvent = getMockALBEvent({
      body: JSON.stringify(requestWithoutCustomer),
      headers: {
        "paypal-application-context": "valid-token",
      },
    });

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.name).toBe("BadRequestError");
  });

  it("should properly format the response body", async () => {
    const response = await handler(mockEvent);

    expect(response).toMatchObject({
      statusCode: 200,
      headers: { "Content-Type": "application/json" },
      body: expect.any(String),
    });

    // Verify body is valid JSON
    const body = JSON.parse(response.body);
    expect(body).toBeDefined();
  });

  it("should handle FirmlyClient creation errors", async () => {
    // Mock the FirmlyClient.create to throw
    vi.mocked(FirmlyClient).create = vi
      .fn()
      .mockRejectedValue(new Error("Failed to create Firmly client"));

    const response = await handler(mockEvent);

    expect(response.statusCode).toBe(500);
    expect(JSON.parse(response.body)).toMatchObject({
      name: "UnknownError",
    });
  });

  it("should call FirmlyClient methods in correct order", async () => {
    await handler(mockEvent);

    // Check that client was created first
    expect(FirmlyClient.create).toHaveBeenCalled();

    // Then items were added
    expect(mockFirmlyClient.addItem).toHaveBeenCalled();

    // Then shipping info was set
    expect(mockFirmlyClient.setShippingInfo).toHaveBeenCalled();

    // Finally checkout was started
    expect(mockFirmlyClient.startCheckout).toHaveBeenCalled();
  });
});
