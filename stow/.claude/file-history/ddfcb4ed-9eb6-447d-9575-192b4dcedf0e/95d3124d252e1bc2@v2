// at top of the test file
import { describe, it, expect, vi, beforeEach } from 'vitest';
import { Context } from 'hono';
import { ALBEvent } from 'aws-lambda';
import { ShopifyUnknownError } from '../shopify/shopify-client';

// 1) Shared logger mock instance
const logMock = {
    info: vi.fn(),
    error: vi.fn(),
};

// 2) Module mocks
vi.mock('../logger/logger', () => ({
    logger: vi.fn(() => logMock), // always the SAME instance
}));

vi.mock('shared/metrics/emitMetric', () => ({
    trackFailedUpdateCart: vi.fn(),
}));

vi.mock('shared/metrics/alarm-metrics', () => ({
    sendShopifyAPIErrorAlarmMetric: vi.fn(),
    sendUpdateCartFailureAlarmMetric: vi.fn(),
}));

// Import AFTER mocks
import { updateCartFailureMetrics } from './updateCartFailureMetrics';
import { trackFailedUpdateCart } from 'shared/metrics/emitMetric';
import {
    sendShopifyAPIErrorAlarmMetric,
    sendUpdateCartFailureAlarmMetric,
} from 'shared/metrics/alarm-metrics';

describe('updateCartFailureMetrics', () => {
    let mockContext: Context;
    let mockEvent: ALBEvent;

    beforeEach(() => {
        vi.clearAllMocks();

        mockEvent = {
            requestContext: { requestId: 'mockRequestId' },
        } as unknown as ALBEvent;

        mockContext = {
            env: { event: mockEvent },
            get: vi.fn((key) => {
                if (key === 'debugId') return 'mockDebugId';
                if (key === 'overallStartTime') return 1000;
                if (key === 'data') return { merchantUrl: 'https://mock-merchant.com' };
                return undefined;
            }),
        } as unknown as Context;
    });

    it('should log the error, track metrics, and return the error response', async () => {
        const orchestrator = 'mockOrchestrator';
        const err = new Error('Mock error');

        const middleware = updateCartFailureMetrics({ orchestrator });
        const response = await middleware(err, mockContext);

        // Assert against the SHARED logMock
        expect(logMock.info).toHaveBeenCalledWith(
            'UpdateCartFailure',
            expect.objectContaining({
                level: 'info',
                debugId: 'mockDebugId',
                timestamp: 1000,
                event: 'UpdateCartFailure',
                message: 'UpdateCartFailed',
                orchestrator,
                merchantUrl: 'https://mock-merchant.com',
                status: '500',             // ensure the middleware logs string "500" if your test expects string
                duration: expect.any(Number),
            }),
        );

        expect(trackFailedUpdateCart).toHaveBeenCalledWith({
            orchestrator,
            merchantUrl: 'https://mock-merchant.com',
            status: '500',
        });

        expect(sendUpdateCartFailureAlarmMetric).toHaveBeenCalledWith({ orchestrator });

        // Updated assertion for the response
        expect(response).toEqual({
            statusCode: 500,
            body: JSON.stringify({
                name: 'InternalServerError',
                status: 500,
                message: 'Internal Server Error',
                details: [{ description: 'Mock error' }],
            }),
            headers: {
                'Content-Type': 'application/json',
                'paypal-debug-id': 'unknown',
            },
        });
    });

    it('should send Shopify API error alarm metric for specific errors', async () => {
        const orchestrator = 'mockOrchestrator';
        const err = new ShopifyUnknownError('Mock Shopify error');

        const middleware = updateCartFailureMetrics({ orchestrator });
        await middleware(err, mockContext);

        expect(sendShopifyAPIErrorAlarmMetric).toHaveBeenCalledWith('ShopifyUnknownError');
    });
});
