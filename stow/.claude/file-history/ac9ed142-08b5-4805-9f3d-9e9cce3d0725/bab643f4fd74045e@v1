import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { ALBEvent, Context as LambdaContext } from "aws-lambda";
import { ZodError } from "zod/v4";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { createCommerceOnboardingService } from "../../shared/commerce-onboarding";
import { parseJwtFromCartApi } from "../../shared/helpers/AppContextAuthorizer";
import {
  trackInitiatedPaymentFireAndForget,
  trackFailedPaymentFireAndForget,
} from "../../shared/metrics/emitMetric";
import { logAPIResponseError } from "../../shared/errors";
// import { getCacheImplementation } from "../../shared/cache/cacheFactory";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";

vi.mock("../../shared/commerce-onboarding");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");
vi.mock("../../shared/cache/cacheFactory", () => {
  const mockCache = {
    set: vi.fn().mockResolvedValue(undefined),
    get: vi.fn().mockResolvedValue(JSON.stringify({ id: "cart-123" })),
    delete: vi.fn().mockResolvedValue(undefined),
  };

  return {
    getCacheImplementation: vi.fn(() => mockCache),
  };
});
vi.mock("../../shared/errors", async () => {
  const actual = await vi.importActual("../../shared/errors");
  return {
    ...actual,
    logAPIResponseError: vi.fn(),
  };
});
vi.mock("../../shared/logger/logger", () => ({
  logger: vi.fn(() => ({
    error: vi.fn(),
    info: vi.fn(),
    warn: vi.fn(),
    log: vi.fn(),
    debug: vi.fn(),
  })),
}));

const validCompleteCartRequest = {
  id: "cart-123",
  payment_method: {
    token: "EC-12345",
    payer_id: "PAYER123",
    type: "paypal",
  },
  checkout_fields: [],
  accepted_policies: ["terms_of_service", "privacy_policy"],
};

const mockCompleteCartResponse = {
  id: "cart-123",
  items: [
    {
      item_id: "product-123",
      quantity: 1,
      name: "Test Product",
      price: {
        currency_code: "USD",
        value: "100.00",
      },
    },
  ],
  payment_confirmation: {
    merchant_order_number: "ORDER-123",
    order_review_page: "https://merchant.com/order/123",
  },
};

describe("Generic Complete Cart Lambda Handler", () => {
  let mockEvent: ALBEvent;
  let mockContext: LambdaContext;
  let mockMerchantClient: any;

  beforeEach(() => {
    // Mock the COMMERCE_ONBOARDING environment variables
    process.env.COMMERCE_ONBOARDING_API_KEY = "test-api-key";
    process.env.COMMERCE_ONBOARDING_URL =
      "https://test-commerce-onboarding.com";

    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: JSON.stringify(validCompleteCartRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    mockContext = {
      functionName: "generic-complete-cart",
      invokedFunctionArn:
        "arn:aws:lambda:us-east-1:123456789012:function:generic-complete-cart",
      awsRequestId: "test-request-id",
      callbackWaitsForEmptyEventLoop: true,
      functionVersion: "1",
      memoryLimitInMB: "128",
      logGroupName: "/aws/lambda/generic-complete-cart",
      logStreamName: "2024/01/01/[$LATEST]test",
      getRemainingTimeInMillis: () => 3000,
      done: vi.fn(),
      fail: vi.fn(),
      succeed: vi.fn(),
    };

    mockMerchantClient = {
      completeCart: vi.fn().mockResolvedValue(mockCompleteCartResponse),
    };

    vi.mocked(createCommerceOnboardingService).mockReturnValue({
      setStoreContext: vi.fn(),
      completeCart: mockMerchantClient.completeCart,
    } as any);
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });
    vi.mocked(trackInitiatedPaymentFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(trackFailedPaymentFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(logAPIResponseError).mockImplementation(() => {});
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  it("should complete a cart successfully with shopware orchestrator", async () => {
    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(200);
    expect(response.headers?.["Content-Type"]).toBe("application/json");
    expect(JSON.parse(response.body)).toEqual(mockCompleteCartResponse);

    expect(parseJwtFromCartApi).toHaveBeenCalledWith({
      event: mockEvent,
      logger: expect.any(Object),
    });

    expect(mockMerchantClient.completeCart).toHaveBeenCalledWith({
      cartId: "cart-123",
      data: {
        id: "cart-123",
        payment_method: {
          token: "EC-12345",
          payer_id: "PAYER123",
          type: "paypal",
        },
        checkout_fields: [],
      },
      event: mockEvent,
    });
  });

  it("should complete a cart successfully with ultracart orchestrator", async () => {
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "ultracart.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(200);
    expect(mockMerchantClient.completeCart).toHaveBeenCalledWith({
      cartId: "cart-123",
      data: {
        id: "cart-123",
        payment_method: {
          token: "EC-12345",
          payer_id: "PAYER123",
          type: "paypal",
        },
        checkout_fields: [],
      },
      event: mockEvent,
    });
  });

  it("should track metrics for successful operations", async () => {
    await handler(mockEvent, mockContext);

    expect(trackInitiatedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
    });

    expect(trackFailedPaymentFireAndForget).not.toHaveBeenCalled();
  });

  it("should handle missing payment token", async () => {
    const invalidRequest = {
      id: "cart-123",
      payment_method: {
        payer_id: "PAYER123",
        type: "paypal",
        // Missing token
      },
      checkout_fields: [],
      accepted_policies: ["terms_of_service", "privacy_policy"],
    };

    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: JSON.stringify(invalidRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.details).toEqual(
      expect.arrayContaining([
        expect.objectContaining({
          description: "A valid payment token is required",
        }),
      ]),
    );

    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "400",
    });
  });

  it("should handle missing payer ID", async () => {
    const invalidRequest = {
      id: "cart-123",
      payment_method: {
        token: "EC-12345",
        type: "paypal",
        // Missing payer_id
      },
      checkout_fields: [],
      accepted_policies: ["terms_of_service", "privacy_policy"],
    };

    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: JSON.stringify(invalidRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.details).toEqual(
      expect.arrayContaining([
        expect.objectContaining({
          description: "A valid payer id is required",
        }),
      ]),
    );

    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "400",
    });
  });

  it("should handle Zod validation errors", async () => {
    const invalidRequest = null; // null should fail object validation

    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: JSON.stringify(invalidRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "400",
    });
  });

  it("should handle invalid JSON in request body", async () => {
    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: '{"invalid": json}',
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "500",
    });
  });

  it("should handle JWT parsing errors", async () => {
    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw new Error("Invalid JWT token");
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: "500",
    });
  });

  it("should handle invalid JWT payload structure", async () => {
    const zodError = new ZodError([
      {
        code: "invalid_type",
        expected: "string",
        path: ["aud"],
        message: "Required",
      } as any,
    ]);

    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw zodError;
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: "400",
    });
  });

  it("should handle MerchantClient errors", async () => {
    mockMerchantClient.completeCart.mockRejectedValue(
      new Error("Network error"),
    );

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      encryptedMerchantId: "encrypted-merchant-123",
      honeyStoreId: "393914911834861447",
      status: "500",
    });
  });

  it("should log errors using logAPIResponseError", async () => {
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });
    mockMerchantClient.completeCart.mockRejectedValue(new Error("Test error"));

    await handler(mockEvent, mockContext);

    expect(logAPIResponseError).toHaveBeenCalledWith(
      expect.any(Object), // logger
      expect.any(Object), // APIError
    );
  });

  it("should handle empty request body", async () => {
    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: "",
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalled();
  });

  it("should handle missing Authorization header", async () => {
    mockEvent = getMockALBEvent({
      path: "/generic/cart/cart-123/complete",
      body: JSON.stringify(validCompleteCartRequest),
      headers: {},
    });

    // JWT parsing should fail without Authorization header
    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw new Error("Missing Authorization header");
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedPaymentFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      encryptedMerchantId: undefined,
      honeyStoreId: undefined,
      status: "500",
    });
  });
});
