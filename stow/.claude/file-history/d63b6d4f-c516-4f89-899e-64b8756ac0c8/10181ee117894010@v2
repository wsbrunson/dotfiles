import { performMask } from "./maskPii";

// Demonstrate the issues
const testData = {
  // Issue 1: Allowed key with object value should recurse, not mask
  productId: { id: "123", name: "Product" }, // Both 'id' and 'name' are allowed keys

  // Issue 2: Array handling inconsistency
  items: [
    { productId: "123", price: 10.99 }, // productId allowed, price not allowed
  ],

  // Issue 3: Date handling
  timestamp: new Date("2023-01-01"),

  // This should work correctly
  correlationId: "test-123",
  sensitiveData: "should-be-masked"
};

console.log("Original:", JSON.stringify(testData, null, 2));

const result = performMask(JSON.parse(JSON.stringify(testData))); // Deep clone to avoid mutation issues

console.log("Result:", JSON.stringify(result, null, 2));

