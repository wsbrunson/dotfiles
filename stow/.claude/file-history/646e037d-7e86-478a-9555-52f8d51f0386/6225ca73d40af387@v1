import { describe, it, expect, vi, beforeEach, afterEach } from "vitest";
import * as dgram from "dgram";
import {
  emitDatadogMetric,
  emitDatadogMetricFireAndForget,
} from "./datadogMetrics";

vi.mock("dgram");
vi.mock("../logger/logger", () => ({
  logger: () => ({
    info: vi.fn(),
    error: vi.fn(),
  }),
}));

describe("datadogMetrics", () => {
  const mockSend = vi.fn();
  const mockClose = vi.fn();
  const mockSocket = {
    send: mockSend,
    close: mockClose,
  };

  beforeEach(() => {
    vi.clearAllMocks();
    vi.mocked(dgram.createSocket).mockReturnValue(mockSocket as any);
    mockSend.mockImplementation(
      (_buffer, _offset, _length, _port, _host, callback) => {
        callback(null);
      },
    );
  });

  afterEach(() => {
    vi.unstubAllEnvs();
  });

  describe("emitDatadogMetric", () => {
    it("should create a UDP socket and send the metric", async () => {
      await emitDatadogMetric("test.metric", { action: "test" });

      expect(dgram.createSocket).toHaveBeenCalledWith("udp4");
      expect(mockSend).toHaveBeenCalled();
      expect(mockClose).toHaveBeenCalled();
    });

    it("should format the StatsD message correctly", async () => {
      await emitDatadogMetric("test.metric", { action: "test" }, 5);

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("commerce_orchestrator.test.metric:5|c");
      expect(message).toContain("action:test");
      expect(message).toContain("service:commerce-orchestrator");
    });

    it("should convert parameter keys to camelCase", async () => {
      await emitDatadogMetric("test.metric", { some_key: "value" });

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("someKey:value");
    });

    it("should extract hostname from merchantUrl", async () => {
      await emitDatadogMetric("test.metric", {
        merchantUrl: "https://example.com/path",
      });

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("merchant_url:example.com");
    });

    it("should fallback to raw merchantUrl if URL parsing fails", async () => {
      await emitDatadogMetric("test.metric", {
        merchantUrl: "not-a-valid-url",
      });

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("merchant_url:not-a-valid-url");
    });

    it("should include resource_name tag when AWS_LAMBDA_FUNCTION_NAME is set", async () => {
      vi.stubEnv("AWS_LAMBDA_FUNCTION_NAME", "my-lambda-function");

      await emitDatadogMetric("test.metric", { action: "test" });

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("resource_name:my-lambda-function");
    });

    it("should use default value of 1 when value is not provided", async () => {
      await emitDatadogMetric("test.metric", { action: "test" });

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("commerce_orchestrator.test.metric:1|c");
    });

    it("should send to default host and port", async () => {
      await emitDatadogMetric("test.metric", { action: "test" });

      const sendCall = mockSend.mock.calls[0];
      const port = sendCall[3];
      const host = sendCall[4];

      expect(port).toBe(8125);
      expect(host).toBe("127.0.0.1");
    });

    it("should handle multiple parameters", async () => {
      await emitDatadogMetric("test.metric", {
        action: "create",
        orchestrator: "shopify",
        status: 200,
        success: true,
      });

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("action:create");
      expect(message).toContain("orchestrator:shopify");
      expect(message).toContain("status:200");
      expect(message).toContain("success:true");
    });

    it("should handle send errors gracefully", async () => {
      const sendError = new Error("Network error");
      mockSend.mockImplementation(
        (_buffer, _offset, _length, _port, _host, callback) => {
          callback(sendError);
        },
      );

      // Should not throw
      await expect(
        emitDatadogMetric("test.metric", { action: "test" }),
      ).resolves.toBeUndefined();
    });

    it("should close socket even when send fails", async () => {
      const sendError = new Error("Network error");
      mockSend.mockImplementation(
        (_buffer, _offset, _length, _port, _host, callback) => {
          callback(sendError);
        },
      );

      await emitDatadogMetric("test.metric", { action: "test" });

      expect(mockClose).toHaveBeenCalled();
    });
  });

  describe("emitDatadogMetricFireAndForget", () => {
    it("should call emitDatadogMetric asynchronously", async () => {
      emitDatadogMetricFireAndForget("test.metric", { action: "test" });

      // Wait for setImmediate to execute
      await new Promise((resolve) => setImmediate(resolve));

      expect(dgram.createSocket).toHaveBeenCalledWith("udp4");
      expect(mockSend).toHaveBeenCalled();
    });

    it("should pass value parameter correctly", async () => {
      emitDatadogMetricFireAndForget("test.metric", { action: "test" }, 42);

      await new Promise((resolve) => setImmediate(resolve));

      const sendCall = mockSend.mock.calls[0];
      const buffer = sendCall[0] as Buffer;
      const message = buffer.toString();

      expect(message).toContain("commerce_orchestrator.test.metric:42|c");
    });

    it("should return immediately without waiting for metric emission", () => {
      const startTime = Date.now();
      emitDatadogMetricFireAndForget("test.metric", { action: "test" });
      const endTime = Date.now();

      // Should return almost immediately (less than 10ms)
      expect(endTime - startTime).toBeLessThan(10);
    });

    it("should handle errors without throwing", async () => {
      mockSend.mockImplementation(
        (_buffer, _offset, _length, _port, _host, callback) => {
          callback(new Error("Network error"));
        },
      );

      // Should not throw
      emitDatadogMetricFireAndForget("test.metric", { action: "test" });

      await new Promise((resolve) => setImmediate(resolve));

      // Give time for error handling
      await new Promise((resolve) => setTimeout(resolve, 10));

      // Test passes if no exception is thrown
      expect(true).toBe(true);
    });
  });
});
