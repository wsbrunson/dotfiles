const MASK_VALUE = "**********";

function isAllowedKey(key: string): boolean {
  return ALLOWED_KEYS.has(key);
}

function isAllowedValue(value: unknown): boolean {
  return (
    value === null ||
    value === undefined ||
    typeof value === "string" ||
    typeof value === "number" ||
    typeof value === "boolean"
  );
}

export function performMask(
  obj: Record<string, unknown>,
  seenObjects = new WeakMap<object, boolean>(),
): Record<string, unknown> {
  // Protect against null or non-object values
  if (!obj || typeof obj !== "object") {
    return obj;
  }

  // Check for circular references
  if (seenObjects.has(obj)) {
    return { __circular__: true, type: obj.constructor?.name || "Object" };
  }

  // Mark this object as seen
  seenObjects.set(obj, true);

  Object.entries(obj).forEach(([key, value]) => {
    // Special handling for 'body' field that might contain JSON with sensitive data
    if (key === "body" && typeof value === "string") {
      try {
        const parsed = JSON.parse(value);
        if (parsed && typeof parsed === "object") {
          // Recursively mask the parsed object
          const masked = performMask(parsed);
          obj[key] = JSON.stringify(masked);
          return;
        }
      } catch {
        // Not valid JSON, continue with normal processing
      }
    }

    // If value is an array, map through it
    if (value && Array.isArray(value)) {
      obj[key] = value.map((v) => {
        if (v && typeof v === "object") {
          // Check if we've seen this object before
          if (seenObjects.has(v)) {
            return {
              __circular__: true,
              type: v.constructor?.name || "Object",
            };
          }
          // If value is an object, recursively mask it with the seen objects map
          return performMask(v as Record<string, unknown>, seenObjects);
        } else if (!isAllowedValue(v)) {
          // If item is not a primitive value, mask it
          return MASK_VALUE;
        } else {
          return v;
        }
      });
    } else if (value && typeof value === "object") {
      // Always recursively process objects regardless of key name
      // The individual primitive values inside will be masked based on their own keys
      obj[key] = performMask(value as Record<string, unknown>, seenObjects);
    } else if (!isAllowedKey(key)) {
      // Mask if key is not allowed (for primitive values)
      obj[key] = MASK_VALUE;
    }
    // If key is allowed and value is primitive, keep it as-is
  });

  return obj;
}
