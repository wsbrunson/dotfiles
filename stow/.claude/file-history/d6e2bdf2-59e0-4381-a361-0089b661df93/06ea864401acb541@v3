#!/usr/bin/env bash
set -euo pipefail

# jason - A JSON utility tool
# Usage: jason <command> [args...]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

show_help() {
    cat << EOF
jason - A JSON utility tool

Usage: $SCRIPT_NAME <command> [args...]

Commands:
    convert-yml <yaml-file>    Convert YAML file to JSON
    format <input>             Format JSON from string or object

Options:
    -h, --help                 Show this help message

Examples:
    $SCRIPT_NAME convert-yml config.yaml
    $SCRIPT_NAME convert-yml data.yml
    $SCRIPT_NAME format '{"name":"test","age":30}'
EOF
}

convert_yml() {
    local yaml_file="$1"

    # Validate input file exists
    if [[ ! -f "$yaml_file" ]]; then
        echo "Error: File '$yaml_file' does not exist" >&2
        exit 1
    fi

    # Validate file extension
    if [[ ! "$yaml_file" =~ \.(yml|yaml)$ ]]; then
        echo "Error: File '$yaml_file' must have .yml or .yaml extension" >&2
        exit 1
    fi

    # Generate output filename (replace .yml/.yaml with .json)
    local json_file="${yaml_file%.*}.json"

    # Check if we have yq available
    if command -v yq >/dev/null 2>&1; then
        # Use yq to convert YAML to JSON
        yq eval -o=json "$yaml_file" > "$json_file"
        echo "Converted '$yaml_file' to '$json_file'"
    elif command -v python3 >/dev/null 2>&1; then
        # Fallback to Python
        python3 << EOF
import yaml
import json
import sys

try:
    with open('$yaml_file', 'r') as yaml_file_handle:
        yaml_data = yaml.safe_load(yaml_file_handle)

    with open('$json_file', 'w') as json_file_handle:
        json.dump(yaml_data, json_file_handle, indent=2)

    print("Converted '$yaml_file' to '$json_file'")
except yaml.YAMLError as e:
    print(f"Error parsing YAML file: {e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f"Error: {e}", file=sys.stderr)
    sys.exit(1)
EOF
    else
        echo "Error: Neither 'yq' nor 'python3' with PyYAML is available" >&2
        echo "Please install one of the following:" >&2
        echo "  - yq: brew install yq" >&2
        echo "  - Python with PyYAML: pip3 install PyYAML" >&2
        exit 1
    fi
}

# Main command dispatcher
main() {
    if [[ $# -eq 0 ]]; then
        echo "Error: No command specified" >&2
        echo ""
        show_help
        exit 1
    fi

    local command="$1"
    shift

    case "$command" in
        convert-yml)
            if [[ $# -eq 0 ]]; then
                echo "Error: convert-yml requires a YAML file path" >&2
                echo "Usage: $SCRIPT_NAME convert-yml <yaml-file>" >&2
                exit 1
            fi
            convert_yml "$1"
            ;;
        -h|--help|help)
            show_help
            ;;
        *)
            echo "Error: Unknown command '$command'" >&2
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"