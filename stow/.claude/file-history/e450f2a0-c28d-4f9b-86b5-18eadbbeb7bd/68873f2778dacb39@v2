## Data Schema Design

### Layer 1: Merchant Request Schema (Inbound)

What merchants send to us:

```typescript
const MerchantWebhookEventSchema = z.object({
  // Event metadata
  event_id: z.string().uuid(),
  event_type: z.enum([
    "ORDER_SHIPPED",
    "ORDER_DELIVERED",
    "ORDER_CANCELLED",
    "ORDER_REFUNDED",
    "ITEM_RETURNED",
    "FULFILLMENT_DELAYED",
  ]),
  event_timestamp: z.string().datetime(),

  // Order identification - links to original checkout
  merchant_order_number: z.string().min(1).max(256),

  // Event-specific payload (discriminated union)
  payload: z.discriminatedUnion("event_type", [
    OrderShippedPayloadSchema,
    OrderDeliveredPayloadSchema,
    OrderCancelledPayloadSchema,
    OrderRefundedPayloadSchema,
    ItemReturnedPayloadSchema,
    FulfillmentDelayedPayloadSchema,
  ]),
});

// Event-specific payloads
const OrderShippedPayloadSchema = z.object({
  event_type: z.literal("ORDER_SHIPPED"),
  carrier: z.string(),
  tracking_number: z.string(),
  tracking_url: z.string().url().optional(),
  shipped_items: z.array(z.object({
    sku: z.string(),
    quantity: z.number().int().positive(),
  })),
  estimated_delivery: z.string().datetime().optional(),
});

const OrderDeliveredPayloadSchema = z.object({
  event_type: z.literal("ORDER_DELIVERED"),
  delivered_at: z.string().datetime(),
  delivery_location: z.enum(["FRONT_DOOR", "MAILBOX", "LOCKER", "SIGNED", "OTHER"]).optional(),
  signature_name: z.string().optional(),
});

const OrderCancelledPayloadSchema = z.object({
  event_type: z.literal("ORDER_CANCELLED"),
  cancelled_by: z.enum(["MERCHANT", "CUSTOMER"]),
  reason: z.string().optional(),
  cancelled_items: z.array(z.object({
    sku: z.string(),
    quantity: z.number().int().positive(),
  })).optional(), // If not provided, entire order cancelled
});

const OrderRefundedPayloadSchema = z.object({
  event_type: z.literal("ORDER_REFUNDED"),
  refund_type: z.enum(["FULL", "PARTIAL"]),
  refund_amount: z.object({
    value: z.string(),
    currency_code: z.string().length(3),
  }),
  refunded_items: z.array(z.object({
    sku: z.string(),
    quantity: z.number().int().positive(),
  })).optional(),
  reason: z.string().optional(),
});

const ItemReturnedPayloadSchema = z.object({
  event_type: z.literal("ITEM_RETURNED"),
  return_status: z.enum(["INITIATED", "IN_TRANSIT", "RECEIVED", "PROCESSED"]),
  returned_items: z.array(z.object({
    sku: z.string(),
    quantity: z.number().int().positive(),
  })),
  return_tracking_number: z.string().optional(),
  refund_issued: z.boolean(),
});

const FulfillmentDelayedPayloadSchema = z.object({
  event_type: z.literal("FULFILLMENT_DELAYED"),
  original_estimated_delivery: z.string().datetime(),
  new_estimated_delivery: z.string().datetime(),
  reason: z.string().optional(),
});
```

### Layer 2: LLM Partner Notification Schema (Outbound)

What we send to LLM partners:

```typescript
const LLMPartnerNotificationSchema = z.object({
  // Routing info for the LLM partner
  notification_id: z.string().uuid(),
  notification_type: z.literal("ORDER_UPDATE"),
  timestamp: z.string().datetime(),

  // Order context - enables LLM to correlate with original purchase
  order_context: z.object({
    merchant_order_number: z.string(),
    merchant_name: z.string(),
    merchant_id: z.string(),
    original_purchase_timestamp: z.string().datetime().optional(),
  }),

  // Human-readable summary for LLM consumption
  update_summary: z.object({
    event_type: z.string(),
    headline: z.string(),        // e.g., "Your order has shipped!"
    details: z.string(),         // e.g., "Tracking: 1Z999..."
    action_url: z.string().url().optional(),
    next_expected_event: z.string().optional(),
  }),

  // Structured data for programmatic use
  structured_data: z.object({
    event_type: z.string(),
    // Event-specific fields flattened
    // Carrier, tracking, amounts, etc.
  }).passthrough(),
});
```

### Transformation Logic

```typescript
function transformToPartnerSchema(
  webhookEvent: MerchantWebhookEvent,
  merchantContext: MerchantContext
): LLMPartnerNotification {
  return {
    notification_id: crypto.randomUUID(),
    notification_type: "ORDER_UPDATE",
    timestamp: new Date().toISOString(),

    order_context: {
      merchant_order_number: webhookEvent.merchant_order_number,
      merchant_name: merchantContext.merchantName,
      merchant_id: merchantContext.merchantId,
    },

    update_summary: generateHumanReadableSummary(webhookEvent),

    structured_data: {
      event_type: webhookEvent.event_type,
      ...webhookEvent.payload,
    },
  };
}

function generateHumanReadableSummary(event: MerchantWebhookEvent): UpdateSummary {
  switch (event.event_type) {
    case "ORDER_SHIPPED":
      return {
        event_type: "ORDER_SHIPPED",
        headline: "Your order has shipped!",
        details: `Carrier: ${event.payload.carrier}. Tracking: ${event.payload.tracking_number}`,
        action_url: event.payload.tracking_url,
        next_expected_event: "ORDER_DELIVERED",
      };
    // ... other cases
  }
}
```

