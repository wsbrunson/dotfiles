vi.mock('msw/node', () => {
  const makeEmitter = () => {
    const map = new Map<string, Array<(req: any) => void>>();
    return {
      on(ev: string, cb: (req: any) => void) {
        map.set(ev, [...(map.get(ev) ?? []), cb]);
      },
      emit(ev: string, req: any) {
        (map.get(ev) ?? []).forEach((cb) => cb(req));
      },
    };
  };

  return {
    setupServer: vi.fn((...handlers: any[]) => {
      const inst = {
        listen: h.listenMock,
        close: h.closeMock,
        events: makeEmitter(),
        _handlers: handlers,
      };
      h.lastInstance.value = inst;
      return inst;
    }),
  };
});

