import { app } from './app';
import { BigCommerceController } from './services/controllers';

describe('BigCommerce App', () => {
    beforeEach(() => {
        vi.clearAllMocks();
        new BigCommerceController({
            cache: {
                get: vi.fn(),
                set: vi.fn(),
                delete: vi.fn(),
            },
            log: {
                error: vi.fn(),
                warn: vi.fn(),
                info: vi.fn(),
                debug: vi.fn(),
            }
        });
    });

    const createMockALBEvent = (
        method: string,
        path: string,
        body?: any,
        headers: Record<string, string> = {}
    ): ALBEvent => ({
        requestContext: {
            elb: {
                targetGroupArn: 'arn:aws:elasticloadbalancing:us-west-2:123456789012:targetgroup/test/123abc',
            },
        },
        httpMethod: method,
        path,
        headers: {
            'content-type': 'application/json',
            'paypal-application-context': 'mock-jwt-token',
            ...headers,
        },
        body: body ? JSON.stringify(body) : null,
        isBase64Encoded: false,
        queryStringParameters: {},
        multiValueHeaders: {},
        multiValueQueryStringParameters: {},
    });

    describe('POST /commerceorchnodeserv/v2/bigcommerce/cart', () => {
        it('should create a cart successfully', async () => {
            const requestBody = {
                id: 'test-cart-1',
                items: [
                    {
                        item_id: 'PROD-123',
                        quantity: 1,
                        item_url: 'https://example.com/product/123',
                        price: {
                            currency_code: 'USD',
                            value: '100.00'
                        }
                    },
                ],
                customer: {
                    name: {
                        given_name: 'John',
                        surname: 'Doe'
                    },
                    email_address: 'john@example.com',
                    phone: {
                        country_code: '1',
                        national_number: '234567890'
                    }
                },
                shipping_address: {
                    address_line_1: '123 Main St',
                    address_line_2: 'Apt 4',
                    admin_area_1: 'CA',
                    admin_area_2: 'San Francisco',
                    postal_code: '94105',
                    country_code: 'US',
                },
                billing_address: {
                    address_line_1: '123 Main St',
                    address_line_2: 'Apt 4',
                    admin_area_1: 'CA',
                    admin_area_2: 'San Francisco',
                    postal_code: '94105',
                    country_code: 'US',
                },
            };

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/bigcommerce/cart',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/bigcommerce/cart', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(201);
            const responseBody = await response.json();
            expect(responseBody).toEqual({
                status: 'CREATED',
                payment_method: { 
                    type: 'paypal',
                    token: 'EC-98765',
                },
                available_shipping_options: [
                    {
                        id: 'STANDARD',
                        name: 'Standard Shipping',
                        price: { currency_code: 'USD', value: '5.00' },
                        is_selected: true,
                    },
                ],
                totals: {
                    total: { currency_code: 'USD', value: '105.00'},
                    tax: { currency_code: 'USD', value: '8.00'}
                },
            });
        });

        it('should return 400 for invalid request body', async () => {
            const invalidBody = {
                items: [], // Empty items array should trigger validation error
            };

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/bigcommerce/cart',
                invalidBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/bigcommerce/cart', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(invalidBody),
                }),
                { event }
            );

            expect(response.status).toBe(400);
        });
    });

    describe('POST /commerceorchnodeserv/v2/bigcommerce/cart/:cartId/complete', () => {
        it('should complete a cart successfully', async () => {
            const requestBody: CompleteCheckoutRequest = {
                payment_method: {
                    type: 'paypal',
                    payer_id: 'PAYER-123',
                    token: 'EC-98765',
                },
            };

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/bigcommerce/cart/test-cart-1/complete',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/bigcommerce/cart/test-cart-1/complete', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(201);
            const responseBody = await response.json();
            expect(responseBody).toEqual({
                id: 'TXN-456',
                status: 'COMPLETED',
                payment_method: {
                  token: "EC-98765",
                  type: "paypal",
                },
                totals: {
                  tax: {
                    currency_code: "USD",
                    value: "8.00",
                  },
                  total: {
                    currency_code: "USD",
                    value: "105.00",
                 },
               },
            });
        });
    });

    describe('PUT /commerceorchnodeserv/v2/bigcommerce/cart/:cartId', () => {
        it('should update a cart successfully', async () => {
            const requestBody = {
                cart: {
                    products: [
                        {
                            productId: '123',
                            quantity: 2,
                        },
                    ],
                    customer: {
                        firstName: 'John',
                        lastName: 'Doe',
                        email: 'john@example.com',
                        phone: '+1234567890',
                    },
                    shippingAddress: {
                        addressLine1: '456 Oak Ave',
                        addressLine2: '',
                        adminArea1: 'NY',
                        adminArea2: 'New York',
                        postalCode: '10001',
                        countryCode: 'US',
                    },
                    billingAddress: {
                        addressLine1: '456 Oak Ave',
                        addressLine2: '',
                        adminArea1: 'NY',
                        adminArea2: 'New York',
                        postalCode: '10001',
                        countryCode: 'US',
                    },
                    shippingOptions: [
                        {
                            id: 'EXPRESS',
                            label: 'Express Shipping',
                            amount: { currency: 'USD', value: '15.00' },
                            selected: true,
                        },
                    ],
                },
                operations: [
                    {
                        op: 'replace',
                        path: '/products/0/quantity',
                        value: 2,
                    },
                    {
                        op: 'replace',
                        path: '/shippingAddress/addressLine1',
                        value: '456 Oak Ave',
                    },
                ],
            };

            const event = createMockALBEvent(
                'PUT',
                '/commerceorchnodeserv/v2/bigcommerce/cart/test-cart-1',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/bigcommerce/cart/test-cart-1', {
                    method: 'PUT',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(200);
            const responseBody = await response.json();
            expect(responseBody).toEqual({
                status: 'READY',
                payment_method: { 
                    type: 'paypal',
                    token: 'EC-98765-UPDATED' 
                },
                available_shipping_options: [
                    {
                        id: 'EXPRESS',
                        name: 'Express Shipping',
                        price: { currency_code: 'USD', value: '15.00' },
                        is_selected: true,
                    },
                ],
                totals: {
                    total: { currency_code: 'USD', value: '115.00'},
                    tax: { currency_code: 'USD', value: '8.00'}
                },
            });
        });

        it('should return 400 for invalid patch operations', async () => {
            const requestBody = {
                items: [],
            };

            const event = createMockALBEvent(
                'PUT',
                '/commerceorchnodeserv/v2/bigcommerce/cart/test-cart-1',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/bigcommerce/cart/test-cart-1', {
                    method: 'PUT',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(400);
        });
    });

    describe('Error handling', () => {
        it('should return 404 for unknown routes', async () => {
            const event = createMockALBEvent(
                'GET',
                '/commerceorchnodeserv/v2/bigcommerce/unknown',
                null
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/bigcommerce/unknown', {
                    method: 'GET',
                    headers: {
                        'paypal-application-context': 'mock-jwt-token',
                    },
                }),
                { event }
            );

            expect(response.status).toBe(404);
        });
    });
});