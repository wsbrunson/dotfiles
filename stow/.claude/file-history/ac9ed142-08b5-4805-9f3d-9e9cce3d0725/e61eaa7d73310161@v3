import { describe, it, expect, vi, beforeEach } from 'vitest';
import { ALBEvent } from 'aws-lambda';

// Set environment variables before any imports
process.env.AWS_REGION = 'us-west-2';

const mockCache = {
    get: vi.fn(),
    set: vi.fn(),
    delete: vi.fn(),
};

vi.mock('shared/cache/cacheFactory', () => ({
    getCacheImplementation: vi.fn(() => mockCache),
}));

vi.mock('shared/instrumentation/datadog', () => ({
    tracer: {
        trace: vi.fn((name, options, callback) => callback()),
        scope: vi.fn(() => ({ active: vi.fn(() => null) })),
    },
    getTraceHeaders: vi.fn(() => ({})),
}));

vi.mock('shared/wix/wix-client', () => ({
    WixClient: {
        create: vi.fn(() => Promise.resolve({
            createCart: vi.fn().mockResolvedValue({
                id: 'wix-cart-123',
                lineItems: [],
                currency: 'USD',
            }),
            completeCheckout: vi.fn().mockResolvedValue({
                checkoutId: 'wix-checkout-123',
                status: 'COMPLETED',
            }),
            updateCart: vi.fn().mockResolvedValue({
                id: 'wix-cart-123',
                lineItems: [],
                currency: 'USD',
            }),
        })),
    },
}));

vi.mock('shared/helpers/AppContextAuthorizer', () => ({
    verifyAppContext: vi.fn(() => true),
    parseJwtFromCartApi: vi.fn(() => ({ sub: 'test-instance-id' })),
}));

// Mock AWS CloudWatch SDK at the source
vi.mock('@aws-sdk/client-cloudwatch', () => {
    const mockSend = vi.fn().mockResolvedValue({});

    return {
        CloudWatch: vi.fn(() => ({
            send: mockSend,
        })),
        StandardUnit: {
            Count: 'Count',
            Seconds: 'Seconds',
            Percent: 'Percent',
            Bytes: 'Bytes',
        },
        PutMetricDataCommand: vi.fn(),
    };
});

// Mock the secrets module to avoid SECRET_PATH requirement in tests
vi.mock('./secrets', () => ({
    getWixCredentials: vi.fn(() => Promise.resolve({
        clientId: 'test-client-id',
        clientSecret: 'test-client-secret',
    })),
    ensureSecretsInitialized: vi.fn(() => Promise.resolve()),
    wixClientId: 'test-client-id',
    wixClientSecret: 'test-client-secret',
}));

vi.mock('shared/helpers/SecretsManagerHelper', () => ({
    SecretsManagerHelper: {
        getInstance: vi.fn(() => ({
            getSecret: vi.fn().mockResolvedValue({
                clientId: 'test-client-id',
                clientSecret: 'test-client-secret',
            }),
        })),
    },
}));

// Mock the index module to provide wixClientId and wixClientSecret
vi.mock('./index', () => ({
    wixClientId: 'test-client-id',
    wixClientSecret: 'test-client-secret',
    handler: vi.fn(),
}));

// Set environment variable before importing
process.env.SECRET_PATH = 'test-secret-path';

import { app } from './app';

describe('Wix App', () => {
    beforeEach(() => {
        vi.clearAllMocks();
    });

    const createMockALBEvent = (
        method: string,
        path: string,
        body?: any,
        headers: Record<string, string> = {}
    ): ALBEvent => ({
        requestContext: {
            elb: {
                targetGroupArn: 'arn:aws:elasticloadbalancing:us-west-2:123456789012:targetgroup/test/123abc',
            },
        },
        httpMethod: method,
        path,
        headers: {
            'content-type': 'application/json',
            'paypal-application-context': 'mock-jwt-token',
            ...headers,
        },
        body: body ? JSON.stringify(body) : null,
        isBase64Encoded: false,
        queryStringParameters: {},
        multiValueHeaders: {},
        multiValueQueryStringParameters: {},
    });

    describe('POST /commerceorchnodeserv/v2/wix/cart', () => {
        it('should create a cart successfully', async () => {
            const requestBody = {
                id: 'cart-123',
                items: [
                    {
                        item_id: 'product-1',
                        variant_id: 'variant-1',
                        quantity: 2,
                    },
                ],
            };

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/wix/cart',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/cart', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(201);
            const responseBody = await response.json();
            expect(responseBody).toEqual({
                id: 'wix-cart-123',
                lineItems: [],
                currency: 'USD',
            });
        });

        it('should nullify variant_id when it equals item_id', async () => {
            const requestBody = {
                id: 'cart-123',
                items: [
                    {
                        item_id: 'product-1',
                        variant_id: 'product-1', // Same as item_id
                        quantity: 2,
                    },
                ],
            };

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/wix/cart',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/cart', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(201);
        });
    });

    describe('POST /commerceorchnodeserv/v2/wix/cart/:cartId/complete', () => {
        it.skip('should complete a cart successfully', async () => {
            const requestBody = {
                billing_address: {
                    address_line_1: '123 Main St',
                    admin_area_1: 'CA',
                    admin_area_2: 'San Jose',
                    postal_code: '95131',
                    country_code: 'US',
                },
                contact: {
                    email: 'test@example.com',
                },
            };

            mockCache.get.mockResolvedValue(
                JSON.stringify({
                    wixResponse: { id: 'wix-cart-123' },
                })
            );

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/wix/cart/cart-123/complete',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/cart/cart-123/complete', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(201);
            const responseBody = await response.json();
            expect(responseBody).toEqual({
                checkoutId: 'wix-checkout-123',
                status: 'COMPLETED',
            });
        });

        it('should return 400 when cart not found in cache', async () => {
            const requestBody = {
                paymentId: 'payment-123',
            };

            mockCache.get.mockResolvedValue(null);

            const event = createMockALBEvent(
                'POST',
                '/commerceorchnodeserv/v2/wix/cart/cart-123/complete',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/cart/cart-123/complete', {
                    method: 'POST',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(400);
        });
    });

    describe('PUT /commerceorchnodeserv/v2/wix/cart/:cartId', () => {
        it('should update a cart successfully', async () => {
            const requestBody = {
                id: 'cart-123',
                items: [
                    {
                        item_id: 'product-1',
                        variant_id: 'variant-1',
                        quantity: 3,
                    },
                ],
            };

            mockCache.get.mockResolvedValue(
                JSON.stringify({
                    wixResponse: { id: 'wix-cart-123' },
                })
            );

            const event = createMockALBEvent(
                'PUT',
                '/commerceorchnodeserv/v2/wix/cart/cart-123',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/cart/cart-123', {
                    method: 'PUT',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(200);
            const responseBody = await response.json();
            expect(responseBody).toEqual({
                id: 'wix-cart-123',
                lineItems: [],
                currency: 'USD',
            });
        });

        it('should return 400 when cart not found in cache', async () => {
            const requestBody = {
                id: 'cart-123',
                items: [],
            };

            mockCache.get.mockResolvedValue(null);

            const event = createMockALBEvent(
                'PUT',
                '/commerceorchnodeserv/v2/wix/cart/cart-123',
                requestBody
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/cart/cart-123', {
                    method: 'PUT',
                    headers: {
                        'content-type': 'application/json',
                        'paypal-application-context': 'mock-jwt-token',
                    },
                    body: JSON.stringify(requestBody),
                }),
                { event }
            );

            expect(response.status).toBe(400);
        });
    });

    describe('Error handling', () => {
        it('should return 404 for unknown routes', async () => {
            const event = createMockALBEvent(
                'GET',
                '/commerceorchnodeserv/v2/wix/unknown',
                null
            );

            const response = await app.fetch(
                new Request('http://localhost/commerceorchnodeserv/v2/wix/unknown', {
                    method: 'GET',
                    headers: {
                        'paypal-application-context': 'mock-jwt-token',
                    },
                }),
                { event }
            );

            expect(response.status).toBe(404);
        });
    });
});
