import 'shared/instrumentation/datadog';
import { wrapHandlerWithTracing } from 'shared/instrumentation/wrapHandler';

import { payPalCartSchema } from "../../shared/schemas/openapi-schemas";
import {
  getCorrelationIdFromRequest,
  UnauthorizedError,
  convertErrorToLambdaResponse,
  logAPIResponseError,
  BadRequestError,
} from "../../shared/errors";
import { ALBEvent, APIGatewayProxyStructuredResultV2 } from "aws-lambda";
import { logger } from "../../shared/logger/logger";
import { Cache } from "../../shared/cache";
import { getCacheImplementation } from "shared/cache/cacheFactory";
import { verifyAppContext } from "shared/helpers/AppContextAuthorizer";
import { WixClient } from "shared/wix/wix-client";
import {
  sendAddCartInitiatedAlarmMetricFireAndForget,
  sendAddCartSuccessAlarmMetricFireAndForget,
  sendAddCartFailureAlarmMetricFireAndForget,
} from "shared/metrics/alarm-metrics";
import {
  BaseMetricParams,
  trackInitiatedAddCartFireAndForget,
  trackSuccessAddCartFireAndForget,
  trackFailedAddCartFireAndForget,
} from "shared/metrics/emitMetric";
import {
  trackDatadogInitiatedAddCartFireAndForget,
  trackDatadogSuccessAddCartFireAndForget,
  trackDatadogFailedAddCartFireAndForget,
} from "shared/metrics/emitDatadogMetric";
import { startSimulatorV2, stopSimulator } from "shared/simulator/server";
import { ZodError } from "zod/v4";
import { isProduction } from "../../shared/utils";
import { SecretsManagerHelper } from "shared/helpers/SecretsManagerHelper";

// Lambda initialization - runs once per container cold start
// When we move to single lambda, this duplication of code will be removed
const initLog = logger("WixCreateCart-Init");
let wixClientId: string;
let wixClientSecret: string;

const initializeSecrets = async (): Promise<void> => {
  const secretPath = process.env.SECRET_PATH;
  if (!secretPath) {
    throw new Error("SECRET_PATH environment variable is not set");
  }

  initLog.info("Fetching Wix secrets during Lambda initialization", { secretPath });
  const secretsManager = SecretsManagerHelper.getInstance();
  const secrets = await secretsManager.getSecret(secretPath);

  wixClientId = secrets.clientId;
  wixClientSecret = secrets.clientSecret;

  if (!wixClientId || !wixClientSecret) {
    throw new Error("Failed to retrieve Wix client credentials from secrets");
  }

  initLog.info("Wix secrets initialized successfully");
};

const secretsPromise = initializeSecrets();
let cache: Cache;

const handler = async (
  event: ALBEvent
): Promise<APIGatewayProxyStructuredResultV2> => {
  const overallStartTime = performance.now();
  await secretsPromise;
  const secretsDuration = performance.now() - overallStartTime;
  const correlationId = getCorrelationIdFromRequest(event);
  const log = logger("WixCreateCart", event);

  log.info("Secrets awaiting completed", {
    correlationId,
    duration: `${secretsDuration.toFixed(2)}ms`,
  });

  log.info("Lambda Function - wix-create-cart - START", {
    correlationId,
    timestamp: new Date().toISOString(),
    httpMethod: event.httpMethod,
    path: event.path,
    userAgent: event.headers?.["user-agent"],
  });

  // Initialize cache once at lambda initialization
  if (!cache) {
    cache = getCacheImplementation();
  }

  const baseMetricParams: BaseMetricParams = {
    orchestrator: "Wix",
    merchantUrl: "",
  };

  sendAddCartInitiatedAlarmMetricFireAndForget({
    orchestrator: baseMetricParams.orchestrator,
  });

  try {
    // 1. Authorization
    const authStartTime = performance.now();
    const isAuthorized = verifyAppContext(event);
    const authDuration = performance.now() - authStartTime;

    log.info("Authorization completed", {
      correlationId,
      duration: `${authDuration.toFixed(2)}ms`,
      authorized: isAuthorized,
    });

    if (!isAuthorized) {
      log.error("Unauthorized access: AppContext verification failed", { correlationId });
      throw new UnauthorizedError(correlationId, {
        details: [
          {
            field: "AppContext",
            description:
              "AppContext verification failed, resulting in unauthorized access.",
          },
        ],
      });
    }

    // 2. Request parsing and validation
    const validationStartTime = performance.now();
    const body =
      typeof event.body === "string" ? JSON.parse(event.body) : event.body;

    let data;
    try {
      data = payPalCartSchema.parse(body);
    } catch (error) {
      if (error instanceof ZodError) {
        throw new BadRequestError(correlationId, {
          details: error.issues.map((issue) => ({
            description: `${issue.path.join(".")} is ${issue.message}`,
          })),
        });
      }
      throw error;
    }
    const validationDuration = performance.now() - validationStartTime;

    log.info("Request validation completed", {
      correlationId,
      duration: `${validationDuration.toFixed(2)}ms`,
      cartId: data.id,
      itemCount: data.items?.length || 0,
    });

    baseMetricParams.merchantUrl = (data as any).merchant_url || "";

    trackInitiatedAddCartFireAndForget(baseMetricParams);
    trackDatadogInitiatedAddCartFireAndForget({
      ...baseMetricParams,
      env: process.env.APP_ENV || "unknown",
    });

    log.info("AddCartInitiated", {
      level: "info",
      timestamp: overallStartTime,
      event: "AddCartInitiated",
      ...baseMetricParams,
    });

    // 3. Simulator setup (skip in production for performance)
    const simulatorStartTime = performance.now();
    if (!isProduction()) {
      await startSimulatorV2({
        type: "create",
        data,
        orchestrator: "wix",
        platformBaseUrl: "https://www.wixapis.com/ecom/api",
        headers: event.headers,
      });
    }
    const simulatorDuration = performance.now() - simulatorStartTime;

    log.info("Simulator setup completed", {
      correlationId,
      duration: `${simulatorDuration.toFixed(2)}ms`,
      skipped: isProduction(),
    });

    // 4. Wix client creation and cart processing
    const clientStartTime = performance.now();
    const wixClient = await WixClient.create(event, wixClientId, wixClientSecret);
    const clientDuration = performance.now() - clientStartTime;

    log.info("Wix client created", {
      correlationId,
      duration: `${clientDuration.toFixed(2)}ms`,
    });

    const cartStartTime = performance.now();
    const wixCartData = await wixClient.createCart(data);
    const cartDuration = performance.now() - cartStartTime;

    log.info("Wix createCart completed", {
      correlationId,
      duration: `${cartDuration.toFixed(2)}ms`,
      hasCartId: !!wixCartData.id,
      hasOrderId: !!(wixCartData as any).order_id,
    });

    // 5. Cache operations
    const cacheStartTime = performance.now();
    await cache.set(
      data.id!,
      JSON.stringify({
        originalRequest: data,
        wixResponse: wixCartData,
      })
    );
    const cacheDuration = performance.now() - cacheStartTime;

    log.info("Cache operation completed", {
      correlationId,
      duration: `${cacheDuration.toFixed(2)}ms`,
      cartId: data.id,
    });

    // 6. Response preparation and metrics
    const finalDuration = performance.now() - overallStartTime;

    log.info("Lambda Function - wix-create-cart - COMPLETED", {
      correlationId,
      totalDuration: `${finalDuration.toFixed(2)}ms`,
      breakdown: {
        secrets: `${secretsDuration.toFixed(2)}ms`,
        auth: `${authDuration.toFixed(2)}ms`,
        validation: `${validationDuration.toFixed(2)}ms`,
        simulator: `${simulatorDuration.toFixed(2)}ms`,
        client: `${clientDuration.toFixed(2)}ms`,
        cart: `${cartDuration.toFixed(2)}ms`,
        cache: `${cacheDuration.toFixed(2)}ms`,
      },
      performance: {
        statusCode: 201,
        hasResult: !!wixCartData,
        cartId: !!wixCartData.id,
      },
    });

    trackSuccessAddCartFireAndForget({
      ...baseMetricParams,
      status: "201",
      duration: finalDuration,
    });

    // Check cart status for Datadog metrics
    let isDatadogSuccess = true;
    if (wixCartData?.status && wixCartData.status === "INCOMPLETE") {
      isDatadogSuccess = false;
      log.warn("Cart status indicates failure despite 201 HTTP status", {
        correlationId,
        httpStatus: 201,
        cartStatus: wixCartData.status,
      });
    }

    if (isDatadogSuccess) {
      trackDatadogSuccessAddCartFireAndForget({
        ...baseMetricParams,
        env: process.env.APP_ENV || "unknown",
        status: "201",
        duration: finalDuration,
      });
    } else {
      trackDatadogFailedAddCartFireAndForget({
        ...baseMetricParams,
        env: process.env.APP_ENV || "unknown",
        status: "201",
      });
    }

    sendAddCartSuccessAlarmMetricFireAndForget({
      orchestrator: baseMetricParams.orchestrator,
    });

    return {
      statusCode: 201,
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(wixCartData),
    };
  } catch (error) {
    const [apiError, errorResponse] = convertErrorToLambdaResponse(error, event);
    logAPIResponseError(log, apiError);

    const errorDuration = performance.now() - overallStartTime;

    log.info("Lambda Function - wix-create-cart - FAILED", {
      correlationId,
      totalDuration: `${errorDuration.toFixed(2)}ms`,
      statusCode: errorResponse.statusCode,
      errorType: apiError.constructor.name,
      errorMessage: apiError.message,
    });

    trackFailedAddCartFireAndForget({
      ...baseMetricParams,
      status: errorResponse.statusCode.toString(),
    });

    trackDatadogFailedAddCartFireAndForget({
      ...baseMetricParams,
      env: process.env.APP_ENV || "unknown",
      status: errorResponse.statusCode.toString(),
    });

    sendAddCartFailureAlarmMetricFireAndForget({
      orchestrator: baseMetricParams.orchestrator,
    });

    return errorResponse;
  } finally {
    // Only stop simulator if it was started (not in production)
    if (!isProduction()) {
      stopSimulator();
    }
  }
};


exports.handler = wrapHandlerWithTracing(handler);
