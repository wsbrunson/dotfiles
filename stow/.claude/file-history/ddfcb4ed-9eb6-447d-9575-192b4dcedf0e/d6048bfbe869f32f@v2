import { InternalServerError } from "../errors";
import { Logger } from "../logger/logger";
import {
  PayPalCreateOrderRequest,
  PayPalOrderResponse,
  PayPalTokenResponse,
  PayPalUpdateOrderRequest,
} from "./paypalTestSchema";
import { SecretsManagerHelper } from "./SecretsManagerHelper";

type PayPalAPISecrets = {
  clientId: string;
  clientSecret: string;
  host: string;
};

export class PayPalOrderManager {
  log: Logger;
  secrets: PayPalAPISecrets;
  accessToken: string = "";

  constructor({ log, secrets }: { log: Logger; secrets: PayPalAPISecrets }) {
    this.log = log;
    this.secrets = secrets;
  }

  static async getPayPalAPISecrets(): Promise<PayPalAPISecrets> {
    if (!process.env.MOCK_SECRET_PATH) {
      throw new Error("SECRET_PATH environment variable is not defined.");
    }

    const secretPath = process.env.MOCK_SECRET_PATH;
    const secretsManager = SecretsManagerHelper.getInstance();

    try {
      const secrets = await secretsManager.getSecret(secretPath);
      const mock = JSON.parse(secrets.mock || "{}");

      if (!mock.client_id || !mock.client_secret) {
        throw new Error(
          `Missing PayPal credentials in secret at ${secretPath}. client_id: ${!!mock.client_id}, client_secret: ${!!mock.client_secret}`
        );
      }

      return {
        clientId: mock.client_id,
        clientSecret: mock.client_secret,
        host: mock.hostname,
      };
    } catch {
      throw new Error(
        "Failed to retrieve secrets to connect to PayPal Orders API"
      );
    }
  }

  async getAccessToken(): Promise<void> {
    if (this.accessToken) {
      return;
    }

    const credentials = btoa(
      `${this.secrets.clientId}:${this.secrets.clientSecret}`
    );
    const authHeader = `Basic ${credentials}`;

    const requestBody = new URLSearchParams({
      grant_type: "client_credentials",
    });

    const response = await fetch(`${this.secrets.host}/v1/oauth2/token`, {
      method: "POST",
      headers: {
        Accept: "application/json",
        "Accept-Language": "en_US",
        "Content-Type": "application/x-www-form-urlencoded",
        Authorization: authHeader,
      },
      body: requestBody.toString(),
    });

    if (!response.ok) {
      let correlationId = "";
      let errorDetails;

      try {
        correlationId = response.headers.get("paypal-debug-id") || "";
        errorDetails = await response.json();
      } catch {
        // If we can't parse the response, just log what we can
      }

      this.log.error(`Error fetching access token - debug_id: ${correlationId}`);

      if (errorDetails) {
        this.log.error(
          `name: ${errorDetails.name}, issue: ${errorDetails.details?.[0]?.issue}, description: ${errorDetails.details?.[0]?.description}`,
        );
      }

      throw new InternalServerError("unknown", {
        details: [{ description: "Failed to obtain PayPal access token" }],
      });
    }

    const responseData = await response.json();
    const { access_token } = responseData as PayPalTokenResponse;

    this.accessToken = access_token;
  }

  async createOrder(orderRequest: PayPalCreateOrderRequest) {
    if (!this.accessToken) {
      await this.getAccessToken();
    }

    const response = await fetch(`${this.secrets.host}/v2/checkout/orders`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${this.accessToken}`,
        Accept: "application/json",
        Prefer: "return=representation",
      },
      body: JSON.stringify(orderRequest),
    });

    if (!response.ok) {
      let correlationId = "";
      let errorDetails;

      try {
        correlationId = response.headers.get("paypal-debug-id") || "";
        errorDetails = await response.json();
      } catch {
        // If we can't parse the response, just log what we can
      }

      this.log.error(`Error creating order - debug_id: ${correlationId}`);

      if (errorDetails) {
        this.log.error(
          `name: ${errorDetails.name}, issue: ${errorDetails.details?.[0]?.issue}, description: ${errorDetails.details?.[0]?.description}`,
        );
      }

      throw new InternalServerError("unknown", {
        details: [{ description: "Failed to create PayPal order" }],
      });
    }

    const responseData = await response.json();

    return responseData as PayPalOrderResponse;
  }

  async updateOrder(updateRequest: PayPalUpdateOrderRequest) {
    if (!this.accessToken) {
      await this.getAccessToken();
    }

    const { orderId, operations } = updateRequest;

    const response = await fetch(
      `${this.secrets.host}/v2/checkout/orders/${orderId}`,
      {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${this.accessToken}`,
          Accept: "application/json",
        },
        body: JSON.stringify(operations),
      }
    );

    if (!response.ok) {
      let correlationId = "";
      let errorDetails;

      try {
        correlationId = response.headers.get("paypal-debug-id") || "";
        errorDetails = await response.json();
      } catch {
        // If we can't parse the response, just log what we can
      }

      this.log.error(
        `Error updating order - debug_id: ${correlationId}, token: ${orderId}`,
      );

      if (errorDetails) {
        this.log.error(
          `name: ${errorDetails.name}, issue: ${errorDetails.details?.[0]?.issue}, description: ${errorDetails.details?.[0]?.description}`,
        );
      }

      throw new InternalServerError("unknown", {
        details: [{ description: "Failed to update PayPal order" }],
      });
    }
  }

  async getOrder(orderId: string) {
    if (!this.accessToken) {
      await this.getAccessToken();
    }
    const response = await fetch(
      `${this.secrets.host}/v2/checkout/orders/${orderId}`,
      {
        method: "GET",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${this.accessToken}`,
          Accept: "application/json",
        },
      }
    );

    if (!response.ok) {
      let correlationId = "";
      let errorDetails;

      try {
        correlationId = response.headers.get("paypal-debug-id") || "";
        errorDetails = await response.json();
      } catch {
        // If we can't parse the response, just log what we can
      }

      this.log.error(
        `Error fetching order - debug_id: ${correlationId}, token: ${orderId}`,
      );

      if (errorDetails) {
        this.log.error(
          `name: ${errorDetails.name}, issue: ${errorDetails.details?.[0]?.issue}, description: ${errorDetails.details?.[0]?.description}`,
        );
      }

      throw new InternalServerError("unknown", {
        details: [{ description: "Failed to fetch PayPal order" }],
      });
    }

    const order = await response.json();

    return order as PayPalOrderResponse;
  }

  async captureOrder(orderId: string) {
    if (!this.accessToken) {
      await this.getAccessToken();
    }

    const response = await fetch(
      `${this.secrets.host}/v2/checkout/orders/${orderId}/capture`,
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${this.accessToken}`,
          Accept: "application/json",
          Prefer: "return=representation",
        },
        body: JSON.stringify({}),
      }
    );

    if (!response.ok) {
      let correlationId = "";
      let errorDetails;

      try {
        correlationId = response.headers.get("paypal-debug-id") || "";
        errorDetails = await response.json();
      } catch {
        // If we can't parse the response, just log what we can
      }

      this.log.error(
        `Error capturing order - debug_id: ${correlationId}, token: ${orderId}`,
      );

      if (errorDetails) {
        this.log.error(
          `name: ${errorDetails.name}, issue: ${errorDetails.details?.[0]?.issue}, description: ${errorDetails.details?.[0]?.description}`,
        );
      }

      throw new InternalServerError("unknown", {
        details: [{ description: "Failed to capture PayPal order" }],
      });
    }

    const captureResponse = await response.json();

    return captureResponse as PayPalOrderResponse;
  }
}
