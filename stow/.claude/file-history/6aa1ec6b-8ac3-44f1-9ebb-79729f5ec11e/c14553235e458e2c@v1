import { createMiddleware } from "hono/factory";
import {
  httpRequestInit,
  httpRequestSuccess,
  httpRequestError,
  commerceOrchestratorRequestInit,
  commerceOrchestratorRequestSuccess,
  commerceOrchestratorRequestError,
  type HttpRequestMetrics,
  type CommerceOrchestratorMetrics,
} from "../metrics/httpMetrics";

export function httpMetricsMiddleware(params: {
  orchestrator: string;
  merchant?: string;
  partner?: string;
}) {
  return createMiddleware(async (c, next) => {
    const httpMetrics = httpRequestInit({ c });
    const commerceMetrics = commerceOrchestratorRequestInit({
      orchestrator: params.orchestrator,
      merchant: params.merchant,
      partner: params.partner,
    });

    c.set("requestMetrics", httpMetrics);
    c.set("commerceMetrics", commerceMetrics);

    try {
      await next();
      httpRequestSuccess({ metrics: httpMetrics, statusCode: c.res.status });
      commerceOrchestratorRequestSuccess({ metrics: commerceMetrics, statusCode: c.res.status });
    } catch (error) {
      httpRequestError({ metrics: httpMetrics, error });
      commerceOrchestratorRequestError({ metrics: commerceMetrics, error });
      throw error;
    }
  });
}

declare module "hono" {
  interface ContextVariableMap {
    requestMetrics: HttpRequestMetrics;
    commerceMetrics: CommerceOrchestratorMetrics;
  }
}
