class PayPalApiError extends Error {
  constructor(
    message: string,
    public statusCode: number,
    public errorResponse?: PayPalErrorResponse
  ) {
    super(message);
    this.name = "PayPalApiError";
  }
}

// Function to generate random amount between $25 and $100
const generateRandomAmount = (): number => {
  return Math.round((Math.random() * (100 - 25) + 25) * 100) / 100; // Ensures two decimal places
};

