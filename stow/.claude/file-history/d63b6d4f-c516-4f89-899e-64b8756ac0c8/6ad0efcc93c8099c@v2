import { describe, it, expect } from "vitest";
import { performMask } from "./maskPii";

describe("performMask behavior analysis", () => {
  it("should demonstrate the actual behavior vs expected behavior", () => {
    console.log("\n=== ANALYZING performMask FUNCTION BEHAVIOR ===\n");

    // Test 1: Allowed key with object value
    console.log("TEST 1: Allowed key with object value");
    const test1 = { productId: { id: "123", name: "Product" } };
    const result1 = performMask(JSON.parse(JSON.stringify(test1)));
    console.log("Input:", JSON.stringify(test1));
    console.log("Output:", JSON.stringify(result1));
    console.log("✓ WORKS: Recursively processes object, keeps allowed keys\n");

    // Test 2: Array with objects
    console.log("TEST 2: Array with objects");
    const test2 = {
      items: [
        { productId: "123", price: 10.99 },
        { id: "456", secret: "hidden" }
      ]
    };
    const result2 = performMask(JSON.parse(JSON.stringify(test2)));
    console.log("Input:", JSON.stringify(test2));
    console.log("Output:", JSON.stringify(result2));
    console.log("✓ WORKS: Array items get processed correctly\n");

    // Test 3: Date handling in arrays
    console.log("TEST 3: Date handling in arrays");
    const testDate = new Date("2023-01-01");
    const test3 = { data: ["string", 123, testDate, { nested: "object" }] };
    const result3 = performMask(JSON.parse(JSON.stringify(test3)));
    console.log("Input:", JSON.stringify(test3));
    console.log("Output:", JSON.stringify(result3));
    console.log("Note: Date gets converted to string in JSON.stringify\n");

    // Test 4: The logic condition issue
    console.log("TEST 4: Checking the masking condition logic");
    const test4 = {
      productId: "123",        // Allowed key + allowed value = should keep
      productId2: new Date(),  // Allowed key + non-primitive = should mask? or recurse?
      badKey: "value",         // Not allowed key + allowed value = should mask
      badKey2: new Date(),     // Not allowed key + non-primitive = should mask
    };
    const result4 = performMask(JSON.parse(JSON.stringify(test4)));
    console.log("Input:", JSON.stringify(test4));
    console.log("Output:", JSON.stringify(result4));
    console.log("Analysis of line 238 condition: !isAllowedKey(key) || !isAllowedValue(value)");
    console.log("- productId: allowed key + string value = false || false = false (no mask) ✓");
    console.log("- productId2: allowed key + date = false || true = true (MASK) - Is this right?");
    console.log("- badKey: not allowed + string = true || false = true (mask) ✓");
    console.log("- badKey2: not allowed + date = true || true = true (mask) ✓\n");

    // Test 5: Null/undefined handling
    console.log("TEST 5: Null/undefined with allowed vs non-allowed keys");
    const test5 = {
      productId: null,     // Allowed key + null
      badKey: null,        // Not allowed key + null
      variantId: undefined, // Allowed key + undefined
      badKey2: undefined,   // Not allowed key + undefined
    };
    const result5 = performMask(JSON.parse(JSON.stringify(test5)));
    console.log("Input:", JSON.stringify(test5));
    console.log("Output:", JSON.stringify(result5));

    // The actual assertions to verify behavior
    expect(result1.productId).toEqual({ id: "123", name: "Product" });
    expect(result2.items[0].productId).toBe("123");
    expect(result2.items[0].price).toBe("**********");
    expect(result5.productId).toBeNull();
    expect(result5.badKey).toBe("**********");
  });

  it("should identify the specific logic issue", () => {
    console.log("\n=== LOGIC ISSUE ANALYSIS ===\n");

    // The problematic condition: !isAllowedKey(key) || !isAllowedValue(value)
    // This means: mask if (key not allowed) OR (value not primitive)

    const cases = [
      { key: "productId", value: "123", keyAllowed: true, valueAllowed: true },
      { key: "productId", value: new Date(), keyAllowed: true, valueAllowed: false },
      { key: "secret", value: "123", keyAllowed: false, valueAllowed: true },
      { key: "secret", value: new Date(), keyAllowed: false, valueAllowed: false },
    ];

    console.log("Current logic: !isAllowedKey(key) || !isAllowedValue(value)");
    console.log("Key\t\tValue\t\tKeyOK\tValueOK\tCondition\tResult");
    console.log("-----------------------------------------------------------");

    cases.forEach(({ key, value, keyAllowed, valueAllowed }) => {
      const condition = !keyAllowed || !valueAllowed;
      const result = condition ? "MASK" : "KEEP";
      console.log(`${key.padEnd(12)}\t${typeof value}\t${keyAllowed}\t${valueAllowed}\t${condition}\t\t${result}`);
    });

    console.log("\nISSUE: Row 2 shows allowed key with non-primitive value gets masked!");
    console.log("EXPECTED: Allowed key with object should recurse, not mask");
  });
});