import { Context, Hono } from "hono";
import { logger } from "shared/logger/logger";
import { auth } from "shared/middleware/auth";
import { datadogTracing } from "shared/middleware/datadogTracing";
import { ALBEvent } from "aws-lambda";
import {
  completeCheckoutRequestSchema,
  payPalCartSchema,
} from "shared/schemas/openapi-schemas";
import { StatusCode } from "hono/utils/http-status";
import { requestLogger } from "shared/middleware/requestLogger";
import { parseRequestBodyWithZod } from "shared/middleware/parseRequestBodyWithZod";
import { cartMetrics } from "shared/middleware/cartMetrics";
import { createErrorHandler } from "shared/handlers/createErrorHandler";
import { paymentMetrics } from "shared/middleware/paymentMetrics";
import { updateCartMetrics } from "shared/middleware/updateCartMetric";
import { getCacheImplementation } from "shared/cache/cacheFactory";
import {
  datadogCartMetrics,
  datadogUpdateCartMetrics,
  datadogPaymentMetrics,
} from "shared/middleware/datadogMetrics";
import type {
  CompleteCheckoutRequest,
  PayPalCart,
} from "shared/schemas/openapi-schemas";
import { BigCommerceController } from "./services/controllers";
import {
  createCartSimulator,
  updateCartSimulator,
  completeCartSimulator,
} from "shared/middleware/simulator";

const log = logger("BigCommerce");
const app = new Hono();
const cache = getCacheImplementation();
const bigCommerceController = new BigCommerceController({ cache, log });

app.use(
  "*",
  datadogTracing("bigcommerce"),
  requestLogger({ type: "big-commerce" }),
  auth,
);

const BASE_PATH = "/commerceorchnodeserv/v2/bigcommerce";

app.post(
  `${BASE_PATH}/cart`,
  parseRequestBodyWithZod({ schema: payPalCartSchema }),
  cartMetrics({ orchestrator: "BigCommerce" }),
  datadogCartMetrics({ orchestrator: "BigCommerce" }),
  createCartSimulator("bigc", (data) => data.items?.[0]?.item_url),
  async (c: Context) => {
    const event = c.env.event as unknown as ALBEvent;
    const data: PayPalCart = c.get("data");
    const cartData = await bigCommerceController.createCart({
      data: data,
      request: event,
    });
    c.status(201 as StatusCode);
    return c.json(cartData);
  },
);

app.onError(createErrorHandler("BigCommerce"));

app.post(
  `${BASE_PATH}/cart/:cartId/complete`,
  parseRequestBodyWithZod({ schema: completeCheckoutRequestSchema }),
  paymentMetrics({ orchestrator: "BigCommerce" }),
  datadogPaymentMetrics({ orchestrator: "BigCommerce" }),
  completeCartSimulator("bigc"),
  async (c: Context) => {
    const event = c.env.event as unknown as ALBEvent;
    const data: CompleteCheckoutRequest = c.get("data");
    const cartId = c.req.param("cartId");
    const completeCart = await bigCommerceController.completeCart({
      cartId: cartId,
      data: data,
      request: event,
    });
    c.status(201 as StatusCode);
    return c.json(completeCart);
  },
);

app.put(
  `${BASE_PATH}/cart/:cartId`,
  parseRequestBodyWithZod({ schema: payPalCartSchema }),
  updateCartMetrics({ orchestrator: "BigCommerce" }),
  updateCartSimulator("bigc"),
  datadogUpdateCartMetrics({ orchestrator: "BigCommerce" }),
  async (c: Context) => {
    const event = c.env.event as unknown as ALBEvent;
    const cartId = c.req.param("cartId");
    const data: PayPalCart = c.get("data");

    // Ensure the payload cart ID is matching with the one in url
    const dataWithCartId = { ...data, id: cartId };

    const updateCart = await bigCommerceController.updateCart({
      data: dataWithCartId,
      request: event,
    });
    c.status(200 as StatusCode);
    return c.json(updateCart);
  },
);

export { app };
