const log = logger("PayPalTestOrder");

async function getPayPalOrdersSecrets(): Promise<{
  clientId: string;
  clientSecret: string;
  host: string;
}> {
  if (!process.env.MOCK_SECRET_PATH) {
    throw new Error("SECRET_PATH environment variable is not defined.");
  }

  const secretPath = process.env.MOCK_SECRET_PATH;
  const secretsManager = SecretsManagerHelper.getInstance();

  try {
    const secrets = await secretsManager.getSecret(secretPath);
    log.info("Retrieved secrets", { secretPath, hasSecret: !!secrets });

    const mock = JSON.parse(secrets.mock || "{}");
    log.info("Parsed mock config", {
      hasMock: !!secrets.mock,
      hasClientId: !!mock.client_id,
      hasClientSecret: !!mock.client_secret,
      hasHostname: !!mock.hostname
    });

    if (!mock.client_id || !mock.client_secret) {
      throw new Error(`Missing PayPal credentials in secret at ${secretPath}. client_id: ${!!mock.client_id}, client_secret: ${!!mock.client_secret}`);
    }

    return {
      clientId: mock.client_id,
      clientSecret: mock.client_secret,
      host: mock.hostname,
    };
  } catch (error) {
    log.error("Failed to get PayPal secrets", { secretPath, error });
    throw new InternalServerError("unknown", {
      details: [
        {
          description:
            "Failed to retrieve secrets to connect to PayPal Orders API",
        },
      ],
    });
  }
}

