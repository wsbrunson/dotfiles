resource "aws_security_group" "hello_world_SG" {
  name        = "${local.app_name}-hello-world"
  description = "Security group to allow hello-world to connect to Elasticache"
  vpc_id      = data.aws_vpc.current.id
  tags        = local.default_tags
}

resource "aws_security_group_rule" "allow_all_outbound_tcp" {
  type              = "egress"
  from_port         = 443
  to_port           = 65535
  protocol          = "tcp"
  cidr_blocks       = ["0.0.0.0/0"]
  security_group_id = aws_security_group.hello_world_SG.id
}

