import { describe, test, expect } from "vitest";
import { performMask } from "./maskPii";

describe("performMask", () => {
  test.each([
    {
      input: { maskedKey: "can't see me", unmaskedKey: "visible" },
      output: { maskedKey: "**********", unmaskedKey: "visible" },
      case: "masks sensitive key and preserves allowed key",
    },
    {
      input: { maskedKey: "secret string" },
      output: { maskedKey: "**********" },
      case: "masks string primitive",
    },
    {
      input: { maskedKey: 12345 },
      output: { maskedKey: "**********" },
      case: "masks number primitive",
    },
    {
      input: { maskedKey: true },
      output: { maskedKey: "**********" },
      case: "masks boolean primitive",
    },
    {
      input: { maskedKey: null },
      output: { maskedKey: "**********" },
      case: "masks null primitive",
    },
    {
      input: { maskedKey: undefined },
      output: { maskedKey: "**********" },
      case: "masks undefined primitive",
    },
    {
      input: { unmaskedKey: "visible string" },
      output: { unmaskedKey: "visible string" },
      case: "preserves string primitive",
    },
    {
      input: { unmaskedKey: 67890 },
      output: { unmaskedKey: 67890 },
      case: "preserves number primitive",
    },
    {
      input: { unmaskedKey: false },
      output: { unmaskedKey: false },
      case: "preserves boolean primitive",
    },
    {
      input: { unmaskedKey: null },
      output: { unmaskedKey: null },
      case: "preserves null primitive",
    },
    {
      input: { unmaskedKey: undefined },
      output: { unmaskedKey: undefined },
      case: "preserves undefined primitive",
    },
    {
      input: {
        maskedKey: "secret",
        nested: {
          unmaskedKey: "visible",
          maskedKey: "hidden",
        },
      },
      output: {
        maskedKey: "**********",
        nested: {
          unmaskedKey: "visible",
          maskedKey: "**********",
        },
      },
      case: "handles 2-level deep nested object with mixed keys",
    },
    {
      input: {
        unmaskedKey: "level0-visible",
        level1: {
          maskedKey: "level1-secret",
          level2: {
            unmaskedKey: "level2-visible",
            level3: {
              maskedKey: "level3-secret",
              level4: {
                unmaskedKey: "level4-visible",
                level5: {
                  maskedKey: "level5-secret",
                  unmaskedKey: "level5-visible",
                },
              },
            },
          },
        },
      },
      output: {
        unmaskedKey: "level0-visible",
        level1: {
          maskedKey: "**********",
          level2: {
            unmaskedKey: "level2-visible",
            level3: {
              maskedKey: "**********",
              level4: {
                unmaskedKey: "level4-visible",
                level5: {
                  maskedKey: "**********",
                  unmaskedKey: "level5-visible",
                },
              },
            },
          },
        },
      },
      case: "handles 5-level deep nested object with mixed keys",
    },
    {
      input: {
        maskedKey: new Error("secret error message"),
        unmaskedKey: new Error("visible error message"),
      },
      output: {
        maskedKey: "**********",
        unmaskedKey: new Error("visible error message"),
      },
      case: "handles Error class objects",
    },
    {
      input: (() => {
        class CircularClass {
          public maskedKey: string;
          public unmaskedKey: string;
          public self?: CircularClass;

          constructor(masked: string, unmasked: string) {
            this.maskedKey = masked;
            this.unmaskedKey = unmasked;
            this.self = this; // Create circular reference
          }
        }

        const circular = new CircularClass("secret", "visible");
        return {
          maskedKey: "top-level-secret",
          circularObject: circular,
        };
      })(),
      output: {
        maskedKey: "**********",
        circularObject: {
          maskedKey: "**********",
          unmaskedKey: "visible",
          self: {
            __circular__: true,
            type: "CircularClass",
          },
        },
      },
      case: "handles class with circular reference",
    },
    {
      input: {
        mixedArray: [
          "primitive",
          { maskedKey: "secret", unmaskedKey: "visible" },
          42,
          { nested: { maskedKey: "hidden" } }
        ]
      },
      output: {
        mixedArray: [
          "primitive",
          { maskedKey: "**********", unmaskedKey: "visible" },
          42,
          { nested: { maskedKey: "**********" } }
        ]
      },
      case: "handles mixed arrays with primitives and objects",
    },
    {
      input: {
        nestedArray: [[{ maskedKey: "secret" }], [{ unmaskedKey: "visible" }]]
      },
      output: {
        nestedArray: [[{ maskedKey: "**********" }], [{ unmaskedKey: "visible" }]]
      },
      case: "handles nested arrays",
    },
    {
      input: (() => {
        const arr = [{ maskedKey: "secret" }];
        arr.push(arr);
        return { circularArray: arr };
      })(),
      output: {
        circularArray: [
          { maskedKey: "**********" },
          { __circular__: true, type: "Array" }
        ]
      },
      case: "handles array circular references",
    },
    {
      input: {
        maskedKey: new Date("2023-01-01"),
        unmaskedKey: new Date("2023-12-31")
      },
      output: {
        maskedKey: "**********",
        unmaskedKey: new Date("2023-12-31")
      },
      case: "handles Date objects",
    },
    {
      input: {
        maskedKey: function() { return "secret"; },
        unmaskedKey: () => "visible"
      },
      output: {
        maskedKey: "**********",
        unmaskedKey: expect.any(Function)
      },
      case: "handles Function objects",
    },
    {
      input: (() => {
        const level1 = { maskedKey: "level1-secret" };
        const level2 = { unmaskedKey: "level2-visible", parent: level1 };
        const level3 = { maskedKey: "level3-secret", parent: level2 };
        const level4 = { unmaskedKey: "level4-visible", parent: level3 };
        level1.deep = level4;
        return { root: level1 };
      })(),
      output: {
        root: {
          maskedKey: "**********",
          deep: {
            unmaskedKey: "level4-visible",
            parent: {
              maskedKey: "**********",
              parent: {
                unmaskedKey: "level2-visible",
                parent: { __circular__: true, type: "Object" }
              }
            }
          }
        }
      },
      case: "handles deep circular references (4 levels)",
    },
    {
      input: (() => {
        const nullProtoObj = Object.create(null);
        nullProtoObj.maskedKey = "secret";
        nullProtoObj.unmaskedKey = "visible";
        return { nullProto: nullProtoObj };
      })(),
      output: {
        nullProto: {
          maskedKey: "**********",
          unmaskedKey: "visible"
        }
      },
      case: "handles Object.create(null) objects",
    },
  ])("$case", ({ input, output }) => {
    expect(performMask(input)).toEqual(output);
  });
});
