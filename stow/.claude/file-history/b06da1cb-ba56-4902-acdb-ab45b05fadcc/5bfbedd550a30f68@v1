// ── Import SUT AFTER mocks ──
import { cartMetrics } from './cartMetrics'
import { trackInitiatedAddCartFireAndForget, trackSuccessAddCartFireAndForget } from 'shared/metrics/emitMetric'
import { sendAddCartInitiatedAlarmMetricFireAndForget, sendAddCartSuccessAlarmMetricFireAndForget } from 'shared/metrics/alarm-metrics'

// ── Helpers ──
function makeAlbEvent(overrides?: Partial<ALBEvent>): ALBEvent {
  return {
    httpMethod: 'POST',
    path: '/commerceorchnodeserv/v2/shopify/cart',
    headers: {},
    multiValueHeaders: {},
    queryStringParameters: null,
    multiValueQueryStringParameters: null,
    body: null,
    isBase64Encoded: false,
    requestContext: { elb: { targetGroupArn: 'arn:aws:elasticloadbalancing:xx:acct:tg/name/id' } },
    ...overrides,
  } as any
}

function makeCtx(opts?: {
  debugId?: string
  start?: number
  merchantUrl?: string | undefined
  event?: Partial<ALBEvent>
}): Context {
  const map = new Map<string, any>([
    ['debugId', opts?.debugId ?? 'dbg-123'],
    ['overallStartTime', opts?.start ?? 1000],
    ['data', opts?.merchantUrl !== undefined ? { merchantUrl: opts.merchantUrl } : undefined],
  ])
  const c = {
    env: { event: makeAlbEvent(opts?.event) },
    get: (k: string) => map.get(k),
    res: undefined as unknown, // will be set by the handler
  } as unknown as Context
  return c
}

async function runMiddlewareWithResponseStatus(
  status: number,
  c: Context,
  body: any = { ok: true },
  headers: Record<string, string> = { 'content-type': 'application/json' }
) {
  const next: Next = async () => {
    ;(c as any).res = new Response(
      headers['content-type']?.includes('application/json') ? JSON.stringify(body) : String(body),
      { status, headers }
    )
  }
  const mw = cartMetrics({ orchestrator: 'Shopify' })
  await mw(c, next)
}

describe('cartMetrics middleware', () => {
  beforeEach(() => {
    vi.clearAllMocks()
    // Make duration deterministic: performance.now() - overallStartTime
    vi.spyOn(performance, 'now').mockReturnValue(1500)
  })

  it('emits initiated + success metrics and logs on 2xx', async () => {
    const c = makeCtx({ start: 1000, merchantUrl: 'https://merchant.example' })
    await runMiddlewareWithResponseStatus(201, c)

    // Initiated metrics fired
    expect(sendAddCartInitiatedAlarmMetricFireAndForget).toHaveBeenCalledWith({ orchestrator: 'Shopify' })
    expect(trackInitiatedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: 'https://merchant.example',
    })

    // Success metrics fired
    expect(sendAddCartSuccessAlarmMetricFireAndForget).toHaveBeenCalledWith({ orchestrator: 'Shopify' })
    expect(trackSuccessAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: 'https://merchant.example',
      status: '201',                 // middleware hardcodes '201'
      duration: 500,                 // 1500 - 1000
    })

  })

  it('does NOT emit success metrics on non-2xx (e.g., 422) but still emits initiated metrics', async () => {
    const c = makeCtx({ merchantUrl: 'https://merchant.example' })
    await runMiddlewareWithResponseStatus(422, c, { error: 'failed' })

    // Initiated still fired
    expect(sendAddCartInitiatedAlarmMetricFireAndForget).toHaveBeenCalledWith({ orchestrator: 'Shopify' })
    expect(trackInitiatedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: 'https://merchant.example',
    })

    // Success should NOT fire
    expect(sendAddCartSuccessAlarmMetricFireAndForget).not.toHaveBeenCalled()
    expect(trackSuccessAddCartFireAndForget).not.toHaveBeenCalled()
  })

  it('defaults merchantUrl to empty string when missing', async () => {
    const c = makeCtx({ merchantUrl: undefined })
    await runMiddlewareWithResponseStatus(201, c)

    expect(trackInitiatedAddCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: 'Shopify',
      merchantUrl: '',            // fallback
    })
    expect(trackSuccessAddCartFireAndForget).toHaveBeenCalledWith(
      expect.objectContaining({ merchantUrl: '' })
    )
  })
})
