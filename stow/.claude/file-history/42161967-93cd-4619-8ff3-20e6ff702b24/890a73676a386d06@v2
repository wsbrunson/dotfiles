export type SimMode = "off" | "replay" | "bypass";
const log = logger("Simulator server");

let server: ReturnType<typeof setupServer> | null = null;

function logEvent(eventName: string, req: any) {
  try {
    if (req?.headers && typeof req.headers.entries === "function") {
      const headersObj = Object.fromEntries(req.headers.entries());
      log.info(`EventName: ${eventName} Request Headers:`, headersObj);
    } else if (req?.headers && typeof req.headers === "object") {
      // Handle case where headers is a plain object
      log.info(`EventName: ${eventName} Request Headers:`, req.headers);
    } else {
      log.info(`EventName: ${eventName} Request Headers: No headers available`);
    }
  } catch (e) {
    log.error("Error logging event:", {
      error: e,
      eventName,
      requestType: typeof req,
    });
  }
  log.info(`EventName: ${eventName} Request:`, req?.url || req);
}

/**
 * Extracts the email from different types of simulation contexts
 * @param context - The simulation context
 * @returns The email address if found, undefined otherwise
 */
function getEmailFromContext(
  context: SimContext | SimContextV2,
): string | undefined {
  // Handle v2 context
  if ("platformBaseUrl" in context) {
    return context.data.customer?.email_address;
  }

  // Handle v1 context
  if (context.type === "create" && context.data.customer) {
    return context.data.customer.email;
  }

  if (
    context.type === "update" &&
    context.data.cart &&
    context.data.cart.customer
  ) {
    return context.data.cart.customer.email;
  }

  // CompleteCartRequest doesn't have a customer field in its schema
  // If we need to access customer email for complete requests, we'd need to
  // modify the schema or store it elsewhere

  return undefined;
}

const shouldBypassSimulation = ({
  headers,
  email,
  logger,
}: {
  headers: Record<string, string> | undefined;
  email: string;
  logger: Logger;
}): boolean => {
  const isTestEnv = process.env.APP_ENV === "test";
  const simulationHeader =
    headers?.["PayPal-Commerce-Simulation"] ||
    headers?.["paypal-commerce-simulation"];
  const isSimulationHeaderFalse = simulationHeader?.toLowerCase() === "false";
  const isSimulationBypassEmail = email === "anthony@paypal.com";

  const shouldBypass =
    !isTestEnv || isSimulationHeaderFalse || isSimulationBypassEmail;

  if (shouldBypass) {
    logger.info("Simulator bypassed - conditions not met", {
      isTestEnv,
      isSimulationHeaderFalse,
      isSimulationBypassEmail,
    });
  }

  return shouldBypass;
};

async function dispatchShopifyHandlers(ctx: ShopifySimContext): Promise<any[]> {
  if (ctx.type === "complete") {
    return shopifyCompleteHandlers(ctx);
  }

  if (ctx.type === "create") {
    return shopifyCreateHandlers(ctx);
  }

  if (ctx.type === "update") {
    return shopifyUpdateCartHandlers(ctx);
  }

  // If no matching context type is found, throw an error
  throw new Error("Unsupported ShopifySimContext type");
}

async function dispatchBigCommerceHandlers(
  ctx: BigCommerceSimContext,
): Promise<any[]> {
  log.info("Dispatching BigCommerce Handlers for context type:", {
    contextType: ctx.type,
  });
  if (ctx.type === "complete") {
    return bigCommerceCompleteHandlers(ctx);
  }

  if (ctx.type === "create") {
    return bigCommerceCreateHandlers(ctx);
  }

  if (ctx.type === "update") {
    return bigCommerceUpdateHandlers(ctx);
  }

  // If no matching context type is found, throw an error
  throw new Error("Unsupported BigCommerceSimContext type");
}

async function dispatchWixHandlers(ctx: any): Promise<any[]> {
  // For now, return wixHandlers directly as they don't seem to be separated by type
  return wixHandlers(ctx);
}
async function dispatchFirmlyHandlers(ctx: any): Promise<any[]> {
  return firmlyHandlers(ctx);
}

async function dispatchGenericHandlers(ctx: SimContextV2): Promise<any[]> {
  log.info("Dispatching Generic Handlers for context:", { ctx });
  return genericHandlers(ctx);
}

async function dispatchAdoramaHandlers(ctx: AdoramaSimContext): Promise<any[]> {
  log.info("Dispatching Adorama Handlers for context type:", {
    contextType: ctx.type,
  });
  if (ctx.type === "complete") {
    return adoramaCompleteHandlers(ctx);
  }

  if (ctx.type === "create") {
    return adoramaCreateHandlers(ctx);
  }

  if (ctx.type === "update") {
    return adoramaUpdateCartHandlers(ctx);
  }

  // If no matching context type is found, throw an error
  throw new Error("Unsupported AdoramaSimContext type");
}

export async function startSimulator(
  context: SimContext,
  mode: SimMode = "bypass",
): Promise<void> {
  const email = getEmailFromContext(context);
  const shouldBypass = shouldBypassSimulation({
    headers: context.headers,
    email,
    logger: log,
  });

  if (shouldBypass) {
    return;
  }

  // if already running, restart
  if (server) {
    try {
      server.close();
    } catch (error) {
      log.error("Error closing server:", { error });
    }
    server = null;
  }

  let lambdaName: string | undefined;

  // Validate the simulation scenario based on the context type
  if (email) {
    // Determine the lambda name from the context type
    if (context.type === "create") {
      lambdaName = `${context.orchestrator}-create-cart`;

      // First check if this is a valid simulation pattern (regardless of flow)
      const errorId = getErrorIdFromEmail(email);

      if (errorId) {
        // If it's a valid simulation pattern, accept it
        log.info(`Valid simulation pattern detected for ${lambdaName}:`, {
          email,
          errorId,
        });
      } else {
        // If not a valid simulation pattern, run the regular validation
        // This will catch patterns that are marked as not valid for simulation
        let validationResult;
        if (context.orchestrator === "shopify") {
          validationResult = validateForShopifyCreateCart(email);
        } else if (context.orchestrator === "bigcommerce") {
          validationResult = validateForBigCommerceCreateCart(email);
        } else if (context.orchestrator === "adorama") {
          validationResult = validateForAdoramaCreateCart(email);
        } else {
          validationResult = { isValid: true };
        }

        if (!validationResult.isValid && validationResult.pattern) {
          const errorMessage =
            validationResult.message ||
            "Invalid simulation scenario for this lambda";

          log.error(`Invalid simulation scenario for ${lambdaName}:`, {
            email,
            errorDetails: {
              pattern: validationResult.pattern.pattern,
              errorType: validationResult.pattern.id,
              description: validationResult.pattern.description,
            },
          });

          // Throw a BadRequestError (400) instead of a generic Error
          throw new BadRequestError("simulator-validation", {
            message: `Invalid simulation scenario for ${lambdaName}: ${errorMessage}`,
            details: [
              {
                description: errorMessage,
                field: "email",
                issue: "INVALID_SIMULATION_SCENARIO",
              },
            ],
          });
        }
      }
    } else if (context.type === "update") {
      lambdaName = `${context.orchestrator}-update-cart`;

      // First check if this is a valid simulation pattern (regardless of flow)
      const errorId = getErrorIdFromEmail(email);

      if (errorId) {
        // If it's a valid simulation pattern, accept it
        log.info(`Valid simulation pattern detected for ${lambdaName}:`, {
          email,
          errorId,
        });
      } else {
        // If not a valid simulation pattern, run the regular validation
        // This will catch patterns that are marked as not valid for simulation
        let validationResult;
        if (context.orchestrator === "shopify") {
          validationResult = validateForShopifyUpdateCart(email);
        } else if (context.orchestrator === "bigcommerce") {
          validationResult = validateForBigCommerceUpdateCart(email);
        } else if (context.orchestrator === "adorama") {
          validationResult = validateForAdoramaUpdateCart(email);
        } else {
          validationResult = { isValid: true };
        }

        if (!validationResult.isValid && validationResult.pattern) {
          const errorMessage =
            validationResult.message ||
            "Invalid simulation scenario for this lambda";

          log.error(`Invalid simulation scenario for ${lambdaName}:`, {
            email,
            errorDetails: {
              pattern: validationResult.pattern.pattern,
              errorType: validationResult.pattern.id,
              description: validationResult.pattern.description,
            },
          });

          // Throw a BadRequestError (400) instead of a generic Error
          throw new BadRequestError("simulator-validation", {
            message: `Invalid simulation scenario for ${lambdaName}: ${errorMessage}`,
            details: [
              {
                description: errorMessage,
                field: "email",
                issue: "INVALID_SIMULATION_SCENARIO",
              },
            ],
          });
        }
      }
    } else if (context.type === "complete") {
      lambdaName = `${context.orchestrator}-complete-cart`;
      // TODO: For future implementation: add validation for complete cart
      // const validationResult = isValidForShopifyCompleteCart(email);
      // if (!validationResult.isValid) { ... }
    }
  }
  let resolvedHandlers: any[] = [];

  // Check which V1 orchestrator we are simulating and dispatch the respective handler
  log.info("Looking to dispatch handlers for orchestrator:", {
    orchestrator: context.orchestrator,
  });
  if (context.orchestrator === "shopify") {
    resolvedHandlers = await dispatchShopifyHandlers(context);
  } else if (context.orchestrator === "bigcommerce") {
    resolvedHandlers = await dispatchBigCommerceHandlers(context);
  } else if (context.orchestrator === "adorama") {
    resolvedHandlers = await dispatchAdoramaHandlers(
      context as AdoramaSimContext,
    );
  }
  server = setupServer(...resolvedHandlers);

  (["request:start", "request:match", "request:unhandled"] as const).forEach(
    (ev) => {
      server!.events.on(ev, (req: any) => logEvent(ev, req));
    },
  );

  server.listen({ onUnhandledRequest: mode === "replay" ? "error" : "bypass" });
  log.info(
    `Simulator started in ${mode} mode with context type: ${context.type}${
      lambdaName ? ` for lambda: ${lambdaName}` : ""
    }.`,
  );
}

export async function startSimulatorV2(
  context: SimContextV2,
  mode: SimMode = "bypass",
): Promise<void> {
  const email = getEmailFromContext(context);
  const shouldBypass = shouldBypassSimulation({
    headers: context.headers,
    email,
    logger: log,
  });

  if (shouldBypass) {
    return;
  }

  // if already running, restart
  if (server) {
    try {
      server.close();
    } catch (error) {
      log.error("Error closing server:", { error });
    }
    server = null;
  }

  let lambdaName: string | undefined;

  // Logging the simulation scenario based on the context type
  if (email) {
    if (context.type === "create") {
      lambdaName = `${context.orchestrator}-create-cart`;
      const errorId = getErrorIdFromEmail(email);
      if (errorId) {
        log.info(`Valid V2 simulation pattern detected for ${lambdaName}:`, {
          email,
          errorId,
        });
      }
    } else if (context.type === "update") {
      lambdaName = `${context.orchestrator}-update-cart`;
      const errorId = getErrorIdFromEmail(email);
      if (errorId) {
        log.info(`Valid V2 simulation pattern detected for ${lambdaName}:`, {
          email,
          errorId,
        });
      }
    } else if (context.type === "complete") {
      lambdaName = `${context.orchestrator}-complete-cart`;
      const errorId = getErrorIdFromEmail(email);
      if (errorId) {
        log.info(`Valid V2 simulation pattern detected for ${lambdaName}:`, {
          email,
          errorId,
        });
      }
    }
  }
  let resolvedHandlers: any[] = [];
  // Check which v2 orchestrator we are simulating ... and dispach the respective handler
  log.info("Looking to dispatch handlers for orchestrator:", {
    orchestrator: context.orchestrator,
  });
  if (context.orchestrator === "wix") {
    resolvedHandlers = await dispatchWixHandlers(context);
  } else if (context.orchestrator.includes("firmly")) {
    resolvedHandlers = await dispatchFirmlyHandlers(context);
  } else if (context.orchestrator === "generic") {
    resolvedHandlers = await dispatchGenericHandlers(context);
  }
  server = setupServer(...resolvedHandlers);

  (["request:start", "request:match", "request:unhandled"] as const).forEach(
    (ev) => {
      server!.events.on(ev, (req: any) => logEvent(ev, req));
    },
  );

  server.listen({ onUnhandledRequest: mode === "replay" ? "error" : "bypass" });
  log.info(
    `V2 Simulator started in ${mode} mode with context type: ${context.type}${
      lambdaName ? ` for lambda: ${lambdaName}` : ""
    }.`,
  );
}

export async function startSimulatorWithHandlers({
  c,
  handlers,
}: {
  c: Context;
  handlers: Parameters<typeof setupServer>;
}): Promise<void> {
  const event = c.env.event as ALBEvent;
  const logger = c.get("logger") as Logger;

  const shouldBypass = shouldBypassSimulation({
    headers: event.headers,
    email: "",
    logger,
  });

  if (shouldBypass) {
    return;
  }

  if (server) {
    try {
      server.close();
    } catch (error) {
      logger.error("simulation error - unable to close existing server", {
        error,
      });
    }
    server = null;
  }

  server = setupServer(...handlers);

  (["request:start", "request:match", "request:unhandled"] as const).forEach(
    (ev) => {
      server!.events.on(ev, (req: any) => logEvent(ev, req));
    },
  );

  server.listen({ onUnhandledRequest: "bypass" });
  logger.info("simulator started");
}

export function stopSimulator(): void {
  if (!server) return;
  try {
    server.close();
    log.info("Simulator stopped.");
  } finally {
    server = null;
  }
}
