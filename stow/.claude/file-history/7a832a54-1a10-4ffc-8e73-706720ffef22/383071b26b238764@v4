import { APIGatewayRequestAuthorizerEventV2, ALBEvent } from "aws-lambda";
import { verifyAppContext } from "shared/helpers/AppContextAuthorizer";
import { logger } from "shared/logger/logger";

const transformToALBEvent = (
  apiGatewayEvent: APIGatewayRequestAuthorizerEventV2,
): ALBEvent => {
  return {
    headers: apiGatewayEvent.headers,
    requestContext: {
      elb: {
        targetGroupArn:
          "arn:aws:elasticloadbalancing:us-west-2:123456789012:targetgroup/api-gateway-authorizer/1234567890123456",
      },
    },
    httpMethod: apiGatewayEvent.requestContext.http.method,
    path: apiGatewayEvent.requestContext.http.path,
    queryStringParameters: {},
    body: "",
    multiValueHeaders: {},
    multiValueQueryStringParameters: {},
    isBase64Encoded: false,
  } as ALBEvent;
};

exports.handler = async (event: APIGatewayRequestAuthorizerEventV2) => {
  const log = logger("AppContextAuthorizer", event);
  const appContext = event.headers?.["paypal-application-context"];
  if (!appContext || appContext.trim().length < 1) {
    log.warn("AppContext is missing");
    throw new Error("Unauthorized");
  }

  try {
    const albCompatibleEvent = transformToALBEvent(event);
    const isAuthorized = verifyAppContext(albCompatibleEvent);

    if (!isAuthorized) {
      throw new Error("Unauthorized");
    }

    return { isAuthorized: true };
  } catch (err) {
    log.error(
      "JWT verification failed",
      err instanceof Error ? err : new Error(String(err)),
    );
    throw new Error("Unauthorized");
  }
};
