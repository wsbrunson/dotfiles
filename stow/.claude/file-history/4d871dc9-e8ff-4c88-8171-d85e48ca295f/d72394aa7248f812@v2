import { describe, it, expect, vi, beforeEach } from "vitest";
import { MockRequestClient } from "./mock-client";
import axios from "axios";

// Mock axios
vi.mock("axios");
const mockedAxios = vi.mocked(axios);

describe("MockRequestClient V1 API Integration", () => {
  let client: MockRequestClient;
  let mockRequest: any;

  beforeEach(() => {
    client = new MockRequestClient();
    mockRequest = {
      log: vi.fn(),
      headers: {
        "x-paypal-security-context": '{"test":"context"}'
      }
    };
    vi.clearAllMocks();
  });

  describe("createEcToken", () => {
    it("should use v1 API when email starts with orders-v1@", async () => {
      const mockCartRequest = {
        cartId: "test-cart-123",
        products: [{ productId: "prod-1", quantity: 1 }],
        customer: { email: "orders-v1@example.com" }
      };

      const mockCart = {
        items: [{
          name: "Test Item",
          sku: "test-sku",
          unit_amount: { currency_code: "USD", value: "19.99" },
          quantity: "1"
        }],
        amount: {
          currency_code: "USD",
          value: "22.04",
          breakdown: {
            item_total: { currency_code: "USD", value: "19.99" },
            tax_total: { currency_code: "USD", value: "2.05" },
            shipping: { currency_code: "USD", value: "0.00" }
          }
        }
      };

      const mockResponse = { data: { id: "v1-cart-id-123" } };
      mockedAxios.post.mockResolvedValue(mockResponse);

      const result = await client.createEcToken({
        cart: mockCart,
        cartRequest: mockCartRequest,
        request: mockRequest,
        accessToken: "test-token",
        hostname: "https://api.paypal.com"
      });

      expect(result).toBe("v1-cart-id-123");
      expect(mockedAxios.post).toHaveBeenCalledWith(
        "https://api.paypal.com/v1/payments/carts",
        expect.objectContaining({
          intent: "order",
          purchase_units: expect.arrayContaining([
            expect.objectContaining({
              payee: { email: "orders-v1@example.com" }
            })
          ])
        }),
        expect.objectContaining({
          headers: expect.objectContaining({
            "X-PAYPAL-SECURITY-CONTEXT": '{"test":"context"}'
          })
        })
      );
    });

    it("should use v2 API when email does not start with orders-v1@", async () => {
      const mockCartRequest = {
        cartId: "test-cart-123",
        products: [{ productId: "prod-1", quantity: 1 }],
        customer: { email: "regular@example.com" }
      };

      const mockCart = {
        items: [],
        amount: {
          currency_code: "USD",
          value: "22.04",
          breakdown: {
            item_total: { currency_code: "USD", value: "19.99" },
            tax_total: { currency_code: "USD", value: "2.05" },
            shipping: { currency_code: "USD", value: "0.00" }
          }
        }
      };

      const mockResponse = { data: { id: "v2-order-id-123" } };
      mockedAxios.post.mockResolvedValue(mockResponse);

      const result = await client.createEcToken({
        cart: mockCart,
        cartRequest: mockCartRequest,
        request: mockRequest,
        accessToken: "test-token",
        hostname: "https://api.paypal.com"
      });

      expect(result).toBe("v2-order-id-123");
      expect(mockedAxios.post).toHaveBeenCalledWith(
        "https://api.paypal.com/v2/checkout/orders",
        expect.objectContaining({
          intent: "CAPTURE"
        }),
        expect.anything()
      );
    });

    it("should use v2 API when no customer email is provided", async () => {
      const mockCartRequest = {
        cartId: "test-cart-123",
        products: [{ productId: "prod-1", quantity: 1 }]
      };

      const mockCart = {
        items: [],
        amount: {
          currency_code: "USD",
          value: "22.04",
          breakdown: {
            item_total: { currency_code: "USD", value: "19.99" },
            tax_total: { currency_code: "USD", value: "2.05" },
            shipping: { currency_code: "USD", value: "0.00" }
          }
        }
      };

      const mockResponse = { data: { id: "v2-order-id-456" } };
      mockedAxios.post.mockResolvedValue(mockResponse);

      const result = await client.createEcToken({
        cart: mockCart,
        cartRequest: mockCartRequest,
        request: mockRequest,
        accessToken: "test-token",
        hostname: "https://api.paypal.com"
      });

      expect(result).toBe("v2-order-id-456");
      expect(mockedAxios.post).toHaveBeenCalledWith(
        "https://api.paypal.com/v2/checkout/orders",
        expect.objectContaining({
          intent: "CAPTURE"
        }),
        expect.anything()
      );
    });
  });

  describe("captureOrder", () => {
    it("should use v1 API when useV1API is true and payerId is provided", async () => {
      const mockResponse = { data: { id: "v1-payment-id-123" } };
      mockedAxios.post.mockResolvedValue(mockResponse);

      const result = await client.captureOrder({
        ecToken: "cart-id-123",
        accessToken: "test-token",
        hostname: "https://api.paypal.com",
        request: mockRequest,
        useV1API: true,
        payerId: "test-payer-id"
      });

      expect(result).toEqual({ id: "v1-payment-id-123" });
      expect(mockedAxios.post).toHaveBeenCalledWith(
        "www.paypal.com:17266/v1/payments/payment",
        expect.objectContaining({
          intent: "sale",
          cart: "cart-id-123",
          payer: {
            payment_method: "paypal",
            payer_info: {
              payer_id: "test-payer-id"
            }
          }
        }),
        expect.anything()
      );
    });

    it("should use v2 API when useV1API is false", async () => {
      const mockResponse = { data: { id: "v2-capture-id-123" } };
      mockedAxios.post.mockResolvedValue(mockResponse);

      const result = await client.captureOrder({
        ecToken: "order-id-123",
        accessToken: "test-token",
        hostname: "https://api.paypal.com",
        request: mockRequest,
        useV1API: false
      });

      expect(result).toEqual({ id: "v2-capture-id-123" });
      expect(mockedAxios.post).toHaveBeenCalledWith(
        "https://api.paypal.com/v2/checkout/orders/order-id-123/capture",
        {},
        expect.anything()
      );
    });

    it("should use v2 API when useV1API is true but payerId is missing", async () => {
      const mockResponse = { data: { id: "v2-capture-id-456" } };
      mockedAxios.post.mockResolvedValue(mockResponse);

      const result = await client.captureOrder({
        ecToken: "order-id-123",
        accessToken: "test-token",
        hostname: "https://api.paypal.com",
        request: mockRequest,
        useV1API: true
        // No payerId provided
      });

      expect(result).toEqual({ id: "v2-capture-id-456" });
      expect(mockedAxios.post).toHaveBeenCalledWith(
        "https://api.paypal.com/v2/checkout/orders/order-id-123/capture",
        {},
        expect.anything()
      );
    });
  });
});