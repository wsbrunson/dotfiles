import { describe, it, beforeEach, afterEach, vi, expect } from "vitest";
import { ALBEvent, Context as LambdaContext } from "aws-lambda";
import { ZodError } from "zod/v4";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { createCommerceOnboardingService } from "../../shared/commerce-onboarding";
import { parseJwtFromCartApi } from "../../shared/helpers/AppContextAuthorizer";
import {
  trackInitiatedUpdateCartFireAndForget,
  trackSuccessUpdateCartFireAndForget,
  trackFailedUpdateCartFireAndForget,
} from "../../shared/metrics/emitMetric";
import { logAPIResponseError } from "../../shared/errors";
import { getCacheImplementation } from "../../shared/cache/cacheFactory";
// @ts-ignore: Using CommonJS exports syntax
import { handler } from "./index";

vi.mock("../../shared/cache/cacheFactory", () => {
  const mockCache = {
    set: vi.fn().mockResolvedValue(undefined),
    get: vi.fn().mockResolvedValue(JSON.stringify({ id: "merchant-cart-123" })),
    delete: vi.fn().mockResolvedValue(undefined),
  };

  return {
    getCacheImplementation: vi.fn(() => mockCache),
  };
});
vi.mock("../../shared/commerce-onboarding");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");
vi.mock("../../shared/errors", async () => {
  const actual = await vi.importActual("../../shared/errors");
  return {
    ...actual,
    logAPIResponseError: vi.fn(),
  };
});
vi.mock("../../shared/logger/logger", () => ({
  logger: vi.fn(() => ({
    error: vi.fn(),
    info: vi.fn(),
    warn: vi.fn(),
  })),
}));

const validUpdateCartRequest = {
  id: "cart-123",
  items: [
    {
      item_id: "product-123",
      quantity: 2, // Updated quantity
      name: "Test Product",
      price: {
        currency_code: "USD",
        value: "100.00",
      },
    },
  ],
};

const mockUpdateCartResponse = {
  id: "cart-123",
  items: [
    {
      item_id: "product-123",
      quantity: 2, // Updated quantity
      name: "Test Product",
      price: {
        currency_code: "USD",
        value: "100.00",
      },
    },
  ],
};

describe("Generic Update Cart Lambda Handler", () => {
  let mockEvent: ALBEvent;
  let mockContext: LambdaContext;
  let mockMerchantClient: any;

  beforeEach(() => {
    // Mock the COMMERCE_ONBOARDING environment variables
    process.env.COMMERCE_ONBOARDING_API_KEY = "test-api-key";
    process.env.COMMERCE_ONBOARDING_URL =
      "https://test-commerce-onboarding.com";

    mockEvent = getMockALBEvent({
      path: "/cart/paypal-cart-123/complete",
      body: JSON.stringify(validUpdateCartRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    mockContext = {
      functionName: "generic-update-cart",
      invokedFunctionArn:
        "arn:aws:lambda:us-east-1:123456789012:function:generic-update-cart",
      awsRequestId: "test-request-id",
      callbackWaitsForEmptyEventLoop: true,
      functionVersion: "1",
      memoryLimitInMB: "128",
      logGroupName: "/aws/lambda/generic-update-cart",
      logStreamName: "2024/01/01/[$LATEST]test",
      getRemainingTimeInMillis: () => 3000,
      done: vi.fn(),
      fail: vi.fn(),
      succeed: vi.fn(),
    };

    mockMerchantClient = {
      updateCart: vi.fn().mockResolvedValue(mockUpdateCartResponse),
    };

    vi.mocked(createCommerceOnboardingService).mockReturnValue({
      setStoreContext: vi.fn(),
      updateCart: mockMerchantClient.updateCart,
      getStoreConfig: vi.fn().mockResolvedValue({
        storeConfig: { name: "test-merchant" },
        platformConfig: { name: "test-partner" }
      }),
    } as any);

    // Mock JWT in a way that consistently extracts shopware orchestrator
    const currentTime = Math.floor(Date.now() / 1000);
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com", // Note: The code will use "shopware" (without .com)
      iat: currentTime,
      exp: currentTime + 3600,
      external_id: [
        "Honey:393914911834861447",
        "PayPal:encrypted-merchant-123",
      ],
    });

    vi.mocked(trackInitiatedUpdateCartFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(trackSuccessUpdateCartFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(trackFailedUpdateCartFireAndForget).mockImplementation(
      () => undefined,
    );
    vi.mocked(logAPIResponseError).mockImplementation(() => {});
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  it("should update a cart successfully with shopware orchestrator", async () => {
    // Mock specific functions required for success path
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(200);
    expect(response.headers?.["Content-Type"]).toBe("application/json");
    expect(JSON.parse(response.body)).toEqual(mockUpdateCartResponse);

    expect(parseJwtFromCartApi).toHaveBeenCalledWith({
      event: mockEvent,
      logger: expect.any(Object),
    });

    expect(mockMerchantClient.updateCart).toHaveBeenCalledWith({
      cartId: "merchant-cart-123",
      data: validUpdateCartRequest,
      event: mockEvent,
    });
  });

  it("should update a cart successfully with ultracart orchestrator", async () => {
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "ultracart.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(200);
    expect(mockMerchantClient.updateCart).toHaveBeenCalledWith({
      cartId: "merchant-cart-123",
      data: validUpdateCartRequest,
      event: mockEvent,
    });
  });

  it("should track metrics for successful operations", async () => {
    // Reset JWT mock to ensure it's right for this test
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });

    await handler(mockEvent, mockContext);

    expect(trackInitiatedUpdateCartFireAndForget).toHaveBeenCalledWith(
      expect.objectContaining({
        orchestrator: "shopware",
      }),
    );

    expect(trackFailedUpdateCartFireAndForget).not.toHaveBeenCalled();
  });

  it("should handle missing cart ID in path", async () => {
    mockEvent = getMockALBEvent({
      path: "/cart//complete", // Missing cart ID
      body: JSON.stringify(validUpdateCartRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(404);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.details).toContainEqual(
      expect.objectContaining({
        description: "No cart id in path",
      }),
    );
  });

  it("should handle cache miss for merchant cart ID", async () => {
    // Ensure parseJwtFromCartApi returns correctly for this test case
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });

    const cache = vi.mocked(getCacheImplementation)();
    (cache.get as ReturnType<typeof vi.fn>).mockResolvedValueOnce(null);
    //
    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(404);
    const responseBody = JSON.parse(response.body);
    expect(responseBody.details[0].description).toContain(
      "Cache: No cart response found",
    );
  });

  it("should handle invalid JSON in request body", async () => {
    mockEvent = getMockALBEvent({
      path: "/cart/paypal-cart-123/complete",
      body: '{"invalid": json}',
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedUpdateCartFireAndForget).toHaveBeenCalledWith(
      expect.objectContaining({
        status: "500",
      }),
    );
  });

  it("should handle Zod validation errors", async () => {
    // Reset JWT mock to ensure it's right for this test
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });

    const invalidRequest = {
      id: "cart-123",
      items: [
        {
          // Missing required fields like item_id and quantity
          name: "Test Product",
        },
      ],
    };

    mockEvent = getMockALBEvent({
      path: "/cart/paypal-cart-123/complete",
      body: JSON.stringify(invalidRequest),
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    expect(trackFailedUpdateCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      status: "400",
    });
  });

  it("should handle JWT parsing errors", async () => {
    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw new Error("Invalid JWT token");
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedUpdateCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      status: "500",
    });
  });

  it("should handle invalid JWT payload structure", async () => {
    const zodError = new ZodError([
      {
        code: "invalid_type",
        expected: "string",
        path: ["aud"],
        message: "Required",
      } as any,
    ]);

    vi.mocked(parseJwtFromCartApi).mockImplementation(() => {
      throw zodError;
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(400);
    expect(trackFailedUpdateCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "Unknown",
      status: "400",
    });
  });

  it("should handle MerchantClient errors", async () => {
    // Reset JWT mock to ensure it's right for this test
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });

    mockMerchantClient.updateCart.mockRejectedValue(new Error("Network error"));

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedUpdateCartFireAndForget).toHaveBeenCalledWith({
      orchestrator: "shopware",
      status: "500",
    });
  });

  it("should log errors using logAPIResponseError", async () => {
    vi.mocked(parseJwtFromCartApi).mockReturnValue({
      iss: "paypal.com",
      sub: "merchant-123",
      aud: "shopware.com",
      iat: Math.floor(Date.now() / 1000),
      exp: Math.floor(Date.now() / 1000) + 3600,
    });
    mockMerchantClient.updateCart.mockRejectedValue(new Error("Test error"));

    await handler(mockEvent, mockContext);

    expect(logAPIResponseError).toHaveBeenCalledWith(
      expect.any(Object), // logger
      expect.any(Object), // APIError
    );
  });

  it("should handle empty request body", async () => {
    mockEvent = getMockALBEvent({
      path: "/cart/paypal-cart-123",
      body: "",
      headers: {
        Authorization: "Bearer valid-token",
      },
    });

    const response = await handler(mockEvent, mockContext);

    expect(response.statusCode).toBe(500);
    expect(trackFailedUpdateCartFireAndForget).toHaveBeenCalled();
  });
});
