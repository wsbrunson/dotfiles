data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

data "aws_vpc" "current" {}

data "aws_subnets" "public" {
  filter {
    name   = "tag:Name"
    values = ["*public*"]
  }
}

data "aws_subnets" "protected" {
  filter {
    name   = "tag:Name"
    values = ["*protected*"]
  }
}

data "aws_subnets" "isolated" {
  filter {
    name   = "tag:Name"
    values = ["*isolated*"]
  }
}

data "aws_lb" "pos" {
  name = local.alb_name
}

data "aws_lb_listener" "pos_https" {
  load_balancer_arn = data.aws_lb.pos.arn
  port              = 443
}

data "aws_ssm_parameter" "appcontext_verification_pem" {
  name = aws_ssm_parameter.appcontext_verification_pem.name
}

data "aws_ssm_parameter" "appcontext_jwt_verification_pem" {
  name = aws_ssm_parameter.appcontext_jwt_verification_pem.name
}

data "aws_ssm_parameter" "appcontext_jwt_aws_verification_pem" {
  name = aws_ssm_parameter.appcontext_jwt_aws_verification_pem.name
}

data "aws_ssm_parameter" "slack_hook_url" {
  name = aws_ssm_parameter.slack_hook_url.name
}

data "aws_ssm_parameter" "adorama_config" {
  name = aws_ssm_parameter.adorama_config.name
}

data "aws_ssm_parameter" "commerce_onboarding_url" {
  name = aws_ssm_parameter.commerce_onboarding_url.name
}

# Fetch the commerce onboarding API key from SSM Parameter Store
# This parameter is managed by the commerce-onboarding team
# Using the same path as PR #239
data "aws_ssm_parameter" "commerce_onboarding_api_key" {
  name = "/commerce-onboarding/api-key"
}