import { describe, it, beforeEach, vi, expect } from "vitest";
import { ALBEvent } from "aws-lambda";
import { getMockALBEvent } from "../../shared/test-utils/mockALBEvent";
import { SessionUtils } from "./SessionUtils";
import {
  PaymentDeclinedError,
  PaymentExpiredError,
  ConnectionResetError,
  ServiceUnavailableError,
} from "../../shared/errors";
import { verifyAppContext } from "../../shared/helpers/AppContextAuthorizer";
import { getCacheImplementation } from "../../shared/cache/cacheFactory";
import {
  trackInitiatedPayment,
  trackSuccessPayment,
  trackFailedPayment,
} from "../../shared/metrics/emitMetric";
import axios from "axios";

// @ts-ignore
import { handler } from "./index";

vi.mock("./SessionUtils");
vi.mock("../../shared/cache/cacheFactory");
vi.mock("../../shared/helpers/AppContextAuthorizer");
vi.mock("../../shared/metrics/emitMetric");
vi.mock("axios");

const exampleCheckoutSession = {
  paypal_payment_link: "https://paypal.com/checkout?token=EC-12345",
  api_key: "test-api-key",
  x_aos_stk: "test-stk-token",
};

const validCompleteCartRequest = {
  cartId: "valid-cart",
  paymentDetails: {
    amount: "100",
    paymentMethod: "PAYPAL",
    ecToken: "EC-12345",
    payerId: "payer-id",
    paymentId: "payment-id",
  },
  buyerApproval: true,
  successReturnUrl: "https://apple.com/success?token=test",
};

describe("Apple Complete Cart Lambda Handler", () => {
  let mockCache: {
    get: ReturnType<typeof vi.fn>;
    set: ReturnType<typeof vi.fn>;
    delete: ReturnType<typeof vi.fn>;
  };

  beforeEach(() => {
    mockCache = {
      get: vi.fn(),
      set: vi.fn(),
      delete: vi.fn(),
    };

    vi.mocked(getCacheImplementation).mockReturnValue(mockCache as any);
    vi.mocked(verifyAppContext).mockReturnValue(true);
    vi.mocked(trackInitiatedPayment).mockResolvedValue(undefined);
    vi.mocked(trackSuccessPayment).mockResolvedValue(undefined);
    vi.mocked(trackFailedPayment).mockResolvedValue(undefined);
    vi.mocked(SessionUtils).mockImplementation(
      () =>
      ({
        getCookiesForRequest: vi.fn().mockReturnValue("mock-cookies"),
        storeCookies: vi.fn(),
      } as any)
    );
    vi.mocked(axios.get).mockImplementation((url: string) => {
      if (url.includes("/shop/checkout/thankyou")) {
        return Promise.resolve({
          data: `<html><script id="init_data">{"thankYou":{"thankYouHeader":{"d":{"orderStatusUrl":"https://apple.com/vieworder/ORDER123"}}}}</script></html>`,
          headers: {},
        });
      }
      return Promise.resolve({
        data: "mock response",
        headers: { "set-cookie": ["mock=cookie"] },
      });
    });

    vi.mocked(axios.post).mockResolvedValue({
      data: "mock response",
      headers: {},
    });

    vi.clearAllMocks();
  });

  describe("Successful cart completion", () => {
    it("should process cart completion successfully", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
        shippingAddress: {
          addressLine1: "123 Main St",
          adminArea2: "Los Angeles",
          adminArea1: "CA",
          postalCode: "90001",
          countryCode: "US",
        },
        productDetails: [
          {
            productId: "product-1",
            quantity: 1,
          },
        ],
      });

      mockCache.get.mockResolvedValue(validCartCache);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });

      const result = await handler(event);

      expect(result.statusCode).toBe(200);
      expect(result.headers).toEqual({ "Content-Type": "application/json" });

      const responseBody = JSON.parse(result.body);
      expect(responseBody).toEqual({
        transactionId: "ORDER123",
        ecToken: "EC-12345",
        reviewOrderPage: "https://apple.com/vieworder/ORDER123",
      });

      expect(mockCache.get).toHaveBeenCalledWith("apple-valid-cart");
      expect(verifyAppContext).toHaveBeenCalledWith(event);
      expect(trackInitiatedPayment).toHaveBeenCalled();
      expect(trackSuccessPayment).toHaveBeenCalled();
    });

    it("should handle response without confirmation page URL", async () => {
      vi.useFakeTimers();

      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);
      vi.mocked(axios.get).mockImplementation((url: string) => {
        if (url.includes("/shop/checkout/thankyou")) {
          return Promise.resolve({
            data: `<html><script id="init_data">{"thankYou":{"thankYouHeader":{"d":{}}}}</script></html>`,
            headers: {},
          });
        }
        return Promise.resolve({
          data: "mock response",
          headers: { "set-cookie": ["mock=cookie"] },
        });
      });

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const handlerPromise = handler(event);
      await vi.runAllTimersAsync();
      const result = await handlerPromise;

      expect(result.statusCode).toBe(500);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "InternalServerError",
        status: 500,
        message: "Internal Server Error",
      });
      vi.useRealTimers();
    });
  });

  describe("Authentication failures", () => {
    it("should return 401 when AppContext verification fails", async () => {
      vi.mocked(verifyAppContext).mockReturnValue(false);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(401);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "UnauthorizedError",
        status: 401,
        message: "Unauthorized",
      });
      expect(trackFailedPayment).toHaveBeenCalled();
    });
  });

  describe("Validation failures", () => {
    it("should return 400 when payment method is not PAYPAL", async () => {
      const invalidRequest = {
        ...validCompleteCartRequest,
        paymentDetails: {
          ...validCompleteCartRequest.paymentDetails,
          paymentMethod: "CREDIT_CARD",
        },
      };

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(invalidRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(400);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "BadRequestError",
        status: 400,
        message: "Bad Request",
      });
      expect(trackFailedPayment).toHaveBeenCalled();
    });

    it("should handle malformed request body", async () => {
      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: "invalid-json",
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "InternalServerError",
        status: 500,
        message: "Internal Server Error",
      });
      expect(trackFailedPayment).toHaveBeenCalled();
    });

    it("should handle missing required fields", async () => {
      const incompleteRequest = {
        cartId: "valid-cart",
      };

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(incompleteRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(400);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "BadRequestError",
        status: 400,
        message: "Bad Request",
      });
      expect(trackFailedPayment).toHaveBeenCalled();
    });

    it("should return 400 when no success return URL provided", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      const requestWithoutSuccessUrl = {
        ...validCompleteCartRequest,
        successReturnUrl: undefined,
      };

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(requestWithoutSuccessUrl),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(400);
      expect(trackFailedPayment).toHaveBeenCalled();
    });
  });

  describe("Cart cache failures", () => {
    it("should return 404 when cart is not found in cache", async () => {
      mockCache.get.mockResolvedValue(null);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(404);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "NotFoundError",
        status: 404,
        message: "Not Found",
      });
      expect(mockCache.get).toHaveBeenCalledWith("apple-valid-cart");
      expect(trackFailedPayment).toHaveBeenCalled();
    });

    it("should return 500 when cached cart is malformed", async () => {
      mockCache.get.mockResolvedValue("invalid-json");

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "InternalServerError",
        status: 500,
        message: "Internal Server Error",
      });
      expect(trackFailedPayment).toHaveBeenCalled();
    });
  });

  describe("Apple service errors", () => {
    it("should handle redirect processing failures", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      // Mock axios to fail on redirect
      vi.mocked(axios.get).mockRejectedValue(
        new Error("Apple redirect failed")
      );

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(trackFailedPayment).toHaveBeenCalled();
    });

    it("should handle checkout page processing failures", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      // Mock successful redirect but failed checkout page
      vi.mocked(axios.get).mockImplementation((url: string) => {
        if (url.includes("success?token=test")) {
          return Promise.resolve({
            data: "redirect success",
            headers: { "set-cookie": ["redirect=cookie"] },
          });
        }
        if (url.includes("/shop/checkout")) {
          return Promise.reject(new Error("Checkout page failed"));
        }
        return Promise.resolve({
          data: "mock response",
          headers: {},
        });
      });

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(trackFailedPayment).toHaveBeenCalled();
    });

    it("should handle place order failures", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      // Mock successful GET requests but failed POST (place order)
      vi.mocked(axios.post).mockRejectedValue(new Error("Place order failed"));

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(trackFailedPayment).toHaveBeenCalled();
    });
  });

  describe("Metrics and logging", () => {
    it("should track payment metrics for successful completion", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      await handler(event);

      expect(trackInitiatedPayment).toHaveBeenCalledWith({
        orchestrator: "Apple",
        ecToken: "EC-12345",
      });

      expect(trackSuccessPayment).toHaveBeenCalledWith({
        duration: expect.any(Number),
        orchestrator: "Apple",
        ecToken: "EC-12345",
        status: "201",
      });
    });

    it("should track failed payment metrics on error", async () => {
      mockCache.get.mockRejectedValue(new Error("Cache error"));

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "InternalServerError",
        status: 500,
        message: "Internal Server Error",
      });
      expect(trackFailedPayment).toHaveBeenCalledWith({
        orchestrator: "Apple",
        ecToken: "EC-12345",
        status: "500",
      });
    });
  });

  describe("Request body parsing", () => {
    it("should handle string body correctly", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(200);
    });

    it("should handle object body correctly", async () => {
      const validCartCache = JSON.stringify({
        checkoutSession: exampleCheckoutSession,
        orderDetails: {
          ecToken: "EC-12345",
          status: "success",
        },
      });

      mockCache.get.mockResolvedValue(validCartCache);

      const event: ALBEvent = {
        ...getMockALBEvent({
          path: "/apple/complete/cart/valid-cart",
          body: JSON.stringify(validCompleteCartRequest),
        }),
        body: validCompleteCartRequest,
      } as any;

      const result = await handler(event);

      expect(result.statusCode).toBe(200);
    });
  });

  describe("Error handling edge cases", () => {
    it("should handle errors without status property", async () => {
      mockCache.get.mockRejectedValue("String error");

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "InternalServerError",
        status: 500,
        message: "Internal Server Error",
      });
      expect(trackFailedPayment).toHaveBeenCalledWith({
        orchestrator: "Apple",
        ecToken: "EC-12345",
        status: "500",
      });
    });

    it("should handle null errors", async () => {
      mockCache.get.mockRejectedValue(null);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      const responseBody = JSON.parse(result.body);
      expect(responseBody.name).toBe("InternalServerError");
      expect(responseBody.status).toBe(500);
      expect(responseBody.message).toBe("Internal Server Error");
    });

    it("should handle errors with custom status codes", async () => {
      const customError = new Error("Custom error");
      (customError as any).status = 404;
      mockCache.get.mockRejectedValue(customError);

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(500);
      expect(JSON.parse(result.body)).toMatchObject({
        name: "InternalServerError",
        status: 500,
        message: "Internal Server Error",
      });
      expect(trackFailedPayment).toHaveBeenCalledWith({
        orchestrator: "Apple",
        ecToken: "EC-12345",
        status: "500",
      });
    });
  });

  describe("Additional Error Type Coverage", () => {
    it("should handle PaymentDeclinedError correctly", async () => {
      // Mock cache to throw PaymentDeclinedError
      mockCache.get.mockRejectedValue(
        new PaymentDeclinedError("test-debug-id", {
          details: [
            {
              description: "Apple Pay payment was declined",
            },
          ],
        })
      );

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(422);
      const responseBody = JSON.parse(result.body);
      expect(responseBody.name).toBe("PaymentDeclinedError");
      expect(responseBody.status).toBe(422);
      expect(responseBody.message).toBe("Unprocessable Entity");
      expect(responseBody.details).toEqual(
        expect.arrayContaining([
          expect.objectContaining({
            issue: "PAYMENT_DECLINED",
          }),
        ])
      );
    });

    it("should handle PaymentExpiredError correctly", async () => {
      // Mock cache to throw PaymentExpiredError
      mockCache.get.mockRejectedValue(
        new PaymentExpiredError("test-debug-id", {
          details: [
            {
              description: "Apple Pay authorization has expired",
            },
          ],
        })
      );

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(422);
      const responseBody = JSON.parse(result.body);
      expect(responseBody.name).toBe("PaymentExpiredError");
      expect(responseBody.status).toBe(422);
      expect(responseBody.message).toBe("Unprocessable Entity");
      expect(responseBody.details).toEqual(
        expect.arrayContaining([
          expect.objectContaining({
            issue: "PAYMENT_EXPIRED",
          }),
        ])
      );
    });

    it("should handle ConnectionResetError correctly", async () => {
      // Mock cache to throw ConnectionResetError
      mockCache.get.mockRejectedValue(
        new ConnectionResetError("test-debug-id", {
          details: [
            {
              description: "Connection was reset by Apple",
            },
          ],
        })
      );

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(503);
      const responseBody = JSON.parse(result.body);
      expect(responseBody.name).toBe("ConnectionResetError");
      expect(responseBody.status).toBe(503);
      expect(responseBody.message).toBe(
        "Connection was reset by the remote server"
      );
      expect(responseBody.details).toEqual(
        expect.arrayContaining([
          expect.objectContaining({
            issue: "CONNECTION_RESET",
          }),
        ])
      );
    });

    it("should handle ServiceUnavailableError correctly", async () => {
      // Mock cache to throw ServiceUnavailableError
      mockCache.get.mockRejectedValue(
        new ServiceUnavailableError("test-debug-id", {
          details: [
            {
              description: "Apple store service temporarily unavailable",
            },
          ],
        })
      );

      const event = getMockALBEvent({
        path: "/apple/complete/cart/valid-cart",
        body: JSON.stringify(validCompleteCartRequest),
      });
      const result = await handler(event);

      expect(result.statusCode).toBe(503);
      const responseBody = JSON.parse(result.body);
      expect(responseBody.name).toBe("ServiceUnavailableError");
      expect(responseBody.status).toBe(503);
      expect(responseBody.message).toBe("Service Unavailable");
    });
  });
});
