#!/opt/homebrew/bin/fish

# Fish wrapper for aws-profile script
# Automatically sources the output so AWS_PROFILE gets set in the current shell

function awsp --description "Switch AWS profiles with automatic sourcing"
    # Call the aws-profile script and capture output
    set output (aws-profile $argv)
    set exit_code $status

    if test $exit_code -eq 0
        # Parse and execute the set command for AWS_PROFILE
        for line in $output
            if string match -q "set -gx AWS_PROFILE*" $line
                eval $line
                break
            end
        end

        # Show the informational messages
        for line in $output
            if string match -q "#*" $line
                echo $line >&2
            end
        end
    else
        # If aws-profile failed, show the error
        echo $output >&2
        return $exit_code
    end
end

# If script is called directly (not sourced), run the function
if status is-interactive
    awsp $argv
end