import { createMiddleware } from "hono/factory";
import {
  honoRequestInit,
  honoRequestSuccess,
  honoRequestError,
  type HonoRequestMetrics,
} from "./honoMetrics";

/**
 * Hono middleware that automatically instruments HTTP requests with DataDog metrics
 * Emits metrics similar to Express auto-instrumentation:
 * - http.requests.count - Total request count
 * - http.requests.success.count - Successful requests with status codes
 * - http.requests.error.count - Failed requests with error details
 * - http.request.duration - Request duration in milliseconds
 *
 * @param platform - Platform identifier (e.g., 'wix', 'shopify', 'bigcommerce')
 * @returns Hono middleware function
 *
 * @example
 * ```typescript
 * import { Hono } from 'hono';
 * import { honoMetricsMiddleware } from 'shared/instrumentation/honoMetricsMiddleware';
 *
 * const app = new Hono();
 *
 * // Apply metrics middleware to all routes
 * app.use('*', honoMetricsMiddleware('wix'));
 *
 * app.get('/cart', (c) => c.json({ message: 'Cart endpoint' }));
 * app.post('/cart/complete', (c) => c.json({ message: 'Complete cart' }));
 * ```
 *
 * The middleware will automatically:
 * - Track request initiation with method, route, and platform tags
 * - Track successful completion with status codes and response times
 * - Track errors with error types and status codes
 * - Normalize route paths to prevent high cardinality (/:id, /:uuid)
 */
export function honoMetricsMiddleware(platform?: string) {
  return createMiddleware(async (c, next) => {
    // Initialize request metrics tracking
    const metrics = honoRequestInit(c, platform);

    // Store metrics in context for potential access by route handlers
    c.set("requestMetrics", metrics);

    try {
      // Execute the route handler
      await next();

      // Track successful completion
      honoRequestSuccess(metrics, c.res.status);
    } catch (error) {
      // Track failed completion
      honoRequestError(metrics, error);

      // Re-throw the error so Hono can handle it normally
      throw error;
    }
  });
}

/**
 * Advanced middleware with custom configuration options
 *
 * @param options - Configuration options
 * @returns Hono middleware function
 *
 * @example
 * ```typescript
 * app.use('*', honoMetricsMiddlewareAdvanced({
 *   platform: 'shopify',
 *   skipRoutes: ['/health', '/metrics'],
 *   enableDurationHistogram: true,
 * }));
 * ```
 */
export function honoMetricsMiddlewareAdvanced(options: {
  platform?: string;
  skipRoutes?: string[];
  enableDurationHistogram?: boolean;
}) {
  const {
    platform,
    skipRoutes = [],
    enableDurationHistogram = false,
  } = options;

  return createMiddleware(async (c, next) => {
    // Skip instrumentation for specified routes
    if (skipRoutes.some((route) => c.req.path.startsWith(route))) {
      await next();
      return;
    }

    // Initialize request metrics tracking
    const metrics = honoRequestInit(c, platform);

    // Store metrics in context
    c.set("requestMetrics", metrics);

    try {
      // Execute the route handler
      await next();

      // Track successful completion
      honoRequestSuccess(c.get("requestMetrics"), c.res.status);

      // TODO: Add histogram metrics if enableDurationHistogram is true
      // This would require extending the DataDog metrics to support histograms
    } catch (error) {
      // Track failed completion
      honoRequestError(c.get("requestMetrics"), error);

      // Re-throw the error so Hono can handle it normally
      throw error;
    }
  });
}

/**
 * Type declaration for accessing request metrics from Hono context
 *
 * @example
 * ```typescript
 * app.get('/custom', (c) => {
 *   const metrics = c.get('requestMetrics') as HonoRequestMetrics | undefined;
 *   if (metrics) {
 *     console.log(`Request started at: ${metrics.startTime}`);
 *   }
 *   return c.json({ success: true });
 * });
 * ```
 */
declare module "hono" {
  interface ContextVariableMap {
    requestMetrics: HonoRequestMetrics;
  }
}
