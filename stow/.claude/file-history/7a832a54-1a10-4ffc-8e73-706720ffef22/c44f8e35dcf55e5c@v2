resource "aws_ssm_parameter" "appcontext_verification_pem" {
  name        = "/${local.app_name}/appcontext_verification_pem"
  description = "Public key used to verify incoming PayPal application contexts"
  type        = "SecureString"
  value       = "no-value-in-terraform"
  overwrite = true

  lifecycle {
    ignore_changes = [value]
  }
}

resource "aws_ssm_parameter" "slack_hook_url" {
  name        = "/${local.app_name}/slack_hook_url"
  description = "Slack webhook URL for notifications"
  type        = "String"
  value       = "no-value-in-terraform"
  overwrite = true

  lifecycle {
    ignore_changes = [value]
  }
}

